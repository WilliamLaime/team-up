<%# ── Email de réinitialisation du mot de passe ───────────────────────────── %>
<%# Envoyé automatiquement par Devise quand l'utilisateur clique sur "Mot de passe oublié" %>
<%# Inline CSS obligatoire dans les emails — les clients mail ignorent les feuilles de style externes %>
<div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #111111; padding: 40px 20px; min-height: 100vh;">

  <%# Carte centrale %>
  <div style="max-width: 520px; margin: 0 auto; background-color: #1a1c1a; border-radius: 16px; border: 1px solid rgba(255,255,255,0.08); overflow: hidden;">

    <%# En-tête avec logo %>
    <div style="background-color: #111111; padding: 28px 40px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.06);">
      <span style="font-size: 1.6rem; font-weight: 800; color: #f0f0f0; letter-spacing: -0.5px;">
        TEAMS<span style="color: #1EDD88;">-UP</span>
      </span>
    </div>

    <%# Corps du message %>
    <div style="padding: 36px 40px;">

      <%# Icône clé %>
      <div style="text-align: center; margin-bottom: 24px;">
        <div style="display: inline-block; background-color: rgba(30, 221, 136, 0.12); border-radius: 50%; width: 64px; height: 64px; line-height: 64px; font-size: 28px;">
          🔑
        </div>
      </div>

      <%# Titre %>
      <h1 style="color: #f0f0f0; font-size: 1.4rem; font-weight: 700; text-align: center; margin: 0 0 8px 0;">
        Réinitialise ton mot de passe
      </h1>

      <p style="color: rgba(255,255,255,0.45); font-size: 0.9rem; text-align: center; margin: 0 0 28px 0;">
        <strong style="color: rgba(255,255,255,0.7);"><%= @resource.email %></strong>
      </p>

      <%# Message principal %>
      <p style="color: rgba(255,255,255,0.65); font-size: 0.95rem; line-height: 1.6; margin: 0 0 28px 0;">
        Tu as demandé à réinitialiser ton mot de passe. Clique sur le bouton ci-dessous pour en choisir un nouveau.
      </p>

      <%# Bouton CTA centré %>
      <div style="text-align: center; margin-bottom: 28px;">
        <%= link_to edit_password_url(@resource, reset_password_token: @token),
            style: "display: inline-block; background-color: #1EDD88; color: #111111; font-weight: 700; font-size: 1rem; padding: 14px 36px; border-radius: 50px; text-decoration: none; letter-spacing: 0.3px;" do %>
          Changer mon mot de passe
        <% end %>
      </div>

      <%# Lien texte de secours %>
      <p style="color: rgba(255,255,255,0.3); font-size: 0.78rem; text-align: center; margin: 0 0 20px 0;">
        Si le bouton ne fonctionne pas, copie ce lien dans ton navigateur :<br>
        <span style="color: rgba(30, 221, 136, 0.6); word-break: break-all;">
          <%= edit_password_url(@resource, reset_password_token: @token) %>
        </span>
      </p>

      <%# Avertissement sécurité %>
      <p style="color: rgba(255,255,255,0.3); font-size: 0.82rem; text-align: center; margin: 0; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06);">
        Si tu n'es pas à l'origine de cette demande, ignore cet email.<br>
        Ton mot de passe ne sera pas modifié.
      </p>

    </div>

    <%# Pied de page %>
    <div style="background-color: #111111; padding: 20px 40px; text-align: center; border-top: 1px solid rgba(255,255,255,0.06);">
      <p style="color: rgba(255,255,255,0.25); font-size: 0.78rem; margin: 0;">
        © <%= Date.today.year %> Teams-Up — Tous droits réservés.
      </p>
    </div>

  </div>
</div>
