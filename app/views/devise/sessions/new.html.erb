<%# ── Page de connexion ─────────────────────────────────────────────────────── %>
<%# Fond sombre pleine page + carte centrée %>
<div class="auth-page">
  <div class="auth-card">

    <%# Titre avec accent vert %>
    <h2><span class="accent">Connexion</span></h2>

    <%# Formulaire Devise géré par simple_form %>
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-inputs">
        <%# Champ Email %>
        <%= f.input :email,
                    label: "Email",
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email", placeholder: "votre@email.com" } %>

        <%# Champ Mot de passe %>
        <%= f.input :password,
                    label: "Mot de passe",
                    required: false,
                    input_html: { autocomplete: "current-password", placeholder: "••••••••" } %>

        <%# Case à cocher "Se souvenir de moi" (si activé dans Devise) %>
        <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
      </div>

      <%# Bouton de soumission — centré, taille auto %>
      <div class="form-actions form-actions--center mt-3">
        <%= f.button :submit, "Se connecter" %>
      </div>

    <% end %>

    <%# Liens secondaires juste sous le bouton "Se connecter" %>
    <div class="auth-links mt-3">
      <%= render "devise/shared/links" %>
    </div>

    <%# Séparateur avec texte "ou" %>
    <div class="auth-divider-or">
      <span>ou</span>
    </div>

    <%# Bouton de connexion Google centré — style officiel Google %>
    <div class="text-center">
      <%= button_to user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, class: "btn-google" do %>
        <%# Logo Google en SVG officiel %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20">
          <path fill="#EA4335" d="M24 9.5c3.14 0 5.95 1.08 8.17 2.86l6.09-6.09C34.46 3.1 29.5 1 24 1 14.82 1 7.07 6.48 3.64 14.18l7.08 5.5C12.4 13.72 17.73 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.5 24.5c0-1.64-.15-3.22-.42-4.74H24v8.98h12.67c-.55 2.96-2.2 5.47-4.68 7.16l7.19 5.58C43.39 37.3 46.5 31.36 46.5 24.5z"/>
          <path fill="#FBBC05" d="M10.72 28.32A14.6 14.6 0 0 1 9.5 24c0-1.5.26-2.95.72-4.32l-7.08-5.5A23.94 23.94 0 0 0 0 24c0 3.87.93 7.52 2.58 10.74l8.14-6.42z"/>
          <path fill="#34A853" d="M24 47c5.5 0 10.12-1.82 13.5-4.94l-7.19-5.58c-1.87 1.26-4.27 2.02-6.31 2.02-6.27 0-11.6-4.22-13.28-9.93l-8.14 6.42C7.07 41.52 14.82 47 24 47z"/>
          <path fill="none" d="M0 0h48v48H0z"/>
        </svg>
        Se connecter avec Google
      <% end %>
    </div>

  </div>
</div>
