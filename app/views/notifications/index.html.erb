<%# Page : toutes les notifications de l'utilisateur connecté %>

<%# data-controller branche le contrôleur Stimulus "notification-page" sur toute la page %>
<div class="notifications-page" data-controller="notification-page">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-7 col-md-9">

        <%# Bouton retour — même DA que sur toutes les autres pages %>
        <%= render "shared/nav_button", label: "Retour", direction: "back", extra_class: "mb-4" %>

        <%# ── En-tête ── %>
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div class="d-flex align-items-center gap-2">
            <h1 class="notif-page-title mb-0">Notifications</h1>
            <%# Badge avec le nombre de non lues %>
            <% unread = @notifications.count { |n| !n.read? } %>
            <% if unread > 0 %>
              <span class="notif-page-badge" data-notification-page-target="badge">
                <%= unread %> non lue<%= unread > 1 ? "s" : "" %>
              </span>
            <% end %>
          </div>

          <%# Bouton "Tout lire" — visible seulement s'il y a des non lues %>
          <% if unread > 0 %>
            <%#
              form: { data: { action: ... } } → Stimulus intercepte le submit
              data: { target: "markAllBtn" }   → permet au contrôleur de supprimer ce bouton après l'action
            %>
            <%= button_to mark_all_read_notifications_path,
                method: :patch,
                form: { data: { action: "submit->notification-page#markAllRead" } },
                data: { notification_page_target: "markAllBtn" },
                class: "btn btn-link btn-sm p-0 text-decoration-none text-primary small" do %>
              Tout lire
            <% end %>
          <% end %>
        </div>

        <%# ── Liste des notifications ── %>
        <% if @notifications.any? %>
          <div class="notif-page-list">
            <% @notifications.each do |notif| %>

              <%# Wrapper relatif pour pouvoir positionner la croix en absolu %>
              <div class="notif-page-wrapper">

                <%# Bouton principal : marque comme lue puis redirige %>
                <%= button_to mark_read_notification_path(notif), method: :patch,
                    class: "notif-page-item w-100 text-start border-0 p-0 #{notif.read? ? 'is-read' : 'is-unread'}" do %>
                  <div class="d-flex align-items-start gap-3 px-4 py-3">

                    <%# Icône : cloche verte si non lue, check grisé si lue %>
                    <div class="notif-page-icon flex-shrink-0 mt-1">
                      <% if notif.read? %>
                        <i data-lucide="check-circle" style="width:18px;height:18px;color:rgba(255,255,255,0.3);"></i>
                      <% else %>
                        <i data-lucide="bell-dot" style="width:18px;height:18px;" class="text-primary"></i>
                      <% end %>
                    </div>

                    <%# Message + date %>
                    <div class="flex-grow-1">
                      <div class="notif-page-message <%= notif.read? ? 'read' : 'unread' %>">
                        <%= notif.message %>
                      </div>
                      <small class="notif-page-time">
                        <i data-lucide="clock" style="width:11px;height:11px;"></i>
                        <%= time_ago_in_words(notif.created_at) %>
                      </small>
                    </div>

                    <%# Point vert "nouveau" à droite pour les non lues %>
                    <% unless notif.read? %>
                      <span class="notif-page-dot flex-shrink-0 mt-2"></span>
                    <% end %>

                  </div>
                <% end %>

                <%# Bouton supprimer (croix) — positionné en absolu dans le wrapper %>
                <%# C'est un formulaire séparé car button_to génère déjà un <form> %>
                <%= button_to notification_path(notif), method: :delete,
                    class: "notif-delete-btn",
                    title: "Supprimer" do %>
                  <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                <% end %>

              </div>

            <% end %>
          </div>

        <% else %>
          <%# État vide %>
          <div class="notif-page-empty text-center py-5">
            <i data-lucide="inbox" style="width:48px;height:48px;color:rgba(255,255,255,0.2);"></i>
            <p class="mt-3">Tu n'as aucune notification pour le moment.</p>
          </div>
        <% end %>

      </div>
    </div>
  </div>
</div>
