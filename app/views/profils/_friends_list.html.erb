<%# Section "Amis" affichée sur la page de profil
    Paramètres locaux :
      - friends      : collection d'utilisateurs amis (acceptés)
      - own_profile  : true si on affiche son propre profil (affiche le bouton Retirer)
    Note : les demandes en attente sont gérées directement dans show.html.erb, au-dessus des matchs %>

<%# Ne rien afficher si la collection d'amis n'est pas chargée (profil d'un autre user) %>
<% return if friends.nil? %>

<%# ── Liste des amis acceptés ── %>
<div style="margin-top:0.5rem;">
  <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700;
              text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88;
              margin-bottom:0.75rem;">
    <i data-lucide="users" style="width:14px; height:14px;"></i>
    Amis (<%= friends.count %>)
  </div>

  <div class="match-block" style="padding:1rem;">
    <% if friends.any? %>
      <%# Grille de pilules pour chaque ami %>
      <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
        <% friends.each do |friend| %>
          <%# Chaque ami : lien vers son profil + bouton Retirer (uniquement sur son propre profil) %>
          <div style="display:inline-flex; align-items:center; gap:0.25rem;">
            <%# data-turbo-frame="_top" → navigation complète au lieu de naviguer dans le turbo_frame %>
            <%= link_to user_profil_path(friend),
                  data: { turbo_frame: "_top" },
                  style: "display:inline-flex; align-items:center; gap:0.5rem; padding:0.3rem 0.7rem;
                          background:var(--theme-hover-bg); border:1px solid var(--theme-border);
                          border-radius:999px; text-decoration:none;" do %>
              <% if friend.profil&.avatar&.attached? %>
                <%= image_tag friend.profil.avatar,
                      style: "width:22px; height:22px; border-radius:50%; object-fit:cover; flex-shrink:0;",
                      alt: friend.display_name %>
              <% else %>
                <span style="width:22px; height:22px; border-radius:50%; background:var(--theme-hover-bg-strong);
                             display:inline-flex; align-items:center; justify-content:center;
                             font-size:0.6rem; font-weight:800; color:var(--theme-text-muted); flex-shrink:0;">
                  <%= friend.display_name.first.upcase %>
                </span>
              <% end %>
              <span style="font-size:0.78rem; font-weight:600; color:var(--theme-text-primary); white-space:nowrap;">
                <%= friend.display_name %>
              </span>
            <% end %>
            <%# Bouton Retirer visible uniquement sur son propre profil %>
            <% if local_assigns[:own_profile] %>
              <% remove_modal_id = "removeFriendListModal#{friend.id}" %>
              <%# Bouton qui ouvre la modale de confirmation (ne supprime pas directement) %>
              <button type="button"
                      data-bs-toggle="modal"
                      data-bs-target="#<%= remove_modal_id %>"
                      style="display:inline-flex; align-items:center; justify-content:center;
                             width:20px; height:20px; padding:0;
                             color:var(--theme-text-muted); background:var(--theme-hover-bg);
                             border:1px solid var(--theme-border); border-radius:50%;
                             cursor:pointer; flex-shrink:0;"
                      title="Retirer <%= friend.display_name %> de vos amis">
                <i data-lucide="x" style="width:10px; height:10px;"></i>
              </button>

              <%# Modale hissée hors du conteneur via content_for :modals
                  (évite les problèmes de z-index causés par les contextes de stacking CSS) %>
              <% content_for :modals do %>
              <div class="modal fade" id="<%= remove_modal_id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-sm">
                  <div class="modal-content" style="background:var(--theme-bg-card); border:1px solid var(--theme-border); border-radius:12px;">

                    <div class="modal-body text-center" style="padding:1.5rem 1.5rem 1rem;">
                      <div style="font-size:2rem; margin-bottom:0.75rem;">👋</div>
                      <p style="color:var(--theme-text-strong); font-weight:700; font-size:0.95rem; margin-bottom:0.3rem;">
                        Retirer <%= friend.profil&.first_name || friend.display_name %> ?
                      </p>
                      <p style="color:var(--theme-text-muted); font-size:0.8rem; margin:0;">
                        Vous ne serez plus amis et ne pourrez plus vous envoyer de messages.
                      </p>
                    </div>

                    <div class="modal-footer" style="border-top:1px solid var(--theme-border); padding:0.75rem 1.5rem; gap:0.5rem; justify-content:center;">
                      <%# Annuler — ferme juste la modale %>
                      <button type="button"
                              data-bs-dismiss="modal"
                              style="font-size:0.8rem; font-weight:600; color:var(--theme-text-muted);
                                     background:var(--theme-hover-bg); border:1px solid var(--theme-border);
                                     border-radius:20px; padding:0.4rem 1rem; cursor:pointer;">
                        Annuler
                      </button>

                      <%# Confirmer — soumet la vraie requête DELETE %>
                      <%= button_to user_friendship_path(friend),
                            method: :delete,
                            data: { turbo_frame: "_top" },
                            style: "font-size:0.8rem; font-weight:700; color:#fff;
                                    background:rgba(220,53,69,0.8); border:1px solid rgba(220,53,69,0.5);
                                    border-radius:20px; padding:0.4rem 1rem; cursor:pointer;" do %>
                        Retirer
                      <% end %>
                    </div>

                  </div>
                </div>
              </div>
            <% end %> <%# fin content_for :modals %>
            <% end %> <%# fin if own_profile %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align:center; padding:0.75rem 0; color:rgba(255,255,255,0.3);">
        <i data-lucide="users" style="width:22px; height:22px; display:block; margin:0 auto 0.3rem;"></i>
        <p style="font-size:0.82rem; margin:0;">Aucun ami pour l'instant.</p>
      </div>
    <% end %>
  </div>
</div>
