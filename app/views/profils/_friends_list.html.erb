<%# Section "Amis" affichée sur la page de profil
    Paramètres locaux :
      - friends      : collection d'utilisateurs amis (acceptés)
      - own_profile  : true si on affiche son propre profil (affiche le bouton Retirer)
    Note : les demandes en attente sont gérées directement dans show.html.erb, au-dessus des matchs %>

<%# Ne rien afficher si la collection d'amis n'est pas chargée (profil d'un autre user) %>
<% return if friends.nil? %>

<%# ── Liste des amis acceptés ── %>
<div style="margin-top:0.5rem;">
  <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700;
              text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88;
              margin-bottom:0.75rem;">
    <i data-lucide="users" style="width:14px; height:14px;"></i>
    Amis (<%= friends.count %>)
  </div>

  <div class="match-block" style="padding:1rem;">
    <% if friends.any? %>
      <%# Grille de pilules pour chaque ami %>
      <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
        <% friends.each do |friend| %>
          <%# Chaque ami : lien vers son profil + bouton Retirer (uniquement sur son propre profil) %>
          <div style="display:inline-flex; align-items:center; gap:0.25rem;">
            <%# data-turbo-frame="_top" → navigation complète au lieu de naviguer dans le turbo_frame %>
            <%= link_to user_profil_path(friend),
                  data: { turbo_frame: "_top" },
                  style: "display:inline-flex; align-items:center; gap:0.5rem; padding:0.3rem 0.7rem;
                          background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);
                          border-radius:999px; text-decoration:none;" do %>
              <% if friend.profil&.avatar&.attached? %>
                <%= image_tag friend.profil.avatar,
                      style: "width:22px; height:22px; border-radius:50%; object-fit:cover; flex-shrink:0;",
                      alt: friend.display_name %>
              <% else %>
                <span style="width:22px; height:22px; border-radius:50%; background:#333;
                             display:inline-flex; align-items:center; justify-content:center;
                             font-size:0.6rem; font-weight:800; color:rgba(255,255,255,0.5); flex-shrink:0;">
                  <%= friend.display_name.first.upcase %>
                </span>
              <% end %>
              <span style="font-size:0.78rem; font-weight:600; color:rgba(255,255,255,0.75); white-space:nowrap;">
                <%= friend.display_name %>
              </span>
            <% end %>
            <%# Bouton Retirer visible uniquement sur son propre profil %>
            <% if local_assigns[:own_profile] %>
              <%# data-turbo-frame="_top" → force navigation complète pour afficher le toast flash %>
              <%= button_to user_friendship_path(friend),
                    method: :delete,
                    data: { turbo_frame: "_top" },
                    style: "display:inline-flex; align-items:center; justify-content:center;
                            width:20px; height:20px; padding:0;
                            color:rgba(255,255,255,0.25); background:rgba(255,255,255,0.04);
                            border:1px solid rgba(255,255,255,0.08); border-radius:50%;
                            cursor:pointer; flex-shrink:0;",
                    title: "Retirer #{friend.display_name} de vos amis" do %>
                <i data-lucide="x" style="width:10px; height:10px;"></i>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align:center; padding:0.75rem 0; color:rgba(255,255,255,0.3);">
        <i data-lucide="users" style="width:22px; height:22px; display:block; margin:0 auto 0.3rem;"></i>
        <p style="font-size:0.82rem; margin:0;">Aucun ami pour l'instant.</p>
      </div>
    <% end %>
  </div>
</div>
