                <%= current_user.display_name %>
              </h1>
              <i data-lucide="badge-check" style="width:18px; height:18px; color:#1EDD88; flex-shrink:0;"></i>
            </div>

            <%# Rôle + localisation + badge niveau %>
            <div style="display:flex; align-items:center; flex-wrap:wrap; gap:0.35rem; margin-bottom:0.85rem;">
              <% if @profil.role.present? %>
