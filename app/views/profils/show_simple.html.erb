<%# ── Page profil simplifiée (sans gamification) ───────────────────────────── %>

<%# Abonnement temps réel au bouton ami — reçoit les mises à jour quand la relation change %>
<% if user_signed_in? && current_user != @profil_user %>
  <%= turbo_stream_from "friend_button_#{current_user.id}_#{@profil_user.id}" %>
<% end %>

<%# Abonnement temps réel à la liste d'amis — uniquement sur son propre profil %>
<% if user_signed_in? && current_user == @profil_user %>
  <%= turbo_stream_from "friends_list_#{@profil_user.id}" %>
<% end %>

<div class="profil-page" style="background-color:#111111; min-height:calc(100vh - 130px); padding:2.5rem 0 4rem;">
  <div class="container">

    <%# ── Lien retour ────────────────────────────────────────────────────────── %>
    <div style="margin-bottom:1.5rem;">
      <%= render "shared/nav_button", url: root_path, label: "Retour", direction: "back", extra_class: "mb-4" %>
    </div>

    <%# ══════════════════════════════════════════════════════════════════════════ %>
    <%# LAYOUT : carte profil à gauche (col-lg-4) | matchs + avis à droite (col-lg-8) %>
    <%# ══════════════════════════════════════════════════════════════════════════ %>
    <div class="row g-4 align-items-start">

      <%# ══════════════════════ COLONNE GAUCHE (col-lg-4) ═══════════════════════ %>
      <%# Carte profil propre : avatar, nom, ville, note, sports, description %>
      <div class="col-lg-4">

        <%# ── Titre "Profil" — EN DEHORS de la card ────────────────────────────── %>
        <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.75rem;">
          <i data-lucide="user" style="width:14px; height:14px;"></i>
          Profil
        </div>

        <%# ── Card : avatar + nom + note + sports + stats + description ─────────── %>
        <div class="match-block" style="padding:1.5rem;">

          <%# ── Avatar + nom + actions ─────────────────────────────────────────── %>
          <div style="display:flex; align-items:flex-start; gap:1rem; margin-bottom:1rem;">

            <%# Avatar %>
            <div style="flex-shrink:0;">
              <% if @profil.avatar.attached? %>
                <%= image_tag @profil.avatar,
                    alt: "Photo de #{@profil_user.display_name}",
                    style: "width:72px; height:72px; border-radius:50%; object-fit:cover; border:2px solid rgba(30,221,136,0.4); display:block;" %>
              <% else %>
                <%# Initiale si pas d'avatar %>
                <div style="width:72px; height:72px; border-radius:50%; border:2px solid rgba(255,255,255,0.12); background:#242624; display:flex; align-items:center; justify-content:center; font-size:1.6rem; font-weight:800; color:rgba(255,255,255,0.4);">
                  <%= @profil.first_name&.first&.upcase || "?" %>
                </div>
              <% end %>
            </div>

            <%# Nom + bouton modifier ou boutons action %>
            <div style="flex:1; min-width:0;">

              <%# Nom + bouton Modifier alignés sur la même ligne %>
              <div style="display:flex; align-items:center; justify-content:space-between; gap:0.5rem; margin-bottom:0.2rem;">
                <h1 style="font-size:1.15rem; font-weight:800; color:#fff; margin:0; line-height:1.2;">
                  <%= @profil_user.display_name %>
                </h1>
                <% if current_user == @profil_user %>
                  <%= link_to edit_profil_path,
                      style: "flex-shrink:0; display:inline-flex; align-items:center; gap:0.3rem; font-size:0.72rem; font-weight:700; color:rgba(255,255,255,0.5); border:1px solid rgba(255,255,255,0.12); border-radius:999px; padding:0.25rem 0.7rem; text-decoration:none;" do %>
                    <i data-lucide="pencil" style="width:10px; height:10px;"></i>
                    Modifier
                  <% end %>
                <% end %>
              </div>

              <%# Ville préférée %>
              <div style="display:flex; align-items:center; gap:0.25rem; font-size:0.78rem; color:rgba(255,255,255,0.45); margin-bottom:0.5rem;">
                <i data-lucide="map-pin" style="width:11px; height:11px; color:rgba(255,255,255,0.2);"></i>
                <%= @profil.preferred_city.presence || "—" %>
              </div>

              <%# Boutons ami + message — uniquement sur le profil d'un autre utilisateur %>
              <% if current_user != @profil_user %>
                <div style="display:flex; align-items:center; gap:0.4rem; flex-wrap:wrap;">
                  <%= render "shared/friend_button",
                        profil_user: @profil_user,
                        already_friends: @already_friends,
                        pending_sent: @pending_sent,
                        pending_received: @pending_received,
                        friendship_initiated_by_me: @friendship_initiated_by_me %>

                  <%= button_to private_conversations_path(recipient_id: @profil_user.id),
                      method: :post,
                      class: "btn btn-sm d-flex align-items-center gap-1",
                      style: "background:rgba(30,221,136,0.12); border:1px solid rgba(30,221,136,0.3); color:#1EDD88; font-size:0.72rem; font-weight:700; padding:0.25rem 0.6rem; border-radius:999px; white-space:nowrap;" do %>
                    <i data-lucide="message-circle" style="width:11px;height:11px;"></i>
                    Message
                  <% end %>
                </div>
              <% end %>

            </div>
          </div>
          <%# / avatar + nom %>

          <%# ── Note moyenne ──────────────────────────────────────────────────── %>
          <%
            avg   = @profil.average_rating.to_f
            full  = avg.floor
            empty = 5 - full
          %>
          <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:1rem; padding-bottom:1rem; border-bottom:1px solid rgba(255,255,255,0.06);">
            <% if @profil.avis_count.to_i > 0 %>
              <span style="color:#1EDD88; font-size:0.85rem;"><%= "★" * full %><span style="color:rgba(255,255,255,0.2);"><%= "★" * empty %></span></span>
              <span style="font-size:0.78rem; font-weight:700; color:#fff;"><%= avg.round(1) %></span>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.35);">(<%= @profil.avis_count %> avis)</span>
            <% else %>
              <span style="color:rgba(255,255,255,0.2); font-size:0.85rem;">★★★★★</span>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.35);">Pas encore noté</span>
            <% end %>
          </div>

          <%# ── Sports pratiqués ─────────────────────────────────────────────── %>
          <% user_sports = @profil_user.sports.order(:name) %>
          <% if user_sports.any? %>
            <% sport_profils_map = @profil.sport_profils.index_by(&:sport_id) %>

            <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.5rem;">
              <i data-lucide="trophy" style="width:13px; height:13px;"></i>
              Sports pratiqués
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:0.35rem; margin-bottom:1rem;">
              <% user_sports.each do |sport| %>
                <% sp = sport_profils_map[sport.id] %>
                <%# Badge sport — mis en avant si c'est le sport actif de la session %>
                <span style="display:inline-flex; align-items:center; gap:0.35rem; padding:0.3rem 0.75rem; border-radius:999px; font-size:0.8rem; font-weight:700; <%= current_sport&.id == sport.id ? 'background:rgba(30,221,136,0.14); border:1px solid rgba(30,221,136,0.45); color:#1EDD88;' : 'background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); color:rgba(255,255,255,0.7);' %>">
                  <%= sport_icon(sport, size: "0.95rem") %>
                  <%= sport.name %>
                  <%# Badge niveau si renseigné %>
                  <% if sp&.level.present? %>
                    <span style="color:rgba(255,255,255,0.25);">·</span>
                    <span class="match-badge-level <%= level_badge_css(sp.level, sport) %>"
                          style="font-size:0.62rem; padding:0.1rem 0.4rem;">
                      <%= sp.level %>
                    </span>
                  <% end %>
                  <%# Rôle si renseigné %>
                  <% if sp&.role.present? %>
                    <span style="color:rgba(255,255,255,0.2);">·</span>
                    <span style="font-size:0.68rem; font-weight:500; color:rgba(255,255,255,0.4);">
                      <%= sp.role %>
                    </span>
                  <% end %>
                </span>
              <% end %>
            </div>
          <% end %>

          <%# ── Statistiques ──────────────────────────────────────────────────── %>
          <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.5rem;">
            <i data-lucide="bar-chart-2" style="width:13px; height:13px;"></i>
            Statistiques
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6">
              <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06); border-radius:8px; padding:0.5rem 0.75rem;">
                <div style="font-size:0.6rem; font-weight:700; color:rgba(255,255,255,0.4); text-transform:uppercase; letter-spacing:0.07em;">Matchs joués</div>
                <div style="font-size:1.3rem; font-weight:800; color:#fff; line-height:1.1;"><%= @profil_user.matchs.count %></div>
              </div>
            </div>
            <div class="col-6">
              <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06); border-radius:8px; padding:0.5rem 0.75rem;">
                <div style="font-size:0.6rem; font-weight:700; color:rgba(255,255,255,0.4); text-transform:uppercase; letter-spacing:0.07em;">Matchs créés</div>
                <div style="font-size:1.3rem; font-weight:800; color:#fff; line-height:1.1;"><%= @profil_user.match_users.where(role: "organisateur").count %></div>
              </div>
            </div>
          </div>

          <%# ── Description ──────────────────────────────────────────────────── %>
          <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.4rem;">
            <i data-lucide="file-text" style="width:13px; height:13px;"></i>
            Description
          </div>
          <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:8px; padding:0.6rem 0.75rem;">
            <% if @profil.description.present? %>
              <p style="font-size:0.82rem; color:rgba(255,255,255,0.6); line-height:1.55; margin:0;">
                <%= @profil.description %>
              </p>
            <% else %>
              <p style="font-size:0.82rem; color:rgba(255,255,255,0.3); margin:0;">
                Pas encore de description.
                <% if current_user == @profil_user %>
                  <%= link_to "Ajouter", edit_profil_path, style: "color:#1EDD88; font-weight:600; text-decoration:none;" %>
                <% end %>
              </p>
            <% end %>
          </div>

        </div>
        <%# / carte profil principale %>

      </div>
      <%# / col-lg-4 %>


      <%# ══════════════════════ COLONNE DROITE (col-lg-8) ═══════════════════════ %>
      <%# Demandes d'ami + Mes matchs + Avis + Liste amis %>
      <div class="col-lg-8">

        <%# ── Demandes d'ami en attente (uniquement sur son propre profil) ──────── %>
        <% if current_user == @profil_user && @pending_friend_requests&.any? %>
          <div style="margin-bottom:1.5rem;">
            <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700;
                        text-transform:uppercase; letter-spacing:0.08em; color:#f59e0b; margin-bottom:0.75rem;">
              <i data-lucide="user-plus" style="width:14px; height:14px;"></i>
              Demandes reçues (<%= @pending_friend_requests.count %>)
            </div>
            <div class="match-block" style="padding:1rem;">
              <div style="display:flex; flex-direction:column; gap:0.6rem;">
                <% @pending_friend_requests.each do |friendship| %>
                  <div style="display:flex; align-items:center; justify-content:space-between; gap:0.75rem;">
                    <%# Lien vers le profil de l'expéditeur %>
                    <%= link_to user_profil_path(friendship.user),
                          data: { turbo_frame: "_top" },
                          style: "display:inline-flex; align-items:center; gap:0.5rem; text-decoration:none; flex:1; min-width:0;" do %>
                      <% if friendship.user.profil&.avatar&.attached? %>
                        <%= image_tag friendship.user.profil.avatar,
                              style: "width:30px; height:30px; border-radius:50%; object-fit:cover; flex-shrink:0;",
                              alt: friendship.user.display_name %>
                      <% else %>
                        <span style="width:30px; height:30px; border-radius:50%; background:#333;
                                     display:inline-flex; align-items:center; justify-content:center;
                                     font-size:0.65rem; font-weight:800; color:rgba(255,255,255,0.5); flex-shrink:0;">
                          <%= friendship.user.display_name.first.upcase %>
                        </span>
                      <% end %>
                      <span style="font-size:0.8rem; font-weight:600; color:rgba(255,255,255,0.8); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                        <%= friendship.user.display_name %>
                      </span>
                    <% end %>
                    <%# Boutons Accepter / Refuser %>
                    <div style="display:flex; gap:0.4rem; flex-shrink:0;">
                      <%= button_to accept_user_friendship_path(friendship.user), method: :patch,
                            data: { turbo_frame: "_top" },
                            style: "display:inline-flex; align-items:center; gap:0.25rem; font-size:0.68rem;
                                    font-weight:700; color:#1EDD88; background:rgba(30,221,136,0.1);
                                    border:1px solid rgba(30,221,136,0.3); border-radius:999px;
                                    padding:0.2rem 0.6rem; cursor:pointer;" do %>
                        <i data-lucide="check" style="width:10px; height:10px;"></i>
                        Accepter
                      <% end %>
                      <%= button_to decline_user_friendship_path(friendship.user), method: :patch,
                            data: { turbo_frame: "_top" },
                            style: "display:inline-flex; align-items:center; gap:0.25rem; font-size:0.68rem;
                                    font-weight:700; color:rgba(255,100,100,0.7);
                                    background:rgba(255,100,100,0.06); border:1px solid rgba(255,100,100,0.2);
                                    border-radius:999px; padding:0.2rem 0.6rem; cursor:pointer;" do %>
                        <i data-lucide="x" style="width:10px; height:10px;"></i>
                        Refuser
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <%# ── Mes matchs ──────────────────────────────────────────────────────── %>
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.75rem;">
          <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88;">
            <i data-lucide="calendar" style="width:14px; height:14px;"></i>
            <%= current_user == @profil_user ? "Mes matchs" : "Matchs de #{@profil_user.display_name}" %>
          </div>
          <% if current_user == @profil_user %>
            <%= link_to "Voir tout", matches_path(mine: true), style: "font-size:0.8rem; font-weight:600; color:#1EDD88; text-decoration:none;" %>
          <% end %>
        </div>

        <div class="match-block">
          <%
            # Récupère les 3 prochains matchs de l'utilisateur affiché
            upcoming_matches = @profil_user.matchs
              .where("(date + time) > ?", Time.current)
              .order(date: :asc, time: :asc)
              .first(3)
          %>

          <% if upcoming_matches.any? %>
            <div style="display:flex; flex-direction:column; gap:0.65rem;">
              <% upcoming_matches.each do |match| %>
                <%
                  cover    = sport_cover_image(match)
                  lvl_css  = level_badge_css(match.level, match.sport)
                  fr_days  = %w[Dim Lun Mar Mer Jeu Ven Sam]
                  date_str = match.date ? "#{fr_days[match.date.wday]} #{match.date.strftime('%d/%m')}" : "—"
                %>
                <div style="display:flex; align-items:center; gap:0.9rem; padding:0.75rem 0.85rem; background-color:#242624; border:1px solid rgba(255,255,255,0.06); border-radius:8px;">
                  <%= image_tag cover, alt: match.title,
                      style: "width:80px; height:58px; object-fit:cover; border-radius:6px; flex-shrink:0; display:block;" %>
                  <div style="flex:1; min-width:0;">
                    <div style="font-size:0.87rem; font-weight:700; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                      <%= match.title %>
                    </div>
                    <% if match.description.present? %>
                      <div style="font-size:0.72rem; color:rgba(255,255,255,0.4); margin-top:0.2rem; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                        <%= match.description %>
                      </div>
                    <% end %>
                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; margin-top:0.35rem;">
                      <span class="match-badge-level <%= lvl_css %>" style="font-size:0.65rem; padding:0.12rem 0.45rem;">
                        <%= match.level %>
                      </span>
                      <span style="display:inline-flex; align-items:center; gap:0.2rem; font-size:0.7rem; color:rgba(255,255,255,0.55);">
                        <i data-lucide="calendar" style="width:10px; height:10px;"></i>
                        <%= date_str %>
                      </span>
                      <% if match.place.present? %>
                        <span style="display:inline-flex; align-items:center; gap:0.2rem; font-size:0.7rem; color:rgba(255,255,255,0.55);">
                          <i data-lucide="map-pin" style="width:10px; height:10px;"></i>
                          <%= match.place.split(",").first %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                  <%= link_to "Détails", match_path(match),
                      style: "flex-shrink:0; font-size:0.75rem; font-weight:600; color:rgba(255,255,255,0.7); border:1px solid rgba(255,255,255,0.2); border-radius:999px; padding:0.25rem 0.8rem; text-decoration:none; white-space:nowrap;" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div style="display:flex; flex-direction:column; align-items:center; gap:0.5rem; padding:1.5rem 0; text-align:center; color:rgba(255,255,255,0.55);">
              <i data-lucide="calendar-x" style="width:28px; height:28px; opacity:0.3;"></i>
              <p style="font-size:0.88rem; margin:0;">Aucun match à venir.</p>
              <%= link_to "Trouver un match", matches_path, class: "btn btn-primary btn-sm btn-cta-primary mt-2" %>
            </div>
          <% end %>
        </div>
        <%# / mes matchs %>


        <%# ── Avis des joueurs ────────────────────────────────────────────────── %>
        <div style="display:flex; align-items:center; justify-content:space-between; margin-top:1.5rem; margin-bottom:0.75rem;">
          <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88;">
            <i data-lucide="star" style="width:14px; height:14px;"></i>
            Avis des joueurs
          </div>
          <%# Bouton "Laisser un avis" — visible si un match commun éligible existe %>
          <% if defined?(@eligible_match) && @eligible_match.present? %>
            <button type="button"
                    data-bs-toggle="modal"
                    data-bs-target="#modal-avis-<%= @profil_user.id %>"
                    style="display:inline-flex; align-items:center; gap:0.35rem; font-size:0.75rem; font-weight:600; color:#1EDD88; background:rgba(30,221,136,0.1); border:1px solid rgba(30,221,136,0.3); border-radius:999px; padding:0.3rem 0.9rem; cursor:pointer; white-space:nowrap;">
              <i data-lucide="star" style="width:11px; height:11px; flex-shrink:0;"></i>
              Laisser un avis
            </button>
          <% end %>
        </div>

        <%# Hint : avis en attente (visible sur son propre profil) %>
        <% if current_user == @profil_user && @pending_avis_count.to_i > 0 %>
          <div style="padding:0.75rem 0.9rem; margin-bottom:0.75rem; background:rgba(30,221,136,0.07); border:1px solid rgba(30,221,136,0.2); border-radius:8px;">
            <div style="display:flex; align-items:center; gap:0.6rem; margin-bottom:0.6rem;">
              <i data-lucide="lock" style="width:14px; height:14px; color:#1EDD88; flex-shrink:0;"></i>
              <p style="margin:0; font-size:0.78rem; color:rgba(255,255,255,0.65); line-height:1.4;">
                <strong style="color:#1EDD88;"><%= @pending_avis_count %> avis</strong>
                <%= @pending_avis_count > 1 ? "vous attendent" : "vous attend" %> —
                notez vos coéquipiers pour les débloquer.
              </p>
            </div>
            <% if @pending_reviewers.any? %>
              <%
                max_pills    = 5
                visible      = @pending_reviewers.first(max_pills)
                hidden_count = @pending_reviewers.count - visible.count
              %>
              <div style="display:flex; flex-wrap:wrap; gap:0.4rem; align-items:center;">
                <% visible.each do |reviewer| %>
                  <%= link_to user_profil_path(reviewer),
                      style: "display:inline-flex; align-items:center; gap:0.4rem; padding:0.3rem 0.7rem; background:rgba(30,221,136,0.12); border:1px solid rgba(30,221,136,0.35); border-radius:999px; text-decoration:none;" do %>
                    <% if reviewer.profil&.avatar&.attached? %>
                      <%= image_tag reviewer.profil.avatar,
                          style: "width:20px; height:20px; border-radius:50%; object-fit:cover; flex-shrink:0;",
                          alt: reviewer.display_name %>
                    <% else %>
                      <span style="width:20px; height:20px; border-radius:50%; background:#333; display:inline-flex; align-items:center; justify-content:center; font-size:0.6rem; font-weight:800; color:rgba(255,255,255,0.5); flex-shrink:0;">
                        <%= reviewer.display_name.first.upcase %>
                      </span>
                    <% end %>
                    <span style="font-size:0.74rem; font-weight:600; color:#1EDD88; white-space:nowrap;">
                      <%= reviewer.display_name %>
                    </span>
                    <i data-lucide="star" style="width:11px; height:11px; color:#1EDD88; flex-shrink:0;"></i>
                  <% end %>
                <% end %>
                <% if hidden_count > 0 %>
                  <span style="font-size:0.72rem; font-weight:600; color:rgba(30,221,136,0.6); padding:0.3rem 0.5rem; white-space:nowrap;">
                    + <%= hidden_count %> autre<%= hidden_count > 1 ? "s" : "" %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Teaser : l'autre user t'a noté %>
        <% if defined?(@hidden_review_from_this_user) && @hidden_review_from_this_user %>
          <div style="padding:0.75rem 0.9rem; margin-bottom:0.75rem; background:rgba(245,158,11,0.07); border:1px solid rgba(245,158,11,0.2); border-radius:8px;">
            <div style="display:flex; align-items:center; gap:0.6rem; margin-bottom:0.6rem;">
              <i data-lucide="eye-off" style="width:14px; height:14px; color:#f59e0b; flex-shrink:0;"></i>
              <p style="margin:0; font-size:0.78rem; color:rgba(255,255,255,0.65); line-height:1.4;">
                <strong style="color:#f59e0b;"><%= @profil_user.display_name %></strong>
                vous a laissé un avis — laissez-lui le vôtre pour le débloquer.
              </p>
            </div>
            <% if @eligible_match.present? %>
              <button type="button"
                      data-bs-toggle="modal"
                      data-bs-target="#modal-avis-<%= @profil_user.id %>"
                      style="display:inline-flex; align-items:center; gap:0.4rem; font-size:0.75rem; font-weight:600; color:#f59e0b; background:rgba(245,158,11,0.12); border:1px solid rgba(245,158,11,0.35); border-radius:999px; padding:0.35rem 0.9rem; cursor:pointer; white-space:nowrap;">
                <i data-lucide="star" style="width:11px; height:11px; flex-shrink:0;"></i>
                Laisser un avis à <%= @profil_user.display_name %>
              </button>
            <% else %>
              <span style="font-size:0.72rem; color:rgba(255,255,255,0.35);">
                La fenêtre de 7 jours est expirée.
              </span>
            <% end %>
          </div>
        <% end %>

        <%# ── Liste des avis (3 visibles + collapse Bootstrap pour la suite) ─── %>
        <%
          avis_visibles = @avis.first(3)
          avis_caches   = @avis.drop(3)
        %>
        <div style="display:flex; flex-direction:column; gap:0.65rem;">
          <% if @avis.any? %>

            <% avis_visibles.each do |avis| %>
              <div class="match-block" style="padding:0.85rem 1rem;">
                <div style="display:flex; align-items:center; gap:0.65rem; margin-bottom:0.5rem;">
                  <% if avis.reviewer.profil&.avatar&.attached? %>
                    <%= image_tag avis.reviewer.profil.avatar,
                        style: "width:36px; height:36px; border-radius:50%; object-fit:cover; flex-shrink:0; display:block;",
                        alt: avis.reviewer.display_name %>
                  <% else %>
                    <div style="width:36px; height:36px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:800; color:rgba(255,255,255,0.5); flex-shrink:0;">
                      <%= avis.reviewer.display_name.first.upcase %>
                    </div>
                  <% end %>
                  <div>
                    <div style="font-size:0.82rem; font-weight:700; color:#fff; line-height:1.2;">
                      <%= avis.reviewer.display_name %>
                    </div>
                    <div style="font-size:0.75rem; line-height:1; margin-top:0.15rem;">
                      <span style="color:#1EDD88;"><%= "★" * avis.rating %></span><span style="color:rgba(255,255,255,0.2);"><%= "★" * (5 - avis.rating) %></span>
                    </div>
                  </div>
                </div>
                <% if avis.content.present? %>
                  <p style="font-size:0.78rem; color:rgba(255,255,255,0.55); line-height:1.5; margin:0;">
                    <%= avis.content %>
                  </p>
                <% end %>
              </div>
            <% end %>

            <%# Avis supplémentaires dans un collapse Bootstrap %>
            <% if avis_caches.any? %>
              <div class="collapse" id="more-avis-<%= @profil_user.id %>">
                <div style="display:flex; flex-direction:column; gap:0.65rem;">
                  <% avis_caches.each do |avis| %>
                    <div class="match-block" style="padding:0.85rem 1rem;">
                      <div style="display:flex; align-items:center; gap:0.65rem; margin-bottom:0.5rem;">
                        <% if avis.reviewer.profil&.avatar&.attached? %>
                          <%= image_tag avis.reviewer.profil.avatar,
                              style: "width:36px; height:36px; border-radius:50%; object-fit:cover; flex-shrink:0; display:block;",
                              alt: avis.reviewer.display_name %>
                        <% else %>
                          <div style="width:36px; height:36px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:800; color:rgba(255,255,255,0.5); flex-shrink:0;">
                            <%= avis.reviewer.display_name.first.upcase %>
                          </div>
                        <% end %>
                        <div>
                          <div style="font-size:0.82rem; font-weight:700; color:#fff; line-height:1.2;">
                            <%= avis.reviewer.display_name %>
                          </div>
                          <div style="font-size:0.75rem; line-height:1; margin-top:0.15rem;">
                            <span style="color:#1EDD88;"><%= "★" * avis.rating %></span><span style="color:rgba(255,255,255,0.2);"><%= "★" * (5 - avis.rating) %></span>
                          </div>
                        </div>
                      </div>
                      <% if avis.content.present? %>
                        <p style="font-size:0.78rem; color:rgba(255,255,255,0.55); line-height:1.5; margin:0;">
                          <%= avis.content %>
                        </p>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
              <div style="margin-top:0.25rem; text-align:center;">
                <button class="btn btn-sm"
                        data-bs-toggle="collapse"
                        data-bs-target="#more-avis-<%= @profil_user.id %>"
                        aria-expanded="false"
                        aria-controls="more-avis-<%= @profil_user.id %>"
                        style="font-size:0.78rem; font-weight:600; color:rgba(255,255,255,0.5);
                               background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1);
                               border-radius:999px; padding:0.3rem 1rem;"
                        data-label-more="Voir plus d'avis (<%= avis_caches.size %>)"
                        data-label-less="Voir moins d'avis"
                        onclick="this.textContent = (this.getAttribute('aria-expanded') === 'true') ? this.dataset.labelMore : this.dataset.labelLess">
                  Voir plus d'avis (<%= avis_caches.size %>)
                </button>
              </div>
            <% end %>

          <% else %>
            <div class="match-block" style="padding:1.25rem; text-align:center; color:rgba(255,255,255,0.35);">
              <i data-lucide="message-circle" style="width:24px; height:24px; margin-bottom:0.4rem; opacity:0.4;"></i>
              <% if defined?(@hidden_review_from_this_user) && @hidden_review_from_this_user %>
                <p style="font-size:0.82rem; margin:0; color:rgba(245,158,11,0.6);">Avis masqué — laissez votre avis pour le débloquer.</p>
              <% else %>
                <p style="font-size:0.82rem; margin:0;">Pas encore d'avis.</p>
              <% end %>
            </div>
          <% end %>
        </div>
        <%# / avis %>

        <%# ── Modal formulaire d'avis ─────────────────────────────────────────── %>
        <% if defined?(@eligible_match) && @eligible_match.present? %>
          <% content_for :modals do %>
          <div class="modal fade" id="modal-avis-<%= @profil_user.id %>" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content" style="background:#1a1a1a; border:1px solid rgba(255,255,255,0.1); border-radius:12px;">
                <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.08);">
                  <h5 class="modal-title" style="color:#fff; font-size:1rem; font-weight:700;">
                    Laisser un avis à <%= @profil_user.display_name %>
                  </h5>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <%= form_with url: user_avis_path(@profil_user), method: :post,
                      data: { controller: "star-rating" } do |f| %>
                    <%= hidden_field_tag "avis[match_id]", @eligible_match.id %>
                    <%= hidden_field_tag "avis[rating]", "",
                        data: { "star-rating-target": "input" } %>
                    <p style="font-size:0.78rem; color:rgba(255,255,255,0.45); margin-bottom:1rem;">
                      Suite au match : <strong style="color:rgba(255,255,255,0.7);"><%= @eligible_match.title %></strong>
                      du <%= @eligible_match.date&.strftime("%d/%m/%Y") %>
                    </p>
                    <div style="margin-bottom:1rem;">
                      <label style="font-size:0.8rem; color:rgba(255,255,255,0.6); display:block; margin-bottom:0.4rem;">Note *</label>
                      <div style="display:flex; gap:0.35rem; font-size:1.8rem; cursor:pointer;"
                           data-star-rating-target="stars">
                        <% (1..5).each do |i| %>
                          <span data-action="click->star-rating#select"
                                data-value="<%= i %>"
                                style="color:rgba(255,255,255,0.2); transition:color 0.15s; user-select:none;">★</span>
                        <% end %>
                      </div>
                    </div>
                    <div style="margin-bottom:1.25rem;">
                      <label style="font-size:0.8rem; color:rgba(255,255,255,0.6); display:block; margin-bottom:0.4rem;">
                        Commentaire <span style="color:rgba(255,255,255,0.3);">(optionnel)</span>
                      </label>
                      <%= text_area_tag "avis[content]", "",
                          placeholder: "Décris ton expérience avec ce joueur...",
                          rows: 3,
                          style: "width:100%; background:#242624; border:1px solid rgba(255,255,255,0.12); border-radius:8px; color:#fff; padding:0.6rem 0.75rem; font-size:0.82rem; resize:none;" %>
                    </div>
                    <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
                      <button type="button" class="btn btn-sm" data-bs-dismiss="modal"
                              style="color:rgba(255,255,255,0.5); background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); border-radius:999px; padding:0.4rem 1rem;">
                        Annuler
                      </button>
                      <button type="submit" class="btn btn-sm btn-cta-primary"
                              style="border-radius:999px; padding:0.4rem 1.2rem;"
                              data-star-rating-target="submit">
                        Envoyer l'avis
                      </button>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <% end %>
        <% end %>

        <%# ── Section Amis ─────────────────────────────────────────────────────── %>
        <%# turbo_frame_tag permet la mise à jour en temps réel via ActionCable %>
        <%= turbo_frame_tag "friends_list_#{@profil_user.id}" do %>
          <%= render "profils/friends_list",
                friends: @all_friends,
                own_profile: (current_user == @profil_user) %>
        <% end %>

      </div>
      <%# / col-lg-8 %>

    </div>
    <%# / row %>

  </div>
  <%# / container %>
</div>
