<%# PARTIAL : Card profil joueur ornementale avec flip (recto/verso) %>
<%# profil_user (User), show_edit (boolean), already_friends, pending_sent, pending_received, friendship_initiated_by_me %>


<%# ── 1. Récupérer les objets associés ───────────────────────────────────── %>

<%# Le profil contient prénom, nom, photo, note, description, ville %>
<% profil = profil_user.profil %>

<%# La map sport_id => sport_profil permet d'accéder au niveau/rôle par sport %>
<% sport_profils_map = profil.sport_profils.index_by(&:sport_id) %>

<%# Tous les achievements et ceux débloqués par le joueur (pour le verso) %>
<% all_achievements = Achievement.order(:category, :xp_reward) %>
<% unlocked_ids     = profil_user.user_achievements.pluck(:achievement_id) %>


<%# ── 2. Thème CSS selon le rang du joueur ───────────────────────────────── %>
<%# Thème dynamique selon le rang XP du joueur (bronze/silver/gold/platinum/emerald) %>
<% theme_class = "theme-#{profil_user.rank}" %>


<%# ── 3. Préparer les données ───────────────────────────────────────────── %>

<% avatar_initial  = profil&.first_name&.first&.upcase || "?" %>
<% matches_played  = profil_user.match_users.count %>
<% matches_created = profil_user.matchs.count %>
<% avg_rating      = profil&.average_rating.to_f || 0.0 %>
<% avis_count      = profil&.avis_count.to_i || 0 %>
<% user_sports     = profil_user.sports.order(:name) %>
<% viewing_other   = !show_edit && user_signed_in? %>


<%# ── HTML : wrapper flip-card ─────────────────────────────────────────── %>
<div class="player-card <%= theme_class %>" data-controller="flip-card">

  <%# Cette div reçoit la rotation 3D via la classe .is-flipped (ajoutée par JS) %>
  <div class="player-card__flip-inner" data-flip-card-target="inner">


    <%# ════════════════════════════════════════════════════════════ RECTO ══ %>
    <div class="player-card__face player-card__front">
      <div class="player-card__inner">

        <%# Texte "TEAMS-UP" défilant discrètement en fond %>
        <div class="player-card__marquee">
          <div class="player-card__marquee-track">
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
          </div>
        </div>

        <%# Brouillard lumineux en bas %>
        <div class="player-card__mist"></div>

        <%# ── En-tête : avatar + nom + bouton modifier ── %>
        <div class="player-card__header">
          <div class="player-card__avatar-wrap">
            <div class="player-card__avatar-ring"></div>
            <div class="player-card__avatar">
              <% if profil && profil.avatar.attached? %>
                <%# RGESN 5.2 — width/height évite le layout shift (CSS règle l'affichage circulaire) %>
                <%= image_tag profil.avatar, alt: profil.first_name, width: 56, height: 56 %>
              <% else %>
                <%= avatar_initial %>
              <% end %>
            </div>
          </div>

          <div class="player-card__info">
            <div class="player-card__name-row">
              <div class="player-card__name">
                <%= profil&.first_name %> <%= profil&.last_name %>
              </div>
              <% if show_edit %>
                <%= link_to edit_profil_path, class: "player-card__btn-modifier" do %>
                  <%# RGAA 4.8 — SVG décoratif, le texte "Modifier" suffit pour l'accessibilité %>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                  Modifier
                <% end %>
              <% end %>
            </div>

            <div class="player-card__location">
              <%# RGAA 4.8 — SVG décoratif, le texte de la ville suffit %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
              <%= profil&.preferred_city.present? ? profil.preferred_city : "—" %>
            </div>
          </div>
        </div><%# / header %>

        <%# ── Boutons ami + message (sur le profil d'un autre joueur) ── %>
        <% if viewing_other %>
          <div class="player-card__actions">
            <%= render "shared/friend_button",
                  profil_user: profil_user,
                  already_friends: already_friends,
                  pending_sent: pending_sent,
                  pending_received: pending_received,
                  friendship_initiated_by_me: friendship_initiated_by_me %>
            <%= button_to private_conversations_path(recipient_id: profil_user.id),
                method: :post,
                class: "player-card__btn-message" do %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
              Message
            <% end %>
          </div>
        <% end %>

        <%# ── Note moyenne ── %>
        <div class="player-card__rating">
          <div class="player-card__stars">
            <% full_stars = avg_rating.floor %>
            <% 5.times do |i| %>
              <span class="star <%= i < full_stars ? 'filled' : '' %>">★</span>
            <% end %>
          </div>
          <span class="player-card__rating-label">
            <% if avis_count > 0 %>
              <%= avg_rating.round(1) %>/5
              <span style="opacity:0.5;">(<%= avis_count %> avis)</span>
            <% else %>
              Pas encore noté
            <% end %>
          </span>
        </div>

        <%# ── Statistiques ── %>
        <div class="player-card__stats">
          <div class="player-card__stat-box">
            <div class="player-card__stat-label">Matchs joués</div>
            <div class="player-card__stat-value"><%= matches_played %></div>
          </div>
          <div class="player-card__stat-box">
            <div class="player-card__stat-label">Matchs créés</div>
            <div class="player-card__stat-value"><%= matches_created %></div>
          </div>
        </div>

        <%# ── Sports avec niveau et rôle ── %>
        <div class="player-card__sports">
          <span class="player-card__sports-label">Sports</span>
          <% if user_sports.any? %>
            <% user_sports.each do |sport| %>
              <% sp = sport_profils_map[sport.id] %>
              <span class="player-card__sport-tag">
                <%= sport_icon(sport, size: "0.9rem") %>
                <%= sport.name %>
                <% if sp&.level.present? %>
                  <span class="player-card__sport-level <%= level_badge_css(sp.level, sport) %>">
                    <%= sp.level %>
                  </span>
                <% end %>
                <% if sp&.role.present? %>
                  <span class="player-card__sport-role"><%= sp.role %></span>
                <% end %>
              </span>
            <% end %>
          <% else %>
            <span class="player-card__sport-tag">Non renseigné</span>
          <% end %>
        </div>

        <%# ── Description ── %>
        <div class="player-card__description">
          <p>
            <% if profil&.description.present? %>
              <%= profil.description %>
            <% else %>
              Pas encore de description.
              <% if show_edit %>
                <%= link_to "Ajouter", edit_profil_path, class: "player-card__add-link" %>
              <% end %>
            <% end %>
          </p>
        </div>

        <%# ── Bouton flip vers l'armoire à trophées ── %>
        <div class="player-card__flip-btn-wrap">
          <button class="player-card__flip-btn" data-action="click->flip-card#flip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;">
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
              <path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
              <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
              <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
            </svg>
            Armoire à trophées
          </button>
        </div>

      </div><%# / player-card__inner %>
    </div><%# / player-card__front %>


    <%# ════════════════════════════════════════════════════════════ VERSO ══ %>
    <div class="player-card__face player-card__back">
      <div class="player-card__inner">

        <%# Texte "TEAMS-UP" en fond %>
        <div class="player-card__marquee">
          <div class="player-card__marquee-track">
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
            <span class="player-card__marquee-word">TEAMS-UP</span>
          </div>
        </div>

        <div class="player-card__mist"></div>

        <%# ── Titre ── %>
        <div class="player-card__trophy-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;">
            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
            <path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
            <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
            <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
          </svg>
          Armoire à trophées
        </div>

        <%# ── Grille des badges ── %>
        <div class="player-card__trophy-grid" data-controller="achievement-tooltip">
          <% all_achievements.each do |achievement| %>
            <% is_unlocked = unlocked_ids.include?(achievement.id) %>
            <%= achievement_badge(achievement, is_unlocked: is_unlocked, size: 40) %>
          <% end %>
        </div>

        <p class="player-card__trophy-hint">Clique sur un badge pour l'inspecter.</p>

        <%# ── Bouton retour vers le recto ── %>
        <div class="player-card__flip-btn-wrap">
          <button class="player-card__flip-btn" data-action="click->flip-card#flip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:11px;height:11px;">
              <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
            </svg>
            Retour au profil
          </button>
        </div>

      </div><%# / player-card__inner %>
    </div><%# / player-card__back %>

  </div><%# / player-card__flip-inner %>
</div><%# / player-card %>
