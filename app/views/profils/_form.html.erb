<%# Formulaire partagé pour modifier le profil %>
<%# La variable @profil est passée automatiquement par le controller %>

<%= form_with model: @profil, url: profil_path, method: :patch, class: "row g-3" do |f| %>

  <%# Affiche les erreurs de validation si le formulaire est invalide %>
  <% if @profil.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @profil.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# Nom affiché %>
  <div class="col-md-6">
    <%= f.label :name, "Nom", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "Ton prénom ou pseudo" %>
  </div>

  <%# Téléphone %>
  <div class="col-md-6">
    <%= f.label :phone, "Téléphone", class: "form-label" %>
    <%= f.text_field :phone, class: "form-control", placeholder: "06 00 00 00 00" %>
  </div>

  <%# Adresse %>
  <div class="col-12">
    <%= f.label :address, "Adresse", class: "form-label" %>
    <%= f.text_field :address, class: "form-control", placeholder: "Ton adresse" %>
  </div>

  <%# Description personnelle %>
  <div class="col-12">
    <%= f.label :description, "À propos de toi", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Parle de toi, de ton style de jeu..." %>
  </div>

  <%# Niveau et rôle préféré sur la même ligne %>
  <div class="col-md-6">
    <%= f.label :level, "Niveau", class: "form-label" %>
    <%= f.select :level, ["Débutant", "Intermédiaire", "Avancé"], { include_blank: "Choisir ton niveau" }, class: "form-select" %>
  </div>

  <div class="col-md-6">
    <%= f.label :role, "Rôle préféré", class: "form-label" %>
    <%= f.text_field :role, class: "form-control", placeholder: "Ex: Attaquant, Gardien..." %>
  </div>

  <%# Bouton de soumission %>
  <div class="col-12">
    <%= f.submit "Sauvegarder", class: "btn btn-primary" %>
  </div>

<% end %>
