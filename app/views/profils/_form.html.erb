<%# ── Formulaire de modification du profil ─────────────────────────────────── %>
<%# Direction artistique : thème sombre, accents verts, sections en match-block %>
<%# La variable profil est passée en local depuis edit.html.erb %>

<%# multipart: true est obligatoire pour les formulaires avec upload de fichier %>
<%= form_with model: profil, url: profil_path, method: :patch, multipart: true do |f| %>

  <%# ── Affichage des erreurs de validation ─────────────────────────────── %>
  <% if profil.errors.any? %>
    <div style="background:rgba(253,16,21,0.1); border:1px solid rgba(253,16,21,0.3); border-radius:8px; padding:0.85rem 1rem; margin-bottom:1.5rem;">
      <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.4rem;">
        <i data-lucide="alert-circle" style="width:14px; height:14px; color:#f87171; flex-shrink:0;"></i>
        <span style="font-size:0.82rem; font-weight:700; color:#f87171;">
          <%= pluralize(profil.errors.count, "erreur") %> à corriger
        </span>
      </div>
      <ul style="margin:0; padding-left:1.2rem;">
        <% profil.errors.full_messages.each do |msg| %>
          <li style="font-size:0.8rem; color:rgba(248,113,113,0.85);"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════════════════════ %>
  <%# LAYOUT DEUX COLONNES : avatar à gauche, champs à droite %>
  <%# ══════════════════════════════════════════════════════════════════════ %>
  <div class="row g-4">

    <%# ════════════ COLONNE GAUCHE — Photo de profil (4/12) ════════════ %>
    <div class="col-lg-4">

      <%# ── En-tête de section ──────────────────────────────────────────── %>
      <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.75rem;">
        <i data-lucide="camera" style="width:14px; height:14px;"></i>
        Photo de profil
      </div>

      <%# ── Card avatar ─────────────────────────────────────────────────── %>
      <%# data-controller connecte le Stimulus avatar-preview pour la prévisualisation %>
      <div class="match-block" data-controller="avatar-preview">

        <%# Cercle cliquable — cliquer dessus déclenche le champ fichier caché %>
        <div style="display:flex; flex-direction:column; align-items:center; gap:1rem; padding:0.5rem 0;">

          <%# Wrapper positionné pour le badge caméra vert %>
          <div style="position:relative; display:inline-block; cursor:pointer;"
               onclick="this.closest('[data-controller]').querySelector('input[type=file]').click()">

            <%# Photo actuelle (si elle existe) — cachée dès qu'une nouvelle est sélectionnée %>
            <% if profil.avatar.attached? %>
              <%# Image de prévisualisation (remplie par le JS après sélection) %>
              <div data-avatar-preview-target="preview" style="display:block;">
                <%# image_tag génère proprement la balise img avec les data-attributes Stimulus %>
                <%= image_tag url_for(profil.avatar),
                    alt: "Photo de profil",
                    style: "width:100px; height:100px; border-radius:50%; object-fit:cover; border:3px solid #1EDD88; display:block;",
                    data: { "avatar-preview-target": "image" } %>
              </div>
              <%# Placeholder caché par défaut quand photo existante %>
              <div data-avatar-preview-target="placeholder"
                   style="display:none; width:100px; height:100px; border-radius:50%; background:#242624; border:2px dashed rgba(255,255,255,0.2); align-items:center; justify-content:center; flex-direction:column; gap:5px;">
                <i data-lucide="user" style="width:28px; height:28px; color:rgba(255,255,255,0.3);"></i>
                <span style="font-size:0.68rem; color:rgba(255,255,255,0.3);">Photo</span>
              </div>
            <% else %>
              <%# Aucune photo — on affiche le placeholder ──────────────── %>
              <%# Le JS le cachera dès qu'une photo est choisie %>
              <div data-avatar-preview-target="placeholder"
                   style="width:100px; height:100px; border-radius:50%; background:#242624; border:2px dashed rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; flex-direction:column; gap:5px; transition:border-color 0.2s;">
                <i data-lucide="user" style="width:28px; height:28px; color:rgba(255,255,255,0.3);"></i>
                <span style="font-size:0.68rem; color:rgba(255,255,255,0.3);">Photo</span>
              </div>
              <%# Zone de prévisualisation — cachée jusqu'à ce qu'une photo soit sélectionnée %>
              <div data-avatar-preview-target="preview" style="display:none;">
                <img data-avatar-preview-target="image"
                     alt="Aperçu de ta photo"
                     style="width:100px; height:100px; border-radius:50%; object-fit:cover; border:3px solid #1EDD88; display:block;">
              </div>
            <% end %>

            <%# Badge caméra vert en bas à droite du cercle %>
            <div style="position:absolute; bottom:2px; right:2px; width:28px; height:28px; background:#1EDD88; border-radius:50%; border:2px solid #1a1c1a; display:flex; align-items:center; justify-content:center;">
              <i data-lucide="camera" style="width:13px; height:13px; color:#111111;"></i>
            </div>

          </div>
          <%# / wrapper positionné %>

          <%# Texte d'aide sous le cercle %>
          <div style="text-align:center;">
            <p style="font-size:0.78rem; color:rgba(255,255,255,0.5); margin:0 0 0.25rem;">
              Clique pour changer ta photo
            </p>
            <p style="font-size:0.7rem; color:rgba(255,255,255,0.25); margin:0;">
              JPG, PNG ou GIF — max 5 Mo
            </p>
          </div>

        </div>
        <%# / flex colonnes %>

        <%# Champ fichier caché — déclenché par le clic sur le cercle %>
        <%#
          data-avatar-preview-target="input" : cible JS du controller
          data-action : déclenche preview() au changement de fichier
        %>
        <%= f.file_field :avatar,
            accept: "image/*",
            style: "display:none;",
            data: {
              "avatar-preview-target": "input",
              action: "change->avatar-preview#preview"
            } %>

      </div>
      <%# / match-block avatar %>


      <%# ── Section sports — sous la photo ──────────────────────────────── %>

      <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.75rem; margin-top:1.5rem;">
        <i data-lucide="trophy" style="width:14px; height:14px;"></i>
        Sports pratiqués
      </div>

      <%# Champ caché : signale au controller que les sports ont été soumis %>
      <input type="hidden" name="user[sports_submitted]" value="1">

      <%# Grille cliquable — sport-select Stimulus controller gère la sélection %>
      <div class="match-block" data-controller="sport-select">
        <div class="sport-select-grid">
          <% Sport.order(:name).each do |sport| %>
            <label class="sport-select-item <%= 'sport-select-item--selected' if current_user.sport_ids.include?(sport.id) %>"
                   data-sport-select-target="item"
                   data-action="click->sport-select#toggle">
              <% if current_user.sport_ids.include?(sport.id) %>
                <input type="checkbox" name="user[sport_ids][]" value="<%= sport.id %>" class="d-none" data-sport-select-target="checkbox" checked>
              <% else %>
                <input type="checkbox" name="user[sport_ids][]" value="<%= sport.id %>" class="d-none" data-sport-select-target="checkbox">
              <% end %>
              <%= sport_icon(sport, size: "1.6rem", css_class: "sport-select-icon") %>
              <span class="sport-select-name"><%= sport.name %></span>
            </label>
          <% end %>
        </div>
      </div>
      <%# / sports %>

    </div>
    <%# / col-lg-4 %>


    <%# ════════════ COLONNE DROITE — Informations (8/12) ════════════════ %>
    <div class="col-lg-8">

      <%# ─────────────────────────────────────────────────────────────────── %>
      <%# SECTION 1 : Identité ──────────────────────────────────────────── %>
      <%# ─────────────────────────────────────────────────────────────────── %>

      <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.75rem;">
        <i data-lucide="user" style="width:14px; height:14px;"></i>
        Identité
      </div>

      <div class="match-block mb-4">
        <div class="row g-3">

          <%# Prénom — obligatoire %>
          <div class="col-md-6">
            <%= f.label :first_name, class: "edit-form-label" do %>
              Prénom <span style="color:#1EDD88; font-weight:700;">*</span>
            <% end %>
            <%= f.text_field :first_name,
                class: "form-control edit-form-input",
                placeholder: "Ton prénom",
                required: true %>
          </div>

          <%# Nom de famille — obligatoire %>
          <div class="col-md-6">
            <%= f.label :last_name, class: "edit-form-label" do %>
              Nom <span style="color:#1EDD88; font-weight:700;">*</span>
            <% end %>
            <%= f.text_field :last_name,
                class: "form-control edit-form-input",
                placeholder: "Ton nom de famille",
                required: true %>
          </div>

          <%# Rôle préféré (poste sur le terrain) %>
          <div class="col-md-6">
            <%= f.label :role, "Rôle préféré", class: "edit-form-label" %>
            <%= f.text_field :role,
                class: "form-control edit-form-input",
                placeholder: "Ex: Attaquant, Gardien..." %>
          </div>

          <%# Niveau de jeu %>
          <div class="col-md-6">
            <%= f.label :level, "Niveau", class: "edit-form-label" %>
            <%= f.select :level,
                ["Débutant", "Intermédiaire", "Avancé"],
                { include_blank: "Choisir ton niveau" },
                class: "form-select edit-form-input" %>
          </div>

        </div>
      </div>
      <%# / identité %>


      <%# ─────────────────────────────────────────────────────────────────── %>
      <%# SECTION 2 : Localisation & Contact ───────────────────────────── %>
      <%# ─────────────────────────────────────────────────────────────────── %>

      <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.75rem;">
        <i data-lucide="map-pin" style="width:14px; height:14px;"></i>
        Localisation & Contact
      </div>

      <div class="match-block mb-4">
        <div class="row g-3">

          <%# Ville / zone géographique %>
          <div class="col-md-6">
            <%= f.label :localisation, "Ville", class: "edit-form-label" %>
            <%= f.text_field :localisation,
                class: "form-control edit-form-input",
                placeholder: "Ex: Paris, Lyon..." %>
          </div>

          <%# Téléphone %>
          <div class="col-md-6">
            <%= f.label :phone, "Téléphone", class: "edit-form-label" %>
            <%= f.text_field :phone,
                class: "form-control edit-form-input",
                placeholder: "06 00 00 00 00" %>
          </div>

          <%# Adresse complète %>
          <div class="col-12">
            <%= f.label :address, "Adresse", class: "edit-form-label" %>
            <%= f.text_field :address,
                class: "form-control edit-form-input",
                placeholder: "Ton adresse complète" %>
          </div>

        </div>
      </div>
      <%# / localisation & contact %>


      <%# ─────────────────────────────────────────────────────────────────── %>
      <%# SECTION 3 : À propos ──────────────────────────────────────────── %>
      <%# ─────────────────────────────────────────────────────────────────── %>

      <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#1EDD88; margin-bottom:0.75rem;">
        <i data-lucide="file-text" style="width:14px; height:14px;"></i>
        À propos
      </div>

      <div class="match-block mb-4">
        <%= f.label :description, "Description", class: "edit-form-label" %>
        <%= f.text_area :description,
            class: "form-control edit-form-input",
            rows: 4,
            placeholder: "Parle de toi, de ton style de jeu, de tes disponibilités..." %>
        <p style="font-size:0.72rem; color:rgba(255,255,255,0.3); margin:0.4rem 0 0;">
          Quelques lignes sur toi pour que les autres joueurs te connaissent mieux.
        </p>
      </div>
      <%# / à propos %>


      <%# ─────────────────────────────────────────────────────────────────── %>
      <%# BOUTONS D'ACTION ──────────────────────────────────────────────── %>
      <%# ─────────────────────────────────────────────────────────────────── %>

      <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">

        <%# Bouton principal — enregistrer les modifications %>
        <%= f.submit "Sauvegarder les modifications",
            class: "btn btn-primary btn-cta-primary",
            style: "display:inline-flex; align-items:center; gap:0.4rem;" %>

        <%# Lien annuler — retour au profil sans sauvegarder %>
        <%= link_to profil_path, class: "btn-cta-secondary btn", style: "display:inline-flex; align-items:center; gap:0.4rem;" do %>
          Annuler
        <% end %>

      </div>

      <%# Légende des champs obligatoires %>
      <p style="font-size:0.72rem; color:rgba(255,255,255,0.3); margin:0.85rem 0 0;">
        <span style="color:#1EDD88; font-weight:700;">*</span> Champs obligatoires
      </p>

    </div>
    <%# / col-lg-8 %>

  </div>
  <%# / row %>

<% end %>
<%# / form %>
