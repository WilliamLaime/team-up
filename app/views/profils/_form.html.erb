<%# Formulaire partagé pour modifier le profil %>
<%# La variable @profil est passée automatiquement par le controller %>

<%# multipart: true est obligatoire pour les formulaires avec upload de fichier %>
<%= form_with model: @profil, url: profil_path, method: :patch, class: "row g-3", multipart: true do |f| %>

  <%# Affiche les erreurs de validation si le formulaire est invalide %>
  <% if @profil.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @profil.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# Prénom — obligatoire %>
  <div class="col-md-6">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :first_name, class: "form-label" do %>
      Prénom <span class="text-danger">*</span>
    <% end %>
    <%= f.text_field :first_name, class: "form-control", placeholder: "Ton prénom", required: true %>
  </div>

  <%# Nom de famille — obligatoire %>
  <div class="col-md-6">
    <%= f.label :last_name, class: "form-label" do %>
      Nom <span class="text-danger">*</span>
    <% end %>
    <%= f.text_field :last_name, class: "form-control", placeholder: "Ton nom de famille", required: true %>
  </div>

  <%# Téléphone %>
  <div class="col-md-6">
    <%= f.label :phone, "Téléphone", class: "form-label" %>
    <%= f.text_field :phone, class: "form-control", placeholder: "06 00 00 00 00" %>
  </div>

  <%# Adresse %>
  <div class="col-12">
    <%= f.label :address, "Adresse", class: "form-label" %>
    <%= f.text_field :address, class: "form-control", placeholder: "Ton adresse" %>
  </div>

  <%# Description personnelle %>
  <div class="col-12">
    <%= f.label :description, "À propos de toi", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Parle de toi, de ton style de jeu..." %>
  </div>

  <%# Niveau et rôle préféré sur la même ligne %>
  <div class="col-md-6">
    <%= f.label :level, "Niveau", class: "form-label" %>
    <%= f.select :level, ["Débutant", "Intermédiaire", "Avancé"], { include_blank: "Choisir ton niveau" }, class: "form-select" %>
  </div>

  <div class="col-md-6">
    <%= f.label :role, "Rôle préféré", class: "form-label" %>
    <%= f.text_field :role, class: "form-control", placeholder: "Ex: Attaquant, Gardien..." %>
  </div>

  <%# Photo de profil — le data-controller connecte le Stimulus controller avatar-preview %>
  <div class="col-12" data-controller="avatar-preview">
    <%= f.label :avatar, "Photo de profil", class: "form-label" %>

    <%# Aperçu de la photo actuelle si elle existe déjà %>
    <% if @profil.avatar.attached? %>
      <div class="mb-2">
        <%= image_tag @profil.avatar, class: "rounded-circle", style: "width:80px;height:80px;object-fit:cover;" %>
        <small class="text-muted ms-2">Photo actuelle</small>
      </div>
    <% end %>

    <%#
      data-avatar-preview-target="input" : cible déclarée dans le controller JS
      data-action : déclenche la méthode preview() au changement de fichier
    %>
    <%= f.file_field :avatar,
        class: "form-control",
        accept: "image/*",
        data: {
          "avatar-preview-target": "input",
          action: "change->avatar-preview#preview"
        } %>
    <div class="form-text">JPG, PNG ou GIF. Max 5 Mo.</div>

    <%# Zone d'aperçu — cachée par défaut, affichée par le controller JS %>
    <div data-avatar-preview-target="preview" class="mt-2" style="display:none;">
      <img data-avatar-preview-target="image"
           alt="Aperçu de ta photo de profil"
           class="rounded-circle"
           style="width:80px;height:80px;object-fit:cover;">
      <small class="text-muted ms-2">Aperçu</small>
    </div>
  </div>

  <%# Légende des champs obligatoires %>
  <div class="col-12">
    <small class="text-muted"><span class="text-danger">*</span> Champs obligatoires</small>
  </div>

  <%# Bouton de soumission %>
  <div class="col-12">
    <%= f.submit "Sauvegarder", class: "btn btn-primary" %>
  </div>

<% end %>
