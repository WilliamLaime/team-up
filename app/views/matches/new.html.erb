<%# ══════════════════════════════════════════════════════════════
    Page de création d'un nouveau match
    ══════════════════════════════════════════════════════════════
    Structure :
    ┌─────────────────────────────────────────────────────────┐
    │  BANNER (fond sombre pleine largeur)                    │
    │  → Titre "Créer un match" + sous-titre                  │
    ├─────────────────────────────────────────────────────────┤
    │  FORMULAIRE (2 colonnes : sections + récapitulatif)     │
    │  → géré par _form.html.erb + _match_form.scss           │
    └─────────────────────────────────────────────────────────┘
    ══════════════════════════════════════════════════════════════ %>

<div class="match-create-page">

  <%# ══════════════════════════════════════════════════════════
      BANNER — En-tête de la page de création
      ══════════════════════════════════════════════════════════
      Pour modifier cette banner :
        → Styles dans app/assets/stylesheets/pages/_match_form.scss
          (section "BANNER - Page new match")
        → Tu peux changer le titre, le sous-titre, ajouter une
          image de fond, des icônes, etc.
      ══════════════════════════════════════════════════════════ %>
  <%# id="match-new-banner" → Stimulus le trouve via document.getElementById pour
      changer le background dynamiquement selon le sport sélectionné %>
  <div class="match-new-banner" id="match-new-banner">
    <div class="container">

      <%# Lien retour vers la liste des matchs %>
      <%= render "shared/nav_button", label: "Retour", direction: "back", extra_class: "mb-3" %>

      <%# Titre principal de la page %>
      <h1 class="match-new-banner-title">
        Créer un match
      </h1>

      <%# Sous-titre / description courte %>
      <p class="match-new-banner-subtitle">
        Remplis les informations ci-dessous et publie ton match en quelques secondes.
      </p>

    </div>
  </div><%# fin .match-new-banner %>

  <%# Formulaire 2 colonnes (sections + récapitulatif sticky) %>
  <%= render "form" %>

</div><%# fin .match-create-page %>
