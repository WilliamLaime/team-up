<%# ═══════════════════════════════════════════════════════════════
    Formulaire partagé : _form.html.erb
    Utilisé par : new.html.erb (créer) et edit.html.erb (modifier)
    ═══════════════════════════════════════════════════════════════

    Structure HTML :
    ┌──────────────────────────────────────────────────────┐
    │  form (data-controller="match-form")                 │
    │  └── .container                                      │
    │       └── .row                                       │
    │            ├── col-lg-7 : les 4 sections de champs   │
    │            └── col-lg-5 : récapitulatif sticky       │
    └──────────────────────────────────────────────────────┘

    Le contrôleur Stimulus "match-form" (match_form_controller.js)
    lit les valeurs des champs (data-match-form-target="xxxInput")
    et les affiche en temps réel dans le récap (data-match-form-target="recapXxx").
    ═══════════════════════════════════════════════════════════════ %>

<%# Détermine le chemin du bouton Annuler selon qu'on crée ou modifie un match %>
<% cancel_path = @match.persisted? ? match_path(@match) : matches_path %>

<%# form_with génère la balise <form> et la configure automatiquement :
    - @match nouveau     → action="/matches"        method="POST"
    - @match existant    → action="/matches/:id"    method="PATCH"
    data-controller="match-form" → connecte le contrôleur Stimulus %>
<%= form_with model: @match,
    data: {
      controller: "match-form",
      action: "sport-picker:sport-selected->match-form#updateSport"
    } do |f| %>

  <div class="container py-4">

    <%# Affiche les erreurs de validation si le formulaire a été soumis et est invalide %>
    <% if @match.errors.any? %>
      <div class="row mb-3">
        <div class="col-12">
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @match.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <%# row sans align-items-start : Bootstrap étire les deux colonnes à la même hauteur
        (celle du formulaire, la plus grande). Ça donne au sticky l'espace pour glisser. %>
    <div class="row g-4">

      <%# ════════════════════════════════════════════════════
          COLONNE GAUCHE : les 4 sections du formulaire
          ════════════════════════════════════════════════════ %>
      <div class="col-lg-7" data-match-form-target="formCol">

        <%# Légende : explication de l'astérisque %>
        <p class="form-required-legend">
          <span class="required-star">*</span> Champs obligatoires
        </p>


        <%# ────────────────────────────────────────────────
            SECTION 1 : Descriptif
            Champs : Titre + Description
            ──────────────────────────────────────────────── %>
        <div class="match-form-section">

          <%# En-tête de la section : badge "1" + titre %>
          <div class="match-form-section-header">
            <div class="match-form-step-badge">1</div>
            <h2 class="match-form-section-title">Descriptif</h2>
          </div>

          <%# Champ Sport — visible et pré-rempli avec le sport actif
              L'utilisateur peut le modifier si besoin %>
          <div class="mb-3">
            <%= f.label :sport_id, class: "form-label" do %>Sport <span class="required-star">*</span><% end %>
            <%
              # Maps JSON passées au controller Stimulus pour adapter le compteur au sport/format
              sports_defaults = Sport.order(:name).each_with_object({}) { |s, h| h[s.id] = s.default_player_count }
              sports_max      = Sport.order(:name).each_with_object({}) { |s, h| h[s.id] = s.max_player_count }
              # Pour le récap Stimulus : emoji + nom (image sports → juste le nom)
              sports_names    = Sport.order(:name).each_with_object({}) { |s, h| h[s.id] = "#{sport_icon_text(s)} #{s.name}".strip }
              # Formats disponibles par sport : { sportId => [{label, players}, ...] }
              sports_formats  = Sport.order(:name).each_with_object({}) { |s, h| h[s.id] = s.available_formats }

              # Images disponibles par sport — même liste que show.html.erb et _match_card.html.erb
              # IMPORTANT : asset_path() lève une erreur si le fichier n'existe pas → ne lister que les vrais fichiers
              _sport_images_data = {
                "football"   => %w[sports/Football/ballon.webp sports/Football/citytoulouse.webp sports/Football/bresil.webp sports/Football/herbe.webp sports/Football/city1.webp sports/Football/citydrone.webp sports/Football/Duel.webp sports/Football/Medellin.webp],
                "tennis"     => %w[sports/Tennis/tennis1.webp sports/Tennis/tennis2.webp sports/Tennis/tennis3.webp sports/Tennis/tennis4.webp sports/Tennis/tennis5.webp sports/Tennis/tennis6.webp],
                "padel"      => %w[sports/Padel/padel1.webp sports/Padel/padel2.webp sports/Padel/padel3.webp sports/Padel/padel4.webp sports/Padel/padel5.webp sports/Padel/padel6.webp],
                "volleyball" => %w[sports/Volley/volley1.webp sports/Volley/volley2.webp sports/Volley/volley3.webp sports/Volley/volley4.webp sports/Volley/volley5.webp sports/Volley/volley6.webp],
                "basketball" => %w[sports/Basketball/basket1.webp sports/Basketball/basket2.webp sports/Basketball/basket3.webp sports/Basketball/basket4.webp sports/Basketball/basket5.webp sports/Basketball/basket6.webp],
                "handball"   => %w[sports/Handball/handball1.webp sports/Handball/handball2.webp],
                "badminton"  => %w[sports/Badminton/badminton1.webp sports/Badminton/badminton2.webp sports/Badminton/badminton3.webp sports/Badminton/badminton4.webp sports/Badminton/badminton5.webp sports/Badminton/badminton6.webp]
              }
              # Construit { sportId => ["/assets/sports/Football/ballon-abc123.webp", ...] }
              # asset_path() génère l'URL avec fingerprint (cache-busting) → nécessaire en prod
              sports_images_map = Sport.order(:name).each_with_object({}) do |s, h|
                slug_imgs = _sport_images_data[s.slug] || _sport_images_data["football"]
                h[s.id] = slug_imgs.map { |img| asset_path(img) }
              end
            %>
            <%#
              Select caché — soumis avec le formulaire et cible Stimulus.
              Le dropdown custom ci-dessous met à jour sa valeur et déclenche
              un event "change" pour que Stimulus (updateSport) réagisse.
            %>
            <%= f.hidden_field :sport_id,
                data: {
                  "match-form-target": "sportInput",
                  "defaults": sports_defaults.to_json,
                  "max-players": sports_max.to_json,
                  "sport-names": sports_names.to_json,
                  "formats": sports_formats.to_json,
                  # images : { sportId => [url1, url2, ...] } — utilisé par Stimulus pour
                  # changer l'image de la banner dynamiquement selon le sport sélectionné
                  "images": sports_images_map.to_json
                } %>

            <%# Champ caché banner_image : stocke l'URL de l'image choisie (soumise avec le formulaire)
                Stimulus met sa valeur à jour via updateBanner() quand le sport change %>
            <%= f.hidden_field :banner_image,
                data: { "match-form-target": "bannerImageInput" } %>

            <%# Dropdown custom — affiche les icônes image + emoji %>
            <div style="position:relative;" data-controller="sport-picker">

              <%# Trigger : affiche le sport sélectionné (ou le prompt)
                  form-select = même style + chevron blanc que date/heure
                  Le contenu intérieur est en flex via un <span> pour ne pas casser
                  le background-image du chevron Bootstrap %>
              <button type="button"
                      class="form-select"
                      data-sport-picker-target="trigger"
                      data-action="click->sport-picker#toggle"
                      style="cursor:pointer; text-align:left;">
                <span class="d-flex align-items-center gap-2">
                  <% if @match.sport %>
                    <%= sport_icon(@match.sport, size: "1.1rem") %>
                    <span><%= @match.sport.name %></span>
                  <% else %>
                    <span style="color:rgba(255,255,255,0.4);">Sélectionner un sport</span>
                  <% end %>
                </span>
              </button>

              <%# Panel dropdown avec tous les sports %>
              <div data-sport-picker-target="dropdown"
                   style="display:none; position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:400;
                          background:#242624; border:1px solid rgba(255,255,255,0.15); border-radius:10px;
                          padding:0.35rem; box-shadow:0 10px 30px rgba(0,0,0,0.6);">
                <% Sport.order(:name).each do |sport| %>
                  <%# data-active="true" = sport actuellement sélectionné → fond vert géré par le controller %>
                  <button type="button"
                          class="sport-picker-item w-100 d-flex align-items-center gap-2 text-start <%= 'sport-picker-item--active' if @match.sport_id == sport.id %>"
                          data-action="click->sport-picker#select"
                          data-sport-picker-target="item"
                          data-sport-id="<%= sport.id %>"
                          data-sport-name="<%= sport.name %>">
                    <%= sport_icon(sport, size: "1.1rem") %>
                    <span><%= sport.name %></span>
                  </button>
                <% end %>
              </div>
            </div>

          </div>

          <%# Champ Titre — obligatoire
              data-match-form-target="titleInput" : Stimulus surveille ce champ
              data-action="input->match-form#updateTitle" : met à jour le récap à chaque frappe %>
          <div class="mb-3">
            <%= f.label :title, class: "form-label" do %>Titre <span class="required-star">*</span><% end %>
            <%= f.text_field :title,
                class: "form-control",
                placeholder: "Ex: Match foot samedi matin",
                required: true,
                data: {
                  "match-form-target": "titleInput",
                  "action": "input->match-form#updateTitle"
                } %>
          </div>

          <%# Champ Description — facultatif
              Textarea redimensionnable (4 lignes par défaut) %>
          <div class="mb-0">
            <%= f.label :description, "Description", class: "form-label" %>
            <%= f.text_area :description,
                class: "form-control",
                rows: 4,
                placeholder: "Décris le match, le niveau attendu, les règles...",
                data: {
                  "match-form-target": "descriptionInput",
                  "action": "input->match-form#updateDescription"
                } %>
          </div>

        </div><%# fin section 1 %>


        <%# ────────────────────────────────────────────────
            SECTION 2 : Lieu
            Champ : Lieu avec autocomplétion (Stimulus "place-search")
            ──────────────────────────────────────────────── %>
        <%# IMPORTANT : ce div a DEUX contrôleurs Stimulus :
            - "place-search"  → gère l'autocomplétion (suggestions Nominatim)
            - "match-form"    → est sur le <form>, donc englobe tout
            Le target "placeInput" est reconnu par les deux %>
        <div class="match-form-section" data-controller="place-search">

          <div class="match-form-section-header">
            <div class="match-form-step-badge">2</div>
            <h2 class="match-form-section-title">Où se déroule le match ?</h2>
          </div>

          <div class="mb-0">
            <%= f.label :place, class: "form-label" do %>Rechercher un club ou une adresse <span class="required-star">*</span><% end %>

            <div class="position-relative">
              <%# Le champ texte :
                  - data-place-search-target="input"   → autocomplétion
                  - data-match-form-target="placeInput" → récap Stimulus
                  - focus->place-search#showDefault     → ouvre le dropdown avec "Ma position" au clic
                  - data-action avec les actions séparées par un espace %>
              <%# form-select = même chevron blanc que date/heure/sport %>
              <%= f.text_field :place,
                  class: "form-select",
                  placeholder: "Ex: Urban Soccer, Bordeaux...",
                  autocomplete: "off",
                  required: true,
                  data: {
                    "place-search-target": "input",
                    "match-form-target":   "placeInput",
                    "action": "input->place-search#search focus->place-search#showDefault input->match-form#updatePlace"
                  } %>

              <%# Champ caché : stocke l'id du venue sélectionné en BDD
                  Rempli par place_search_controller.js quand l'user choisit un résultat BDD.
                  Vide si l'user choisit un résultat OSM ou saisit librement. %>
              <%= f.hidden_field :venue_id, data: { "place-search-target": "venueId" } %>

              <%# Dropdown des suggestions — géré par place_search_controller.js %>
              <div data-place-search-target="dropdown"
                   class="dropdown-menu w-100 shadow"
                   style="display:none; position:absolute; top:100%; left:0; z-index:1050; max-height:250px; overflow-y:auto;">
              </div>
            </div>
          </div>

        </div><%# fin section 2 %>


        <%# ────────────────────────────────────────────────
            SECTION 3 : Quand ?
            Champs : Date + Heure (deux colonnes)
            ──────────────────────────────────────────────── %>
        <div class="match-form-section">

          <div class="match-form-section-header">
            <div class="match-form-step-badge">3</div>
            <h2 class="match-form-section-title">Quand ?</h2>
          </div>

          <div class="row g-3">

            <%# Champ Date — dropdown calendrier custom (date_picker_controller) %>
            <div class="col-md-6">
              <%= f.label :date, class: "form-label" do %>Date du match <span class="required-star">*</span><% end %>

              <%# Conteneur du picker : même pattern que time-picker %>
              <div style="position:relative;" data-controller="date-picker">

                <%# Input caché : valeur réelle soumise avec le formulaire
                    data-match-form-target → récap | data-action → updateDate au changement %>
                <%= f.hidden_field :date,
                    value: @match.date,
                    data: {
                      "date-picker-target": "input",
                      "match-form-target":  "dateInput",
                      "action":             "change->match-form#updateDate"
                    } %>

                <%# Trigger : bouton avec icône calendrier à droite au lieu du chevron %>
                <button type="button"
                        class="form-select w-100 dp-trigger"
                        data-date-picker-target="trigger"
                        data-action="click->date-picker#toggle"
                        style="cursor:pointer; display:flex; align-items:center; background-image:none; padding-right:0.75rem;">
                  <%# Span du texte — mis à jour par Stimulus sans toucher à l'icône %>
                  <span data-date-picker-target="triggerText"
                        style="color:<%= @match.date.present? ? 'inherit' : 'rgba(255,255,255,0.4)' %>;">
                    <% if @match.date.present? %>
                      <% fr_days = %w[Dim Lun Mar Mer Jeu Ven Sam]; fr_months = %w[jan. fév. mars avr. mai juin juil. août sept. oct. nov. déc.] %>
                      <%= "#{fr_days[@match.date.wday]} #{@match.date.day} #{fr_months[@match.date.month - 1]} #{@match.date.year}" %>
                    <% else %>
                      Choisir une date
                    <% end %>
                  </span>
                  <%# Icône calendrier — reste fixe, jamais remplacée par Stimulus %>
                  <i data-lucide="calendar" style="width:14px;height:14px;color:white;flex-shrink:0;margin-left:auto;"></i>
                </button>

                <%# Dropdown calendrier — rempli dynamiquement par le controller JS %>
                <div data-date-picker-target="dropdown"
                     class="dp-dropdown"
                     style="display:none; position:absolute; top:calc(100% + 4px); left:0; z-index:400; min-width:280px;">
                </div>

              </div>
            </div>

            <%# Champ Heure
                Deux selects custom (au lieu de time_select) pour limiter les options :
                  - Heures : 6h à 23h uniquement (pas de 0h-5h)
                  - Minutes : 00, 15, 30, 45
                Les noms time(4i) / time(5i) sont la convention Rails pour les champs composés %>
            <div class="col-md-6">
              <%= f.label :time, class: "form-label" do %>Heure de début <span class="required-star">*</span><% end %>
              <div class="d-flex gap-2"
                   data-action="change->match-form#updateTime">

                <%# ── Dropdown custom pour les heures (time_picker_controller) ── %>
                <%# Affiche 5 heures à la fois + scroll — même pattern que sport-picker %>
                <div style="position:relative; flex:1;" data-controller="time-picker">

                  <%# Input hidden time(4i) : valeur réelle soumise avec le formulaire %>
                  <%= f.hidden_field "time(4i)",
                      value: @match.time&.hour,
                      data: { "time-picker-target": "input" } %>

                  <%# Trigger : même rendu visuel que le form-select des minutes %>
                  <button type="button"
                          class="form-select w-100"
                          data-time-picker-target="trigger"
                          data-action="click->time-picker#toggle"
                          style="cursor:pointer; text-align:left; color:<%= @match.time ? 'inherit' : 'rgba(255,255,255,0.4)' %>;">
                    <%= @match.time ? ("%02dh" % @match.time.hour) : "Heure" %>
                  </button>

                  <%# Dropdown : toutes les heures (0h-23h), 5 visibles + scroll %>
                  <%# .time-picker-dropdown → scrollbar verte (même style que .notif-list) %>
                  <div class="time-picker-dropdown"
                       data-time-picker-target="dropdown"
                       style="display:none; position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:400;
                              background:#242624; border:1px solid rgba(255,255,255,0.15); border-radius:10px;
                              overflow-y:auto; max-height:200px; box-shadow:0 10px 30px rgba(0,0,0,0.6);">
                    <% (0..23).each do |h| %>
                      <%# Styles inline garantis : évite tout conflit Bootstrap/navigateur %>
                      <button type="button"
                              class="time-picker-item w-100 <%= 'time-picker-item--active' if @match.time&.hour == h %>"
                              style="display:block; width:100%; padding:0.5rem 0.85rem; background:<%= @match.time&.hour == h ? 'rgba(30,221,136,0.12)' : 'transparent' %> !important; border:none !important; outline:none; border-radius:6px; color:<%= @match.time&.hour == h ? '#1EDD88' : 'rgba(255,255,255,0.7)' %>; font-size:0.88rem; font-weight:<%= @match.time&.hour == h ? '700' : '500' %>; text-align:left; cursor:pointer; box-shadow:none !important;"
                              data-time-picker-item
                              data-action="click->time-picker#select"
                              data-value="<%= h %>"
                              data-label="<%= "%02dh" % h %>">
                        <%= "%02dh" % h %>
                      </button>
                    <% end %>
                  </div>

                </div>

                <%# ── Dropdown custom pour les minutes — même pattern que les heures ── %>
                <div style="position:relative; flex:1;" data-controller="time-picker">

                  <%# Input hidden time(5i) : valeur réelle soumise avec le formulaire %>
                  <%= f.hidden_field "time(5i)",
                      value: @match.time&.min,
                      data: { "time-picker-target": "input" } %>

                  <%# Trigger : même rendu que le bouton heures %>
                  <button type="button"
                          class="form-select w-100"
                          data-time-picker-target="trigger"
                          data-action="click->time-picker#toggle"
                          style="cursor:pointer; text-align:left; color:<%= @match.time ? 'inherit' : 'rgba(255,255,255,0.4)' %>;">
                    <%= @match.time ? ("%02d" % @match.time.min) : "Min" %>
                  </button>

                  <%# Dropdown : 4 options (quarts d'heure) %>
                  <%# .time-picker-dropdown → même style scrollbar que les heures et les notifs %>
                  <div class="time-picker-dropdown"
                       data-time-picker-target="dropdown"
                       style="display:none; position:absolute; top:calc(100% + 4px); left:0; right:0; z-index:400;
                              background:#242624; border:1px solid rgba(255,255,255,0.15); border-radius:10px;
                              overflow-y:auto; max-height:200px; box-shadow:0 10px 30px rgba(0,0,0,0.6);">
                    <% [[0, "00"], [15, "15"], [30, "30"], [45, "45"]].each do |val, lbl| %>
                      <button type="button"
                              class="time-picker-item w-100 <%= 'time-picker-item--active' if @match.time&.min == val %>"
                              style="display:block; width:100%; padding:0.5rem 0.85rem; background:<%= @match.time&.min == val ? 'rgba(30,221,136,0.12)' : 'transparent' %> !important; border:none !important; outline:none; border-radius:6px; color:<%= @match.time&.min == val ? '#1EDD88' : 'rgba(255,255,255,0.7)' %>; font-size:0.88rem; font-weight:<%= @match.time&.min == val ? '700' : '500' %>; text-align:left; cursor:pointer; box-shadow:none !important;"
                              data-time-picker-item
                              data-action="click->time-picker#select"
                              data-value="<%= val %>"
                              data-label="<%= lbl %>">
                        <%= lbl %>
                      </button>
                    <% end %>
                  </div>

                </div>

              </div>
            </div>

          </div>
        </div><%# fin section 3 %>


        <%# ────────────────────────────────────────────────
            SECTION 4 : Détails du match
            Champs :
              - Nombre de joueurs manquants (compteur − N +)
              - Niveau requis (boutons radio stylisés)
              - Validation des joueurs (toggle Manuel/Auto)
            ──────────────────────────────────────────────── %>
        <div class="match-form-section">

          <div class="match-form-section-header">
            <div class="match-form-step-badge">4</div>
            <h2 class="match-form-section-title">Détails du match</h2>
          </div>

          <%# ── Sélecteur de format — visible uniquement pour les sports multi-formats ── %>
          <div class="mb-4" data-match-form-target="formatWrapper" style="display:none;">
            <label class="form-label d-block">Format <span class="required-star">*</span></label>
            <%= f.hidden_field :format, data: { "match-form-target": "formatInput" } %>
            <div class="match-level-buttons" data-match-form-target="formatButtons"></div>
          </div>

          <%# ── Compteur : Nombre de joueurs manquants ── %>
          <div class="mb-4">
            <label class="form-label d-block">Nombre de joueurs manquants <span class="required-star">*</span></label>

            <%# Input caché : sa valeur est la vraie valeur soumise avec le formulaire.
                Le compteur visible (+/-) met à jour cet input via Stimulus.
                Valeur par défaut : 4 si non défini %>
            <%= f.hidden_field :player_left,
                value: (@match.player_left || 1),
                data: { "match-form-target": "playersInput" } %>

            <div class="match-player-counter">

              <%# Bouton "−" : appelle decrement() dans le contrôleur Stimulus
                  data-match-form-target="minusBtn" → Stimulus y accède pour changer sa couleur %>
              <button type="button"
                      class="counter-btn counter-btn-minus"
                      data-action="click->match-form#decrement"
                      data-match-form-target="minusBtn"
                      aria-label="Réduire le nombre de joueurs">−</button>

              <%# Chiffre affiché — mis à jour par Stimulus (target "playersCount") %>
              <span class="counter-value"
                    data-match-form-target="playersCount">
                <%= @match.player_left || 1 %>
              </span>

              <%# Bouton "+" : appelle increment() dans le contrôleur Stimulus
                  data-match-form-target="plusBtn" → Stimulus y accède pour changer sa couleur %>
              <button type="button"
                      class="counter-btn"
                      data-action="click->match-form#increment"
                      data-match-form-target="plusBtn"
                      aria-label="Augmenter le nombre de joueurs">+</button>

            </div>
          </div><%# fin compteur %>

          <%# ── Boutons de niveau ── %>
          <div class="mb-4">
            <label class="form-label d-block">Niveau requis <span class="required-star">*</span></label>

            <%# Input caché : contient le niveau sélectionné (ex: "Avancé").
                Mis à jour par selectLevel() dans Stimulus quand on clique un bouton. %>
            <%= f.hidden_field :level,
                value: @match.level,
                data: { "match-form-target": "levelInput" } %>

            <%# Groupe de boutons stylisés (pas de vrais radio inputs)
                Chaque bouton a data-level="Nom du niveau" et data-action pour Stimulus
                La classe .active est ajoutée/retirée par Stimulus selon la sélection %>
            <div class="match-level-buttons">
              <% Match::LEVELS.each do |lvl| %>
                <%# Styles inline garantis + hover via onmouseover/onmouseout (contourne !important du CSS) %>
                <button type="button"
                        class="match-level-btn <%= 'active' if @match.level == lvl %>"
                        style="padding:0.5rem 1.1rem; border-radius:0.5rem; font-size:0.9rem; cursor:pointer; border:<%= @match.level == lvl ? '2px solid #1EDD88' : '2px solid rgba(255,255,255,0.4)' %> !important; background:<%= @match.level == lvl ? 'rgba(30,221,136,0.12)' : 'rgba(255,255,255,0.08)' %> !important; color:<%= @match.level == lvl ? '#1EDD88' : 'rgba(255,255,255,0.9)' %> !important;"
                        onmouseover="if(!this.classList.contains('active')){this.style.setProperty('border','2px solid #1EDD88','important');this.style.setProperty('background','rgba(30,221,136,0.08)','important');this.style.setProperty('color','#1EDD88','important')}"
                        onmouseout="if(!this.classList.contains('active')){this.style.setProperty('border','2px solid rgba(255,255,255,0.4)','important');this.style.setProperty('background','rgba(255,255,255,0.08)','important');this.style.setProperty('color','rgba(255,255,255,0.9)','important')}"
                        data-level="<%= lvl %>"
                        data-action="click->match-form#selectLevel">
                  <%= lvl %>
                </button>
              <% end %>
            </div>

          </div><%# fin niveau %>

          <%# ── Toggle : Validation Manuel / Automatique ── %>
          <div class="mb-0">
            <label class="form-label d-block">
              Validation des joueurs
              <%# Infobulle CSS pure — même style que sur la page d'inscription %>
              <span class="css-tooltip"
                    data-tip="Vous avez la possibilité de valider manuellement ou automatiquement les personnes qui s'inscrivent à votre match.">
                <i data-lucide="info" style="width:14px;height:14px;vertical-align:middle;"></i>
              </span>
            </label>

            <%# Champ caché : contient la vraie valeur envoyée avec le formulaire.
                Mis à jour via onchange du toggle ci-dessous. %>
            <%= f.hidden_field :validation_mode, value: (@match.validation_mode || "automatic"),
                id: "match_validation_mode" %>

            <%# Conteneur compact : fond + bordure, inline pour ne pas prendre toute la largeur %>
            <div style="display:inline-flex; align-items:center; gap:0.75rem; margin-top:0.6rem;
                        background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12);
                        border-radius:10px; padding:0.55rem 0.9rem;">

              <%# Label gauche : Manuel — cliquable, vert si sélectionné %>
              <span id="label_manuel"
                    onclick="document.getElementById('validation_toggle').checked = false; document.getElementById('validation_toggle').dispatchEvent(new Event('change'));"
                    style="font-size:0.82rem; font-weight:700; white-space:nowrap; cursor:pointer;
                           color:<%= @match.manual_validation? ? '#1EDD88' : 'rgba(255,255,255,0.4)' %>;
                           transition:color 0.15s;">
                ✋ Manuel
              </span>

              <%# Toggle pill %>
              <label class="pill-toggle" for="validation_toggle" style="flex-shrink:0;">
                <%= check_box_tag :validation_mode_toggle,
                    "automatic",
                    !@match.manual_validation?,
                    class: "pill-toggle-input",
                    id: "validation_toggle",
                    data: {
                      "match-form-target": "validationToggle",
                      "action": "change->match-form#updateValidation"
                    },
                    onchange: "
                      document.getElementById('match_validation_mode').value = this.checked ? 'automatic' : 'manual';
                      document.getElementById('label_manuel').style.color      = this.checked ? 'rgba(255,255,255,0.4)' : '#1EDD88';
                      document.getElementById('label_automatique').style.color = this.checked ? '#1EDD88' : 'rgba(255,255,255,0.4)';
                    " %>
                <span class="pill-toggle-track"></span>
              </label>

              <%# Label droit : Automatique — cliquable, vert si sélectionné %>
              <span id="label_automatique"
                    onclick="document.getElementById('validation_toggle').checked = true; document.getElementById('validation_toggle').dispatchEvent(new Event('change'));"
                    style="font-size:0.82rem; font-weight:700; white-space:nowrap; cursor:pointer;
                           color:<%= @match.manual_validation? ? 'rgba(255,255,255,0.4)' : '#1EDD88' %>;
                           transition:color 0.15s;">
                ⚡ Automatique
              </span>

            </div>
          </div><%# fin toggle validation %>

          <%# ── Toggle : Visibilité Public / Privé ── %>
          <%# Champ caché mis à jour par JS selon la position du toggle %>
          <%= hidden_field_tag "match[visibility]", @match.visibility.presence || "public", id: "match_visibility" %>

          <div class="mb-0 mt-3">
            <label class="form-label d-block">
              Visibilité du match
              <span class="css-tooltip"
                    data-tip="Un match privé n'est accessible que via le lien d'invitation. Vous pouvez l'ouvrir au public à tout moment pour compléter les places restantes.">
                <i data-lucide="info" style="width:13px; height:13px; vertical-align:middle; opacity:0.5;"></i>
              </span>
            </label>

            <div style="display:inline-flex; align-items:center; gap:0.75rem; margin-top:0.6rem;
                        background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12);
                        border-radius:10px; padding:0.55rem 0.9rem;">

              <%# Label gauche : Privé — cliquable, vert si sélectionné %>
              <span id="label_prive"
                    onclick="document.getElementById('visibility_toggle').checked = false; document.getElementById('visibility_toggle').dispatchEvent(new Event('change'));"
                    style="font-size:0.82rem; font-weight:700; white-space:nowrap; cursor:pointer;
                           color:<%= @match.private? ? '#1EDD88' : 'rgba(255,255,255,0.4)' %>;
                           transition:color 0.15s;">
                🔒 Privé
              </span>

              <%# Toggle pill — coché = public (par défaut), décoché = privé %>
              <label class="pill-toggle" for="visibility_toggle" style="flex-shrink:0;">
                <%= check_box_tag :visibility_toggle,
                    "public",
                    !@match.private?,
                    class: "pill-toggle-input",
                    id: "visibility_toggle",
                    onchange: "
                      document.getElementById('match_visibility').value   = this.checked ? 'public' : 'private';
                      document.getElementById('label_prive').style.color  = this.checked ? 'rgba(255,255,255,0.4)' : '#1EDD88';
                      document.getElementById('label_public').style.color = this.checked ? '#1EDD88' : 'rgba(255,255,255,0.4)';
                    " %>
                <span class="pill-toggle-track"></span>
              </label>

              <%# Label droit : Public — cliquable, vert si sélectionné %>
              <span id="label_public"
                    onclick="document.getElementById('visibility_toggle').checked = true; document.getElementById('visibility_toggle').dispatchEvent(new Event('change'));"
                    style="font-size:0.82rem; font-weight:700; white-space:nowrap; cursor:pointer;
                           color:<%= @match.private? ? 'rgba(255,255,255,0.4)' : '#1EDD88' %>;
                           transition:color 0.15s;">
                🌍 Public
              </span>

            </div>
          </div><%# fin toggle visibilité %>

          <%# ── Toggle : Restriction de genre Tous / Féminin ── %>
          <%# Champ caché mis à jour par JS selon la position du toggle %>
          <%= f.hidden_field :genre_restriction,
              value: (@match.genre_restriction.presence || "tous"),
              id: "match_genre_restriction" %>

          <div class="mb-0 mt-3">
            <label class="form-label d-block">
              Restriction de genre
              <span class="css-tooltip"
                    data-tip="'Tous' : tout le monde peut rejoindre. 'Féminin' : uniquement les joueuses.">
                <i data-lucide="info" style="width:13px; height:13px; vertical-align:middle; opacity:0.5;"></i>
              </span>
            </label>

            <%# Toggle : coché = féminin, décoché = tous (par défaut) %>
            <div style="display:inline-flex; align-items:center; gap:0.75rem; margin-top:0.6rem;
                        background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12);
                        border-radius:10px; padding:0.55rem 0.9rem;">

              <%# Label gauche : Tous — cliquable, vert si sélectionné %>
              <span id="label_genre_tous"
                    onclick="document.getElementById('genre_restriction_toggle').checked = false; document.getElementById('genre_restriction_toggle').dispatchEvent(new Event('change'));"
                    style="font-size:0.82rem; font-weight:700; white-space:nowrap; cursor:pointer;
                           color:<%= (@match.genre_restriction.presence || 'tous') == 'tous' ? '#1EDD88' : 'rgba(255,255,255,0.4)' %>;
                           transition:color 0.15s;">
                🌍 Tous
              </span>

              <%# Toggle pill — décoché = tous, coché = féminin %>
              <label class="pill-toggle" for="genre_restriction_toggle" style="flex-shrink:0;">
                <%= check_box_tag :genre_restriction_toggle,
                    "feminin",
                    (@match.genre_restriction == "feminin"),
                    class: "pill-toggle-input",
                    id: "genre_restriction_toggle",
                    onchange: "
                      document.getElementById('match_genre_restriction').value         = this.checked ? 'feminin' : 'tous';
                      document.getElementById('label_genre_tous').style.color     = this.checked ? 'rgba(255,255,255,0.4)' : '#1EDD88';
                      document.getElementById('label_genre_feminin').style.color  = this.checked ? '#1EDD88' : 'rgba(255,255,255,0.4)';
                    " %>
                <span class="pill-toggle-track"></span>
              </label>

              <%# Label droit : Féminin — cliquable, vert si sélectionné %>
              <span id="label_genre_feminin"
                    onclick="document.getElementById('genre_restriction_toggle').checked = true; document.getElementById('genre_restriction_toggle').dispatchEvent(new Event('change'));"
                    style="font-size:0.82rem; font-weight:700; white-space:nowrap; cursor:pointer;
                           color:<%= @match.genre_restriction == 'feminin' ? '#1EDD88' : 'rgba(255,255,255,0.4)' %>;
                           transition:color 0.15s;">
                ♀ Féminin uniquement
              </span>

            </div>
          </div><%# fin toggle restriction de genre %>

          <%# ── Ligne séparatrice ── %>
          <hr class="my-4">

          <%# ── Prix par joueur (à titre indicatif) ── %>
          <div class="mb-0">
            <label class="form-label d-block" for="match_price_per_player">
              Prix par joueur (€)
            </label>

            <%# Champ petit : max-width 100px pour ne pas prendre toute la largeur %>
            <div style="max-width: 100px;">
              <%= f.number_field :price_per_player,
                  class: "form-control form-control-sm",
                  placeholder: "0",
                  min: 0,
                  step: 1,
                  value: (@match.price_per_player || 0),
                  onfocus: "if(this.value === '0') this.value = ''",
                  onblur:  "if(this.value === '') this.value = '0'",
                  data: {
                    "match-form-target": "priceInput",
                    "action": "input->match-form#updatePrice"
                  } %>
            </div>

            <%# Message informatif en gris semi-transparent %>
            <p class="form-text mt-1" style="color: rgba(255, 255, 255, 0.55); font-size: 0.8rem;">
              <i data-lucide="info" style="width:12px; height:12px; vertical-align:middle;"></i>
              Prix indicatif.
            </p>
          </div><%# fin prix %>

        </div><%# fin section 4 %>

        <%# Lien Annuler visible uniquement sur mobile (< lg)
            Sur desktop il est dans la sidebar %>
        <div class="d-lg-none mt-2">
          <%= link_to "Annuler", cancel_path, class: "btn btn-outline-secondary w-100" %>
        </div>

      </div><%# fin colonne gauche %>


      <%# ════════════════════════════════════════════════════
          COLONNE DROITE : Récapitulatif (sticky)
          Cette colonne reste visible pendant le scroll grâce à
          position: sticky dans _match_form.scss
          ════════════════════════════════════════════════════ %>
      <%# position:sticky + align-self:flex-start : la colonne a sa hauteur naturelle
          (celle de la carte) et reste visible en haut pendant le scroll.
          top:-1.5rem (négatif) : compense le margin-top:2rem de .match-recap-card
          → au scroll, la carte apparaît à -1.5rem + 2rem = 0.5rem du haut de l'écran %>
      <div class="col-lg-5" style="position:sticky; top:-16px; align-self:flex-start;">
        <div class="match-recap-card">

          <%# En-tête "Récapitulatif" avec icône %>
          <div class="match-recap-header">
            <i data-lucide="bar-chart-2" style="width:18px; height:18px;"></i>
            <span>Récapitulatif</span>
          </div>

          <%# Titre du match (mis à jour en temps réel par Stimulus)
              Valeur initiale : titre existant ou texte par défaut %>
          <h3 class="match-recap-main-title"
              data-match-form-target="recapTitle">
            <%# Première lettre en majuscule, reste en minuscules %>
            <%= @match.title.present? ? (@match.title[0].upcase + @match.title[1..].downcase) : "Titre" %>
          </h3>

          <%# Description courte (tronquée à 80 caractères par Stimulus)
              Masquée si vide — Stimulus la réaffiche quand l'utilisateur saisit quelque chose %>
          <p class="match-recap-description"
             data-match-form-target="recapDescription"
             style="<%= 'display:none;' if @match.description.blank? %>">
            <%= truncate(@match.description.to_s, length: 80) %>
          </p>

          <%# ── Ligne Sport ── %>
          <div class="match-recap-row">
            <span class="recap-label">Sport</span>
            <span class="recap-value" data-match-form-target="recapSport">
              <%# Affiche l'emoji + nom du sport si sélectionné %>
              <% if @match.sport %>
                <%= sport_icon(@match.sport, size: "1rem") %> <%= @match.sport.name %>
              <% else %>
                —
              <% end %>
            </span>
          </div>

          <%# ── Ligne Lieu ── %>
          <div class="match-recap-row">
            <span class="recap-label">Lieu</span>
            <span class="recap-value" data-match-form-target="recapPlace">
              <%= @match.place.to_s %>
            </span>
          </div>

          <%# ── Ligne Date ── %>
          <div class="match-recap-row">
            <span class="recap-label">Date</span>
            <span class="recap-value" data-match-form-target="recapDate">
              <%# strftime formatage : "16 mar. 2026"
                  Stimulus mettra à jour avec le format français dynamiquement %>
              <%= @match.date.present? ? @match.date.strftime("%d %b %Y") : "—" %>
            </span>
          </div>

          <%# ── Ligne Heure ── %>
          <div class="match-recap-row">
            <span class="recap-label">Heure</span>
            <span class="recap-value" data-match-form-target="recapTime">
              <%# strftime "%Hh%M" donne "21h15" %>
              <%= @match.time.present? ? @match.time.strftime("%Hh%M") : "—" %>
            </span>
          </div>

          <%# ── Ligne Format — masquée si sport mono-format ── %>
          <div class="match-recap-row" data-match-form-target="recapFormatRow" style="display:none;">
            <span class="recap-label">Format</span>
            <span class="recap-value" data-match-form-target="recapFormat">—</span>
          </div>

          <%# ── Ligne Joueurs recherchés ── %>
          <div class="match-recap-row">
            <span class="recap-label">Joueurs recherchés</span>
            <span class="recap-value" data-match-form-target="recapPlayers">
              <%= @match.player_left || 4 %>
            </span>
          </div>

          <%# ── Ligne Niveau souhaité ── %>
          <div class="match-recap-row">
            <span class="recap-label">Niveau souhaité</span>
            <span class="recap-value" data-match-form-target="recapLevel">
              <%= @match.level.to_s %>
            </span>
          </div>

          <%# ── Ligne Validation — mise à jour en temps réel par Stimulus ── %>
          <div class="match-recap-row" style="border-bottom: none;">
            <span class="recap-label">Validation</span>
            <%# data-match-form-target="recapValidation" : Stimulus écrit "Manuel" ou "Automatique" ici %>
            <span class="recap-value" data-match-form-target="recapValidation">
              <%= @match.manual_validation? ? "Manuel" : "Automatique" %>
            </span>
          </div>

          <%# ── Prix par joueur (affiché en blanc en bas du récap) ── %>
          <div class="match-recap-price mt-1">
            <span class="recap-price-label">Prix par joueur</span>
            <span class="recap-price-value" data-match-form-target="recapPrice">
              <%# Affiche le prix en € si > 0, sinon rien %>
              <% price = @match.price_per_player.to_i %>
              <%= price > 0 ? "#{price} €" : "" %>
            </span>
          </div>

          <%# ── Bouton de soumission ──
              f.submit détecte automatiquement si c'est une création ou une modification
              On surcharge le texte manuellement pour coller au design %>
          <%= f.submit(@match.new_record? ? "Publier le match" : "Enregistrer les modifications",
              class: "match-publish-btn") %>

          <%# Petit texte légal sous le bouton %>
          <p class="match-publish-legal">
            En publiant, vous acceptez nos conditions d'utilisation et la politique d'annulation.
          </p>

          <%# Lien Annuler visible uniquement sur desktop (≥ lg)
              Sur mobile il est en bas de la colonne gauche %>
          <div class="d-none d-lg-block text-center mt-2">
            <%= link_to "Annuler", cancel_path,
                class: "btn btn-link btn-sm text-success" %>
          </div>

        </div><%# fin match-recap-card %>
      </div><%# fin colonne droite %>

    </div><%# fin row %>
  </div><%# fin container %>

<% end %><%# fin form_with %>
