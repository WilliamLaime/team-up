<%# Partial réutilisé par new.html.erb et edit.html.erb %>
<%# La variable @match est passée automatiquement par le controller %>

<%= form_with model: @match, class: "row g-3" do |f| %>

  <%# Affiche les erreurs de validation si le formulaire est invalide %>
  <% if @match.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @match.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# Titre du match — obligatoire %>
  <div class="col-12">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :title, class: "form-label" do %>
      Titre <span class="text-danger">*</span>
    <% end %>
    <%= f.text_field :title, class: "form-control", placeholder: "Ex: Match foot samedi matin", required: true %>
  </div>

  <%# Description %>
  <div class="col-12">
    <%= f.label :description, "Description", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Décris ton match..." %>
  </div>

  <%# Date et heure sur la même ligne %>
  <div class="col-md-6">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :date, class: "form-label" do %>
      Date <span class="text-danger">*</span>
    <% end %>
    <%# La valeur par défaut (aujourd'hui) est définie dans le controller #new %>
    <%= f.date_field :date, class: "form-control", value: @match.date, required: true %>
  </div>

  <div class="col-md-6">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :time, class: "form-label" do %>
      Heure <span class="text-danger">*</span>
    <% end %>
    <%#
      time_select génère deux <select> séparés :
        - un pour les heures (0 à 23)
        - un pour les minutes (uniquement 00, 15, 30, 45 grâce à minute_step: 15)
      Rails combine automatiquement les deux valeurs en un objet Time lors de la soumission.
    %>
    <div class="d-flex gap-2">
      <%= f.time_select :time,
          { minute_step: 15, default: @match.time, prompt: { hour: "Heure", minute: "Min" } },
          { class: "form-select" } %>
    </div>
  </div>

  <%#
    Lieu avec barre de recherche dynamique (Stimulus controller "place-search")
    L'utilisateur tape, des suggestions apparaissent en dessous via l'API Nominatim
  %>
  <div class="col-12" data-controller="place-search">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :place, class: "form-label" do %>
      Lieu <span class="text-danger">*</span>
    <% end %>

    <div class="position-relative">
      <%#
        Champ principal — sa valeur est soumise avec le formulaire
        data-place-search-target="input" : Stimulus surveille ce champ
        data-action="input->place-search#search" : lance la recherche à chaque frappe
      %>
      <%= f.text_field :place,
          class: "form-control",
          placeholder: "Rechercher un lieu... ex: 4Padel Bordeaux",
          autocomplete: "off",
          required: true,
          data: {
            "place-search-target": "input",
            "action": "input->place-search#search"
          } %>

      <%# Dropdown des résultats — affiché/caché dynamiquement par Stimulus %>
      <div data-place-search-target="dropdown"
           class="dropdown-menu w-100 shadow"
           style="display:none; position:absolute; top:100%; left:0; z-index:1050; max-height:250px; overflow-y:auto;">
      </div>
    </div>
  </div>

  <%# Niveau et nombre de joueurs sur la même ligne %>
  <div class="col-md-6">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :level, class: "form-label" do %>
      Niveau <span class="text-danger">*</span>
    <% end %>
    <%#
      Match::LEVELS = ["Tout niveau", "Débutant", "Intermédiaire", "Avancé"]
      prompt: affiche "Choisir un niveau" en premier (non sélectionnable)
      required: true → le navigateur bloque la soumission si vide
    %>
    <%= f.select :level,
        Match::LEVELS,
        { prompt: "Choisir un niveau" },
        class: "form-select",
        required: true %>
  </div>

  <div class="col-md-6">
    <%# La * rouge indique que le champ est obligatoire %>
    <%= f.label :player_left, class: "form-label" do %>
      Places disponibles <span class="text-danger">*</span>
    <% end %>
    <%= f.number_field :player_left, class: "form-control", min: 1, placeholder: "Ex: 5", required: true %>
  </div>

  <%# Mode de validation des joueurs — toggle Bootstrap %>
  <div class="col-12">
    <label class="form-label d-block">Validation des joueurs</label>

    <%# Champ caché envoyé par défaut quand le toggle est OFF (automatique) %>
    <%= f.hidden_field :validation_mode, value: "automatic" %>

    <div class="form-check form-switch">
      <%#
        La checkbox envoie "manual" quand elle est cochée (toggle ON).
        Quand elle est décochée, le hidden_field au-dessus envoie "automatic".
        checked: true si le match est déjà en mode manuel (utile pour l'édition)
      %>
      <%= check_box_tag :validation_mode_toggle,
          "manual",
          @match.manual_validation?,
          class: "form-check-input",
          id: "validation_toggle",
          role: "switch",
          onchange: "document.getElementById('match_validation_mode').value = this.checked ? 'manual' : 'automatic'" %>
      <label class="form-check-label" for="validation_toggle">
        Validation manuelle
      </label>
    </div>

    <%# Texte d'aide qui change selon l'état du toggle %>
    <div class="form-text" id="validation_help">
      <% if @match.manual_validation? %>
        Tu valides toi-même chaque joueur.
      <% else %>
        Les joueurs sont acceptés immédiatement.
      <% end %>
    </div>

    <%# Script pour mettre à jour le texte d'aide en temps réel %>
    <script>
      document.getElementById('validation_toggle').addEventListener('change', function() {
        const help = document.getElementById('validation_help');
        help.textContent = this.checked
          ? 'Tu valides toi-même chaque joueur.'
          : 'Les joueurs sont acceptés immédiatement.';
      });
    </script>
  </div>

  <%# Légende des champs obligatoires %>
  <div class="col-12">
    <small class="text-muted"><span class="text-danger">*</span> Champs obligatoires</small>
  </div>

  <%# Bouton de soumission %>
  <div class="col-12">
    <%= f.submit class: "btn btn-primary" %>
  </div>

<% end %>
