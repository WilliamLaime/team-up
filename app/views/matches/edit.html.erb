<%# Page de modification d'un match existant %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <h1 class="mb-4">Modifier le match</h1>

      <%# On appelle le formulaire partagé _form.html.erb %>
      <%# Rails détecte que @match existe déjà en base et génère un formulaire PATCH %>
      <%= render "form" %>

      <%# Liens de navigation %>
      <div class="mt-3 d-flex gap-2">
        <%= link_to "Annuler", match_path(@match), class: "btn btn-outline-secondary" %>
      </div>

    </div>
  </div>
</div>
