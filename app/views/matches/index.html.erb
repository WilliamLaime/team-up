<%# Liste de tous les matchs disponibles %>

<%#
  Abonnement au canal ActionCable "matches".
  Quand un match est créé/modifié/supprimé, la page se met à jour automatiquement
  sans rechargement grâce à Turbo Stream (WebSocket).
%>
<%= turbo_stream_from "matches" %>

<div class="container my-4">

  <%# ── Bouton retour ──────────────────────────────────────────────────────── %>
  <%= link_to :back, class: "btn btn-outline-secondary btn-sm mb-3" do %>
    ← Retour
  <% end %>

  <%# ── En-tête avec titre et bouton de création ───────────────────────────── %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Les matchs</h1>
    <%= link_to "Créer un match", new_match_path, class: "btn btn-primary" %>
  </div>

  <%# ── Formulaire de filtres ──────────────────────────────────────────────── %>
  <%# Méthode GET pour que les filtres apparaissent dans l'URL (pratique pour partager) %>
  <%= form_with url: matches_path, method: :get, local: true, class: "mb-4" do |f| %>
    <div class="row g-2 align-items-end">

      <%# Barre de recherche libre — cherche dans titre, ville, description et email du créateur %>
      <div class="col-12 col-md-4">
        <%= f.label :query, "Recherche", class: "form-label small fw-semibold mb-1" %>
        <%= f.text_field :query,
            value: params[:query],
            placeholder: "Titre, ville, description...",
            class: "form-control form-control-sm" %>
      </div>

      <%# Filtre : Date (impossible de choisir une date déjà passée) %>
      <div class="col-12 col-md-2">
        <%= f.label :date, "Date", class: "form-label small fw-semibold mb-1" %>
        <%= f.date_field :date,
            value: params[:date],
            min: Date.today,
            class: "form-control form-control-sm" %>
      </div>


      <%# Filtre : Heure minimum — uniquement les créneaux toutes les 15 minutes %>
      <div class="col-12 col-md-2">
        <%= f.label :time_from, "Heure (à partir de)", class: "form-label small fw-semibold mb-1" %>
        <%#
          On génère les options : 00:00, 00:15, 00:30, 00:45, 01:00, ..., 23:45
          (0..23) → chaque heure
          [0, 15, 30, 45] → les 4 créneaux par heure
        %>
        <%= f.select :time_from,
            [["Toutes heures", ""]] + (0..23).flat_map { |h|
              [0, 15, 30, 45].map { |m| "%02d:%02d" % [h, m] }
            },
            { selected: params[:time_from] },
            class: "form-select form-select-sm" %>
      </div>

      <%# Filtre : Niveau %>
      <div class="col-12 col-md-2">
        <%= f.label :level, "Niveau", class: "form-label small fw-semibold mb-1" %>
        <%= f.select :level,
            [["Tous les niveaux", ""]] + Match::LEVELS,
            { selected: params[:level] },
            class: "form-select form-select-sm" %>
      </div>

      <%# Filtre : Ville %>
      <div class="col-12 col-md-2">
        <%= f.label :place, "Ville", class: "form-label small fw-semibold mb-1" %>
        <%= f.text_field :place,
            value: params[:place],
            placeholder: "Ex : Paris",
            class: "form-control form-control-sm" %>
      </div>

      <%# Filtre : Places disponibles (minimum) %>
      <div class="col-12 col-md-2">
        <%= f.label :player_left, "Places dispo (min)", class: "form-label small fw-semibold mb-1" %>
        <%= f.number_field :player_left,
            value: params[:player_left],
            min: 1,
            placeholder: "Ex : 2",
            class: "form-control form-control-sm" %>
      </div>

      <%# Boutons Filtrer + Réinitialiser %>
      <div class="col-12 col-md-2 d-flex gap-2">
        <%= f.submit "Filtrer", class: "btn btn-primary btn-sm" %>
        <%= link_to "Réinitialiser", matches_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>

    </div>
  <% end %>

  <%# ── Liste des matchs ───────────────────────────────────────────────────── %>
  <% if @matches.empty? %>
    <%# Message si aucun match ne correspond aux filtres %>
    <div class="alert alert-info">
      Aucun match disponible pour le moment. Sois le premier à en créer un !
    </div>
  <% else %>

    <%#
      Stimulus controller "load-more" :
      - data-controller="load-more"          → active le controller JS
      - data-load-more-step-value="6"        → nombre de cartes révélées par clic
      Chaque carte a data-load-more-target="card"
      Le bouton a data-load-more-target="button" et data-action="load-more#more"
    %>
    <div data-controller="load-more" data-load-more-step-value="6">

      <%#
        Grille de cartes Bootstrap — 3 colonnes sur grand écran, 1 sur mobile.
        id="matches" est OBLIGATOIRE : c'est la cible du broadcast ActionCable.
        Quand un nouveau match est créé, Turbo l'ajoute automatiquement ici (append).
      %>
      <div id="matches" class="row row-cols-1 row-cols-md-3 g-4">
        <%# render @matches appelle automatiquement le partial _match.html.erb pour chaque match %>
        <%= render @matches %>
      </div>

      <%# ── Bouton "Afficher plus de matchs" ──────────────────────────────── %>
      <%# data-load-more-target="button" → le controller le cache quand tout est visible %>
      <%# data-action="load-more#more"   → appelle la méthode more() au clic %>
      <div class="text-center mt-4">
        <button
          class="btn btn-outline-primary"
          data-load-more-target="button"
          data-action="click->load-more#more">
          Afficher plus de matchs
        </button>
      </div>

    </div>
  <% end %>

</div>
