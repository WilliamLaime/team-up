<%# ── Liste de tous les matchs disponibles ──────────────────────────────────── %>

<%# Abonnement ActionCable : mises à jour en temps réel sans rechargement %>
<%= turbo_stream_from "matches" %>

<div class="matches-index-page">
  <div class="container">

  <%# ── En-tête ──────────────────────────────────────────────────────────── %>
    <div class="matches-index-header">

      <%# Lien retour — utilise le composant partagé nav_button %>
      <%= render "shared/nav_button", url: root_path, label: "Retour", direction: "back", extra_class: "mb-2" %>

      <%# Titre et sous-titre différents selon le contexte (mes matchs vs liste générale) %>
      <% if params[:mine].present? %>
        <h1 class="matches-index-title">Mes matchs</h1>
        <div class="d-flex align-items-center justify-content-between">
          <p class="matches-index-subtitle mb-0">
            Tous les matchs auxquels tu participes ou que tu as créés.
          </p>
          <%= link_to "Créer un match", new_match_path, class: "btn btn-primary btn-sm px-3 btn-cta-primary" %>
        </div>

        <%# Onglets En cours / Terminés — uniquement dans le mode "mes matchs" %>
        <%# Lien sans status = En cours ; status=completed = Terminés %>
        <div class="matches-status-tabs">
          <%= link_to matches_path(mine: 1),
              class: "matches-status-tab #{'active' if params[:status].blank?}" do %>
            <i data-lucide="play-circle" style="width:14px;height:14px;"></i>
            En cours
          <% end %>
          <%= link_to matches_path(mine: 1, status: "completed"),
              class: "matches-status-tab #{'active' if params[:status] == 'completed'}" do %>
            <i data-lucide="check-circle" style="width:14px;height:14px;"></i>
            Terminés
          <% end %>
        </div>

      <% else %>
        <h1 class="matches-index-title">Trouver un match</h1>
        <div class="d-flex align-items-center justify-content-between">
          <p class="matches-index-subtitle mb-0">
            Rejoignez les matchs pas loin de chez vous.
          </p>
          <% if user_signed_in? %>
            <%= link_to "Créer un match", new_match_path, class: "btn btn-primary btn-sm px-3 btn-cta-primary" %>
          <% end %>
        </div>
      <% end %>

    </div>

    <%# ── Barre de filtres ────────────────────────────────────────────────── %>
    <%# Masquée en mode "mes matchs" : les onglets En cours/Terminés remplacent les filtres %>
    <%# GET → les paramètres apparaissent dans l'URL (partageables) %>
    <%= form_with url: matches_path, method: :get, local: true,
        style: params[:mine].present? ? "display:none;" : "" do |f| %>
      <div class="matches-filters-bar">

        <%# ── Filtres pill (gauche) ─────────────────────────────────────── %>
        <div class="matches-filters-left">

          <%# Date %>
          <div class="filter-pill-group">
            <i data-lucide="calendar" style="width:14px;height:14px;"></i>
            <%= f.date_field :date,
                value: params[:date],
                min: Date.today,
                class: "filter-date-input" %>
          </div>

          <%#
            ── Calculs pour le filtre niveau dynamique ──
            Les niveaux affichés dépendent du/des sport(s) sélectionné(s).
            En JS (level-filter + sport-filter controllers), les checkboxes
            sont reconstruites côté client quand le sport change — sans rechargement.
          %>
          <%
            # IDs des sports cochés dans l'URL (ou sport actif si pas de param)
            selected_sport_ids = params[:sport_ids]&.map(&:to_i)&.reject(&:zero?) || []
            selected_sport_ids = [current_sport.id] if selected_sport_ids.empty? && current_sport&.id

            # Sport par défaut pour le filtre niveau quand aucun sport n'est sélectionné :
            # → sport actif du contexte utilisateur, sinon premier sport alphabétiquement
            default_sport = current_sport || Sport.order(:name).first

            # Convertit un sport en tableau de niveaux [{label, css}] sans "Tout niveau"
            levels_for = ->(sp) {
              sp.available_levels.map { |l| { label: l[:label], css: level_badge_css(l[:label], sp) } }
            }

            # Niveaux à afficher au chargement de la page
            initial_levels = if selected_sport_ids.length == 1
              # 1 sport → grille complète du sport
              sp = Sport.find_by(id: selected_sport_ids.first)
              sp ? levels_for.(sp) : (default_sport ? levels_for.(default_sport) : [])
            else
              # 0 sport → grille du sport actif par défaut
              default_sport ? levels_for.(default_sport) : []
            end

            # Map sport_id → [{label, css}] passée en JSON au controller Stimulus.
            # Clé "0" = niveaux du sport actif (fallback JS quand aucun sport sélectionné).
            sports_levels_map = Sport.all.each_with_object({}) do |sp, h|
              h[sp.id] = levels_for.(sp)
            end
            sports_levels_map[0] = default_sport ? levels_for.(default_sport) : []
          %>

          <%# Niveau — dropdown custom avec badges et checkboxes (multi-sélection) %>
          <%# data-sports-levels : map JSON utilisée par le controller pour reconstruire les options %>
          <div class="level-filter-pill"
               data-controller="level-filter"
               data-sports-levels="<%= sports_levels_map.to_json %>"
               style="position:relative">

            <%# Trigger : pill cliquable %>
            <button type="button"
                    class="filter-pill-group level-filter-trigger"
                    data-action="click->level-filter#toggle">
              <i data-lucide="bar-chart-2" style="width:14px;height:14px;"></i>
              <span data-level-filter-target="label" style="color:rgba(255,255,255,0.9);">Niveau</span>
              <i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:2px;"></i>
            </button>

            <%# Panel dropdown %>
            <div class="level-filter-dropdown"
                 data-level-filter-target="dropdown"
                 style="display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:300; flex-direction:column; width:fit-content; min-width:160px; background:#242624; border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:0.35rem; box-shadow:0 10px 30px rgba(0,0,0,0.6); gap:0.15rem; max-height:340px; overflow-y:auto;">

              <%# RGAA 11.5 — fieldset/legend pour grouper les checkboxes de même nature %>
              <%# Conteneur des checkboxes — reconstruit par JS quand le sport change %>
              <fieldset style="border:none; padding:0; margin:0;">
                <legend class="visually-hidden">Filtrer par niveau</legend>
              <div data-level-filter-target="list"
                   style="display:flex; flex-direction:column; gap:0.15rem;">
                <% initial_levels.each do |lvl| %>
                  <label style="display:flex; flex-direction:row; align-items:center; gap:0.6rem; padding:0.35rem 0.5rem; border-radius:6px; cursor:pointer; margin:0; width:100%;">
                    <input type="checkbox"
                           name="levels[]"
                           value="<%= lvl[:label] %>"
                           data-level-filter-target="checkbox"
                           data-action="change->level-filter#change"
                           style="width:15px; height:15px; margin:0; padding:0; flex-shrink:0; cursor:pointer; accent-color:#1EDD88;"
                           <%# Pré-coché si filtre URL OU si préfiltre profil actif %>
                           <%= "checked" if params[:levels]&.include?(lvl[:label]) ||
                                            (@active_prefilters&.dig(:level) && @prefilter_params[:level] == lvl[:label]) %>>
                    <span class="match-badge-level <%= lvl[:css] %>"
                          style="font-size:0.72rem; padding:0.2rem 0.6rem; line-height:1; margin:0;">
                      <%= lvl[:label] %>
                    </span>
                  </label>
                <% end %>
              </div>
              </fieldset>

              <%# Bouton "?" pour ouvrir la modale des grilles %>
              <button type="button"
                      style="margin-top:0.2rem; width:100%; padding:0.3rem 0.5rem; background:rgba(255,255,255,0.04);
                             border:1px solid rgba(255,255,255,0.1); border-radius:6px; font-size:0.72rem;
                             color:rgba(255,255,255,0.5); cursor:pointer; text-align:left;"
                      data-bs-toggle="modal"
                      data-bs-target="#levelGridModal"
                      aria-label="Voir la grille des niveaux">
                ? Voir les grilles de niveaux
              </button>

              <%# Bouton Appliquer %>
              <button type="button"
                      data-action="click->level-filter#apply"
                      style="margin-top:0.3rem; width:100%; padding:0.35rem 0; background:#1EDD88; color:#111; border:none; border-radius:6px; font-size:0.75rem; font-weight:700; cursor:pointer; transition:opacity 0.15s;"
                      onmouseover="this.style.opacity='0.85'"
                      onmouseout="this.style.opacity='1'">
                Appliquer
              </button>

            </div>
          </div>

          <%# Sport — dropdown custom sélection unique (radio buttons) %>
          <% if Sport.count > 0 %>
            <div class="sport-filter-pill" data-controller="sport-filter" style="position:relative">

              <%# Trigger : pill cliquable %>
              <button type="button"
                      class="filter-pill-group sport-filter-trigger"
                      data-action="click->sport-filter#toggle">
                <span data-sport-filter-target="label" style="color:rgba(255,255,255,0.9);">Sport</span>
                <i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:2px;"></i>
              </button>

              <%# Panel dropdown — clic sur un radio ferme et soumet automatiquement %>
              <div class="sport-filter-dropdown"
                   data-sport-filter-target="dropdown"
                   style="display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:300; flex-direction:column; width:fit-content; min-width:150px; background:#242624; border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:0.35rem; box-shadow:0 10px 30px rgba(0,0,0,0.6); gap:0.15rem">

                <%# RGAA 11.5 — fieldset/legend pour grouper les boutons radio de même nature %>
                <fieldset style="border:none; padding:0; margin:0;">
                <legend class="visually-hidden">Filtrer par sport</legend>
                <%# Un radio par sport — auto-soumet au clic %>
                <% Sport.order(:name).each do |sport| %>
                  <%# Pré-sélectionné si dans l'URL, ou si c'est le sport actif (aucun filtre URL) %>
                  <% sport_checked = params[:sport_ids]&.include?(sport.id.to_s) ||
                                     (params[:sport_ids].blank? && current_sport&.id == sport.id) %>
                  <label style="display:flex; flex-direction:row; align-items:center; gap:0.6rem; padding:0.35rem 0.5rem; border-radius:6px; cursor:pointer; margin:0; width:100%;">
                    <input type="radio"
                           name="sport_ids[]"
                           value="<%= sport.id %>"
                           data-sport-filter-target="checkbox"
                           data-label-html="<%= sport_icon_html_attr(sport, size: '1rem') %>"
                           data-action="change->sport-filter#change"
                           style="width:15px; height:15px; margin:0; padding:0; flex-shrink:0; cursor:pointer; accent-color:#1EDD88;"
                           <% if sport_checked %>checked<% end %>>
                    <span style="display:inline-flex; align-items:center; gap:0.35rem; font-size:0.8rem; font-weight:600; color:rgba(255,255,255,0.85);">
                      <%= sport_icon(sport, size: "1.05rem") %>
                      <%= sport.name %>
                    </span>
                  </label>
                <% end %>
                </fieldset>

              </div>
            </div>
          <% end %>

          <%# Ville — avec autocomplétion via city_search_controller %>
          <%# position:relative nécessaire pour positionner le dropdown absolu dans ce bloc %>
          <div class="filter-pill-group" data-controller="city-search" style="position:relative;">
            <i data-lucide="map-pin" style="width:14px;height:14px; flex-shrink:0;"></i>
            <%# Pré-rempli avec la ville du préfiltre profil si aucun filtre URL actif %>
            <%= f.text_field :place,
                value: params[:place].presence || (@active_prefilters&.dig(:city) ? @prefilter_params[:city] : nil),
                placeholder: "Ville",
                class: "filter-text-input",
                autocomplete: "off",
                data: {
                  "city-search-target": "input",
                  action: "keyup->city-search#search"
                } %>

            <%# Dropdown de suggestions — caché par défaut, rempli dynamiquement par JS %>
            <div data-city-search-target="dropdown"
                 style="display:none; position:absolute; top:100%; left:0; z-index:300; min-width:200px; max-height:200px; overflow-y:auto; background:#242624; border:1px solid rgba(255,255,255,0.12); border-radius:8px; padding:0.35rem; box-shadow:0 10px 30px rgba(0,0,0,0.6);">
            </div>
          </div>

          <%# Filtre "Mes lieux favoris" — visible seulement si connecté ET lieux favoris renseignés %>
          <% if user_signed_in? && current_user.profil&.favorite_venues&.any? %>
            <label class="filter-pill-group" style="cursor:pointer; user-select:none;">
              <%= check_box_tag :favorite_venues, "1", params[:favorite_venues].present?,
                  class: "filter-checkbox",
                  style: "accent-color:#1EDD88; width:13px; height:13px; cursor:pointer;" %>
              <span style="font-size:0.8rem; white-space:nowrap;">Mes lieux ⭐</span>
            </label>
          <% end %>

          <%# Bouton "Effacer" visible seulement si un filtre est actif %>
          <% if params[:date].present? || params[:levels].present? || params[:place].present? || params[:query].present? || params[:sport_ids].present? || params[:favorite_venues].present? %>
            <%= link_to matches_path, class: "filter-reset-btn" do %>
              <i data-lucide="x" style="width:13px;height:13px;"></i>
              Effacer
            <% end %>
          <% end %>
        </div>

        <%# ── Recherche + Créer (droite) ───────────────────────────────── %>
        <div class="matches-filters-right">

          <%# Barre de recherche texte libre %>
          <div class="filter-search-wrap">
            <i data-lucide="search" style="width:15px;height:15px;" class="filter-search-icon"></i>
            <%= f.text_field :query,
                value: params[:query],
                placeholder: "Rechercher un match...",
                class: "filter-search-input" %>
          </div>

          <%# Submit caché — déclenché par JS au changement des selects/date %>
          <%= f.submit "Filtrer", id: "filter-submit-btn", class: "d-none" %>
        </div>

      </div>
    <% end %>

    <%# ── Indicateur discret : pré-filtres actifs OU désactivés ─────────────── %>
    <% if !params[:mine].present? %>
      <% if @active_prefilters&.any? %>
        <%# Les pré-filtres sont actifs → badges pour chaque filtre actif + lien "Voir tout" %>
        <p style="font-size:0.75rem; color:rgba(255,255,255,0.4); margin:0.1rem 0 0.75rem; display:flex; align-items:center; flex-wrap:wrap; gap:0.4rem;">
          <i data-lucide="sparkles" style="width:12px; height:12px; color:#1EDD88; flex-shrink:0;"></i>
          <span>Pré-filtrés :</span>

          <%# Badge ville préférée %>
          <% if @active_prefilters[:city] %>
            <span style="background:rgba(30,221,136,0.12); color:#1EDD88; border-radius:999px; padding:0.1rem 0.55rem; font-size:0.7rem;">
              📍 <%= @prefilter_params[:city] %>
            </span>
          <% end %>

          <%# Badge lieux favoris (un badge par venue) %>
          <% if @active_prefilters[:venues] %>
            <% @prefilter_params[:venues].each do |venue_name| %>
              <span style="background:rgba(30,221,136,0.12); color:#1EDD88; border-radius:999px; padding:0.1rem 0.55rem; font-size:0.7rem;">
                🏟️ <%= venue_name %>
              </span>
            <% end %>
          <% end %>

          <%# Badge niveau %>
          <% if @active_prefilters[:level] %>
            <span style="background:rgba(30,221,136,0.12); color:#1EDD88; border-radius:999px; padding:0.1rem 0.55rem; font-size:0.7rem;">
              ⭐ <%= @prefilter_params[:level] %>
            </span>
          <% end %>

          <%# Badges sports pratiqués (mode multisport uniquement) %>
          <% if @active_prefilters[:sports] %>
            <% @prefilter_params[:sports].each do |sport_name| %>
              <span style="background:rgba(30,221,136,0.12); color:#1EDD88; border-radius:999px; padding:0.1rem 0.55rem; font-size:0.7rem;">
                🏅 <%= sport_name %>
              </span>
            <% end %>
          <% end %>

          <%# Compteur : X matchs sur Y total %>
          <% if @filtered_matches_count && @total_matches_count %>
            <span style="color:rgba(255,255,255,0.25);">·</span>
            <span style="font-size:0.7rem; color:rgba(255,255,255,0.35);">
              <%= @filtered_matches_count %> match<%= @filtered_matches_count > 1 ? "s" : "" %> sur <%= @total_matches_count %>
            </span>
          <% end %>

          <span style="color:rgba(255,255,255,0.25);">·</span>
          <%= link_to "Voir tous les matchs", matches_path(no_prefilter: 1), style: "color:rgba(255,255,255,0.45); text-decoration:underline;" %>
          <span style="color:rgba(255,255,255,0.25);">·</span>
          <%= link_to "Modifier mes préférences", edit_profil_path(current_user.profil), style: "color:rgba(255,255,255,0.45); text-decoration:underline;" %>
        </p>
      <% elsif params[:no_prefilter].present? %>
        <%# L'user a cliqué "Voir tous les matchs" → proposer de réactiver les pré-filtres %>
        <p style="font-size:0.75rem; color:rgba(255,255,255,0.4); margin:0.1rem 0 0.75rem; display:flex; align-items:center; gap:0.4rem;">
          <i data-lucide="sparkles" style="width:12px; height:12px; color:rgba(255,255,255,0.3); flex-shrink:0;"></i>
          Tous les matchs affichés.
          &nbsp;·&nbsp;
          <%= link_to "Filtrer selon mon profil", matches_path, style: "color:rgba(255,255,255,0.45); text-decoration:underline;" %>
        </p>
      <% end %>
    <% end %>

    <%# ── Grille de matchs ────────────────────────────────────────────────── %>
    <% if @matches.empty? %>

      <div class="matches-empty-state">
        <i data-lucide="search-x" style="width:48px;height:48px;"></i>
        <p class="mt-3 mb-1">
          <%# Message adapté au contexte %>
          <% if params[:mine].present? && params[:status] == "completed" %>
            Tu n'as pas encore de matchs terminés.
          <% elsif params[:mine].present? %>
            Tu n'as aucun match en cours pour l'instant.
          <% elsif @active_prefilters&.any? %>
            <%# Préfiltres actifs mais aucun résultat → on guide l'utilisateur %>
            Aucun match ne correspond à tes préférences de profil.
          <% else %>
            Aucun match ne correspond à ta recherche.
          <% end %>
        </p>
        <%# Si les préfiltres sont responsables de l'absence de résultats, proposer de les désactiver %>
        <% if @active_prefilters&.any? %>
          <%= link_to "Voir tous les matchs", matches_path(no_prefilter: 1), class: "btn btn-outline-secondary mt-2 me-2" %>
        <% end %>
        <% if user_signed_in? %>
          <%= link_to "Créer un match", new_match_path, class: "btn btn-primary mt-2" %>
        <% end %>
      </div>

    <% else %>

      <%#
        Stimulus "load-more" :
          data-load-more-step-value="6" → 6 cartes révélées par clic sur le bouton
          Chaque carte (_match.html.erb) a data-load-more-target="card"
      %>
      <div data-controller="load-more" data-load-more-step-value="6">

        <%#
          id="matches" obligatoire → cible des broadcasts ActionCable.
          Quand un nouveau match est créé, Turbo l'insère ici automatiquement (prepend).
        %>
        <div id="matches" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
          <%= render @matches %>
        </div>

        <%# Bouton "Afficher plus" — géré par le Stimulus load-more controller %>
        <div class="text-center mt-5">
          <button
            class="matches-load-more-btn"
            data-load-more-target="button"
            data-action="click->load-more#more">
            Afficher plus de matchs
            <i data-lucide="chevron-down" style="width:16px;height:16px;margin-left:6px;"></i>
          </button>
        </div>

      </div>
    <% end %>

  </div>
</div>

<%# Auto-submit : date et niveau déclenchent le filtre sans clic sur "Filtrer" %>
<script>
  document.querySelectorAll(".filter-date-input, .filter-select, .filter-checkbox").forEach(function(el) {
    el.addEventListener("change", function() {
      document.getElementById("filter-submit-btn").click();
    });
  });
</script>
