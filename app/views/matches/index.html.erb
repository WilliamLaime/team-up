<%# ── Liste de tous les matchs disponibles ──────────────────────────────────── %>

<%# Abonnement ActionCable : mises à jour en temps réel sans rechargement %>
<%= turbo_stream_from "matches" %>

<div class="matches-index-page">
  <div class="container">

  <%# ── En-tête ──────────────────────────────────────────────────────────── %>
    <div class="matches-index-header">

      <%# Lien retour — utilise le composant partagé nav_button %>
      <%= render "shared/nav_button", url: root_path, label: "Retour", direction: "back", extra_class: "mb-2" %>

      <%# Titre et sous-titre différents selon le contexte (mes matchs vs liste générale) %>
      <% if params[:mine].present? %>
        <h1 class="matches-index-title">Mes matchs</h1>
        <div class="d-flex align-items-center justify-content-between">
          <p class="matches-index-subtitle mb-0">
            Tous les matchs auxquels tu participes ou que tu as créés.
          </p>
          <%= link_to "Créer un match", new_match_path, class: "btn btn-primary btn-sm px-3 btn-cta-primary" %>
        </div>

        <%# Onglets En cours / Terminés — uniquement dans le mode "mes matchs" %>
        <%# Lien sans status = En cours ; status=completed = Terminés %>
        <div class="matches-status-tabs">
          <%= link_to matches_path(mine: 1),
              class: "matches-status-tab #{'active' if params[:status].blank?}" do %>
            <i data-lucide="play-circle" style="width:14px;height:14px;"></i>
            En cours
          <% end %>
          <%= link_to matches_path(mine: 1, status: "completed"),
              class: "matches-status-tab #{'active' if params[:status] == 'completed'}" do %>
            <i data-lucide="check-circle" style="width:14px;height:14px;"></i>
            Terminés
          <% end %>
        </div>

      <% else %>
        <h1 class="matches-index-title">Trouver un match</h1>
        <div class="d-flex align-items-center justify-content-between">
          <p class="matches-index-subtitle mb-0">
            Rejoignez les matchs pas loin de chez vous.
          </p>
          <% if user_signed_in? %>
            <%= link_to "Créer un match", new_match_path, class: "btn btn-primary btn-sm px-3 btn-cta-primary" %>
          <% end %>
        </div>
      <% end %>

    </div>

    <%# ── Barre de filtres ────────────────────────────────────────────────── %>
    <%# Masquée en mode "mes matchs" : les onglets En cours/Terminés remplacent les filtres %>
    <%# GET → les paramètres apparaissent dans l'URL (partageables) %>
    <%= form_with url: matches_path, method: :get, local: true,
        style: params[:mine].present? ? "display:none;" : "" do |f| %>
      <div class="matches-filters-bar">

        <%# ── Filtres pill (gauche) ─────────────────────────────────────── %>
        <div class="matches-filters-left">

          <%# Date %>
          <div class="filter-pill-group">
            <i data-lucide="calendar" style="width:14px;height:14px;"></i>
            <%= f.date_field :date,
                value: params[:date],
                min: Date.today,
                class: "filter-date-input" %>
          </div>

          <%# Niveau — dropdown custom avec badges et checkboxes (multi-sélection) %>
          <%# position:relative en inline = ancre garantie pour le dropdown absolu %>
          <div class="level-filter-pill" data-controller="level-filter" style="position:relative">

            <%# Trigger : pill cliquable qui ouvre le dropdown %>
            <button type="button"
                    class="filter-pill-group level-filter-trigger"
                    data-action="click->level-filter#toggle">
              <i data-lucide="bar-chart-2" style="width:14px;height:14px;"></i>
              <span data-level-filter-target="label" style="color:rgba(255,255,255,0.9);">Niveau</span>
              <i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:2px;"></i>
            </button>

            <%#
              Panel dropdown — tous les styles critiques en inline pour éviter tout conflit CSS/cache.
              display:none = caché par défaut, Stimulus le passe à "flex" au clic.
            %>
            <div class="level-filter-dropdown"
                 data-level-filter-target="dropdown"
                 style="display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:300; flex-direction:column; width:fit-content; min-width:120px; background:#242624; border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:0.35rem; box-shadow:0 10px 30px rgba(0,0,0,0.6); gap:0.15rem">

              <% [["Débutant", "level-debutant"], ["Intermédiaire", "level-intermediaire"], ["Avancé", "level-avance"], ["Tout niveau", "level-tout"]].each do |level_name, level_css| %>
                <%# Inline styles sur le label = une seule ligne, checkbox + badge côte à côte, centrés %>
                <label style="display:flex; flex-direction:row; align-items:center; gap:0.6rem; padding:0.35rem 0.5rem; border-radius:6px; cursor:pointer; margin:0; width:100%;">
                  <input type="checkbox"
                         name="levels[]"
                         value="<%= level_name %>"
                         data-level-filter-target="checkbox"
                         data-action="change->level-filter#change"
                         style="width:15px; height:15px; margin:0; padding:0; flex-shrink:0; cursor:pointer; accent-color:#1EDD88;"
                         <%= "checked" if params[:levels]&.include?(level_name) %>>
                  <span class="match-badge-level <%= level_css %>" style="font-size:0.72rem; padding:0.2rem 0.6rem; line-height:1; margin:0;"><%= level_name %></span>
                </label>
              <% end %>

              <%# Bouton Appliquer — soumet le formulaire et ferme le dropdown %>
              <button type="button"
                      data-action="click->level-filter#apply"
                      style="margin-top:0.3rem; width:100%; padding:0.35rem 0; background:#1EDD88; color:#111; border:none; border-radius:6px; font-size:0.75rem; font-weight:700; cursor:pointer; transition:opacity 0.15s;"
                      onmouseover="this.style.opacity='0.85'"
                      onmouseout="this.style.opacity='1'">
                Appliquer
              </button>

            </div>
          </div>

          <%# Sport — dropdown custom multi-select (comme le filtre Niveau) %>
          <% if Sport.count > 0 %>
            <div class="sport-filter-pill" data-controller="sport-filter" style="position:relative">

              <%# Trigger : pill cliquable %>
              <button type="button"
                      class="filter-pill-group sport-filter-trigger"
                      data-action="click->sport-filter#toggle">
                <span data-sport-filter-target="label" style="color:rgba(255,255,255,0.9);">Sport</span>
                <i data-lucide="chevron-down" style="width:11px;height:11px;margin-left:2px;"></i>
              </button>

              <%# Panel dropdown %>
              <div class="sport-filter-dropdown"
                   data-sport-filter-target="dropdown"
                   style="display:none; position:absolute; top:calc(100% + 6px); left:0; z-index:300; flex-direction:column; width:fit-content; min-width:150px; background:#242624; border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:0.35rem; box-shadow:0 10px 30px rgba(0,0,0,0.6); gap:0.15rem">

                <%# Bouton Tout sélectionner — en haut, style pill vert outline %>
                <button type="button"
                        data-action="click->sport-filter#selectAll"
                        style="width:100%; padding:0.35rem 0.5rem; background:rgba(30,221,136,0.1); color:#1EDD88; border:1px solid rgba(30,221,136,0.35); border-radius:6px; font-size:0.75rem; font-weight:700; cursor:pointer; text-align:center; transition:background 0.15s, border-color 0.15s; margin-bottom:0.2rem;"
                        onmouseover="this.style.background='rgba(30,221,136,0.2)'; this.style.borderColor='rgba(30,221,136,0.6)'"
                        onmouseout="this.style.background='rgba(30,221,136,0.1)'; this.style.borderColor='rgba(30,221,136,0.35)'">
                  Tout sélectionner
                </button>

                <%# Séparateur %>
                <div style="height:1px; background:rgba(255,255,255,0.08); margin:0.2rem 0 0.25rem;"></div>

                <% Sport.order(:name).each do |sport| %>
                  <%# Pré-coché si ce sport est dans les filtres URL, ou si c'est le sport actif (et aucun filtre URL) %>
                  <% sport_checked = params[:sport_ids]&.include?(sport.id.to_s) ||
                                     (params[:sport_ids].blank? && current_sport&.id == sport.id) ||
                                     (params[:sport_ids].blank? && multisport_mode?) %>
                  <label style="display:flex; flex-direction:row; align-items:center; gap:0.6rem; padding:0.35rem 0.5rem; border-radius:6px; cursor:pointer; margin:0; width:100%;">
                    <input type="checkbox"
                           name="sport_ids[]"
                           value="<%= sport.id %>"
                           data-sport-filter-target="checkbox"
                           data-label="<%= sport_icon_text(sport) %> <%= sport.name %>"
                           data-label-html="<%= sport_icon_html_attr(sport, size: '1rem') %>"
                           data-action="change->sport-filter#change"
                           style="width:15px; height:15px; margin:0; padding:0; flex-shrink:0; cursor:pointer; accent-color:#1EDD88;"
                           <% if sport_checked %>checked<% end %>>
                    <%# Emoji + nom du sport %>
                    <span style="display:inline-flex; align-items:center; gap:0.35rem; font-size:0.8rem; font-weight:600; color:rgba(255,255,255,0.85);">
                      <%= sport_icon(sport, size: "1.05rem") %>
                      <%= sport.name %>
                    </span>
                  </label>
                <% end %>

                <%# Bouton Appliquer %>
                <button type="button"
                        data-action="click->sport-filter#apply"
                        style="margin-top:0.3rem; width:100%; padding:0.35rem 0; background:#1EDD88; color:#111; border:none; border-radius:6px; font-size:0.75rem; font-weight:700; cursor:pointer; transition:opacity 0.15s;"
                        onmouseover="this.style.opacity='0.85'"
                        onmouseout="this.style.opacity='1'">
                  Appliquer
                </button>

              </div>
            </div>
          <% end %>

          <%# Ville %>
          <div class="filter-pill-group">
            <i data-lucide="map-pin" style="width:14px;height:14px;"></i>
            <%= f.text_field :place,
                value: params[:place],
                placeholder: "Ville",
                class: "filter-text-input" %>
          </div>

          <%# Bouton "Effacer" visible seulement si un filtre est actif %>
          <% if params[:date].present? || params[:levels].present? || params[:place].present? || params[:query].present? || params[:sport_ids].present? %>
            <%= link_to matches_path, class: "filter-reset-btn" do %>
              <i data-lucide="x" style="width:13px;height:13px;"></i>
              Effacer
            <% end %>
          <% end %>
        </div>

        <%# ── Recherche + Créer (droite) ───────────────────────────────── %>
        <div class="matches-filters-right">

          <%# Barre de recherche texte libre %>
          <div class="filter-search-wrap">
            <i data-lucide="search" style="width:15px;height:15px;" class="filter-search-icon"></i>
            <%= f.text_field :query,
                value: params[:query],
                placeholder: "Rechercher un match...",
                class: "filter-search-input" %>
          </div>

          <%# Submit caché — déclenché par JS au changement des selects/date %>
          <%= f.submit "Filtrer", id: "filter-submit-btn", class: "d-none" %>
        </div>

      </div>
    <% end %>

    <%# ── Grille de matchs ────────────────────────────────────────────────── %>
    <% if @matches.empty? %>

      <div class="matches-empty-state">
        <i data-lucide="search-x" style="width:48px;height:48px;"></i>
        <p class="mt-3 mb-1">
          <%# Message adapté au contexte %>
          <% if params[:mine].present? && params[:status] == "completed" %>
            Tu n'as pas encore de matchs terminés.
          <% elsif params[:mine].present? %>
            Tu n'as aucun match en cours pour l'instant.
          <% else %>
            Aucun match ne correspond à ta recherche.
          <% end %>
        </p>
        <% if user_signed_in? %>
          <%= link_to "Créer un match", new_match_path, class: "btn btn-primary mt-2" %>
        <% end %>
      </div>

    <% else %>

      <%#
        Stimulus "load-more" :
          data-load-more-step-value="6" → 6 cartes révélées par clic sur le bouton
          Chaque carte (_match.html.erb) a data-load-more-target="card"
      %>
      <div data-controller="load-more" data-load-more-step-value="6">

        <%#
          id="matches" obligatoire → cible des broadcasts ActionCable.
          Quand un nouveau match est créé, Turbo l'insère ici automatiquement (prepend).
        %>
        <div id="matches" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
          <%= render @matches %>
        </div>

        <%# Bouton "Afficher plus" — géré par le Stimulus load-more controller %>
        <div class="text-center mt-5">
          <button
            class="matches-load-more-btn"
            data-load-more-target="button"
            data-action="click->load-more#more">
            Afficher plus de matchs
            <i data-lucide="chevron-down" style="width:16px;height:16px;margin-left:6px;"></i>
          </button>
        </div>

      </div>
    <% end %>

  </div>
</div>

<%# Auto-submit : date et niveau déclenchent le filtre sans clic sur "Filtrer" %>
<script>
  document.querySelectorAll(".filter-date-input, .filter-select").forEach(function(el) {
    el.addEventListener("change", function() {
      document.getElementById("filter-submit-btn").click();
    });
  });
</script>
