<%# =====================================================
    PAGE DÉTAIL D'UN MATCH — /matches/:id
    Structure :
      1. Banner pleine largeur (image + overlay)
      2. Colonne gauche : organisateur / map / joueurs
      3. Colonne droite : rejoindre / chat
      4. Modal "Rejoindre ce match ?"
      5. Modal chat complet (participants seulement)
    ===================================================== %>

<%# ── Données calculées une seule fois en haut ── %>
<%
  # Organisateur du match
  organizer_mu   = @match_users.find { |mu| mu.role == "organisateur" }
  organizer      = organizer_mu&.user

  # Joueurs approuvés (organisateur inclus)
  approved_users = @match_users.select { |mu| mu.approved? || mu.role == "organisateur" }

  # L'utilisateur connecté est-il participant accepté (ou organisateur) ?
  is_participant = @current_match_user &&
                   (@current_match_user.approved? || @current_match_user.role == "organisateur")

  # Classe CSS du badge niveau
  level_css = case @match.level
    when "Débutant"      then "level-debutant"
    when "Intermédiaire" then "level-intermediaire"
    when "Avancé"        then "level-avance"
    else                      "level-tout"
  end

  # Jours et mois en français
  fr_days   = %w[Dim Lun Mar Mer Jeu Ven Sam]
  fr_months = %w[jan fév mar avr mai jui juil aoû sep oct nov déc]
%>


<%# ══════════════════════════════════════════════════
    1. BANNER — fond d'image + overlay sombre
    ══════════════════════════════════════════════════ %>
<section class="match-banner">

  <%# Image de fond (placeholder terrain — pas encore de champ image en BDD) %>
  <div class="match-banner-bg"
       style="background-image: url('https://images.unsplash.com/photo-1529900748604-07564a03e7a6?w=1400&q=80')">
  </div>

  <%# Calque sombre semi-transparent pour lisibilité du texte %>
  <div class="match-banner-overlay"></div>

  <div class="container match-banner-container">

    <%# ── Ligne haute : Retour (gauche) + Partager (droite) ── %>
    <div class="match-banner-topbar">
      <%= render "shared/nav_button", url: matches_path, label: "Retour", direction: "back" %>
      <button class="match-banner-share-btn" title="Partager ce match">
        <i data-lucide="share-2" style="width:17px;height:17px;"></i>
      </button>
    </div>

    <%# ── Ligne basse : gauche = titre/desc/date, droite = boutons+prix en bas ── %>
    <div class="match-banner-content">

      <%# Gauche : badges / titre / description / date %>
      <div class="match-banner-left">

        <%# Badges %>
        <div class="d-flex gap-2 mb-3 flex-wrap">
          <% if @match.urgent? %>
            <span class="match-badge-urgent">🔥 Urgent</span>
          <% end %>
          <span class="match-badge-level <%= level_css %>"><%= @match.level %></span>
          <% if @match.full? %>
            <span class="match-badge-level" style="background:rgba(255,100,100,0.15);color:#ff6b6b;border:1px solid rgba(255,100,100,0.40);">Complet</span>
          <% end %>
        </div>

        <%# Titre %>
        <h1 class="match-banner-title"><%= @match.title %></h1>

        <%# Description %>
        <% if @match.description.present? %>
          <p class="match-banner-desc"><%= @match.description %></p>
        <% end %>

        <%# Date & heure %>
        <%
          d = @match.date
          t = @match.time
          date_str = d ? "#{fr_days[d.wday]} #{d.day} #{fr_months[d.month - 1]}" : "Date à définir"
          time_str = t ? t.strftime('%H:%M') : "—"
        %>
        <div class="match-banner-datetime">
          <div class="match-banner-datetime-icon">
            <i data-lucide="clock" style="width:16px;height:16px;"></i>
          </div>
          <div>
            <div class="match-banner-datetime-label">Date &amp; Heure</div>
            <div class="match-banner-datetime-value"><%= date_str %> · <%= time_str %></div>
          </div>
        </div>

      </div>

      <%# Droite : prix en haut, boutons organisateur en dessous, collés en bas %>
      <div class="match-banner-right">

        <%# Prix au-dessus des boutons %>
        <% if @match.price_per_player.present? && @match.price_per_player.to_f > 0 %>
          <div class="match-banner-price">
            <i data-lucide="euro" style="width:15px;height:15px;"></i>
            <span class="match-banner-price-amount"><%= number_to_currency(@match.price_per_player, unit: "€", format: "%n %u", precision: 0) %></span>
            <span class="match-banner-price-label">par joueur</span>
          </div>
        <% else %>
          <div class="match-banner-price">
            <i data-lucide="euro" style="width:15px;height:15px;"></i>
            <span class="match-banner-price-amount">Gratuit</span>
          </div>
        <% end %>

        <%# Boutons Modifier / Supprimer en dessous — uniquement pour l'organisateur %>
        <% if @current_match_user&.role == "organisateur" %>
          <%
            # Calcul des demandes en attente pour le badge dans la bannière
            banner_pending_count = @match_users.count(&:pending?)
          %>
          <div class="match-banner-organizer-actions">

            <%# Bouton "en attente" — ouvre la modale de gestion des demandes %>
            <button class="match-banner-action-btn match-banner-action-btn--pending"
                    data-bs-toggle="modal"
                    data-bs-target="#pendingModal"
                    title="Gérer les demandes en attente">
              <i data-lucide="clock" style="width:14px;height:14px;"></i>
              <% if banner_pending_count > 0 %>
                <%= banner_pending_count %> en attente
              <% else %>
                Demandes
              <% end %>
            </button>

            <%= link_to edit_match_path(@match), class: "match-banner-action-btn" do %>
              <i data-lucide="edit-2" style="width:14px;height:14px;"></i>
              Modifier
            <% end %>
            <%= button_to match_path(@match),
                method: :delete,
                class: "match-banner-action-btn match-banner-action-btn--danger",
                data: { turbo_confirm: "Supprimer définitivement ce match ?" } do %>
              <i data-lucide="trash-2" style="width:14px;height:14px;"></i>
              Supprimer
            <% end %>
          </div>
        <% end %>

      </div>

    </div>

  </div>
</section>


<%# ══════════════════════════════════════════════════
    2. CONTENU PRINCIPAL — 2 colonnes Bootstrap
    ══════════════════════════════════════════════════ %>
<div class="match-show-wrapper">
  <div class="container">
    <div class="row g-4">

      <%# ════════════════════════════════════════
          COLONNE GAUCHE (8 / 12)
          ════════════════════════════════════════ %>
      <div class="col-lg-8">


        <%# ──────────────────────────────────────
            BLOC ORGANISATEUR (Capitaine)
            ────────────────────────────────────── %>
        <div class="match-block">

          <h5 class="match-block-title">
            <i data-lucide="shield" style="width:15px;height:15px;"></i>
            Capitaine
          </h5>

          <div class="d-flex align-items-center justify-content-between gap-3">

            <%# Identité %>
            <div class="d-flex align-items-center gap-3">
              <%# Avatar de l'organisateur %>
              <% if organizer&.profil&.avatar&.attached? %>
                <%= image_tag organizer.profil.avatar,
                    class: "match-organizer-avatar", alt: "Avatar organisateur" %>
              <% else %>
                <img src="https://kitt.lewagon.com/placeholder/users/ssaunier"
                     class="match-organizer-avatar" alt="avatar">
              <% end %>

              <div>
                <%# Nom complet ou email si pas de profil %>
                <div class="match-organizer-name">
                  <% if organizer&.profil %>
                    <%= [organizer.profil.first_name, organizer.profil.last_name]
                          .compact.join(" ").presence || organizer.email %>
                  <% else %>
                    <%= organizer&.email || "Organisateur" %>
                  <% end %>
                </div>
                <div class="match-organizer-tag">Organisateur</div>
              </div>
            </div>

            <%# Bouton voir profil — redirige vers le profil de l'organisateur %>
            <%= link_to user_profil_path(organizer), class: "btn btn-sm match-profile-btn" do %>
              <i data-lucide="user" style="width:13px;height:13px;"></i>
              Voir profil
            <% end %>

          </div>
        </div>


        <%# ──────────────────────────────────────
            BLOC MAP — centré sur le lieu
            ────────────────────────────────────── %>
        <div class="match-block">

          <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="match-block-title mb-0">
              <i data-lucide="map-pin" style="width:15px;height:15px;"></i>
              Lieu du match
            </h5>
            <%# Nom de l'établissement en vert en haut à droite %>
            <% if @match.place.present? %>
              <span class="match-map-venue-name"><%= @match.place.split(' - ').first %></span>
            <% end %>
          </div>

          <%# Iframe Google Maps centré sur l'adresse %>
          <% if @match.place.present? %>
            <div class="match-map-wrapper">
              <iframe
                title="Carte Google Maps du lieu du match"
                src="https://maps.google.com/maps?q=<%= URI.encode_www_form_component(@match.place) %>&output=embed"
                width="100%"
                height="220"
                style="border:0;"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
          <% end %>

          <%# Rappel de l'adresse sous la carte %>
          <div class="match-map-address-row">
            <i data-lucide="map-pin" style="width:13px;height:13px;"></i>
            <span><%= @match.place || "Adresse non définie" %></span>
          </div>

        </div>


        <%# ──────────────────────────────────────
            BLOC JOUEURS INSCRITS
            Joueurs approuvés + joueurs en attente (avec badge horloge).
            Pour l'organisateur : bouton "Gérer les demandes" dans le titre
            qui ouvre la modale de validation (#pendingModal).
            ────────────────────────────────────── %>
        <%
          # Calcul des joueurs en attente une seule fois pour ce bloc
          pending_mus = @match_users.select(&:pending?)
        %>
        <div class="match-block">

          <%# Titre + bouton "Gérer les demandes" pour l'organisateur %>
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="match-block-title mb-0">
              <i data-lucide="users" style="width:15px;height:15px;"></i>
              Joueurs inscrits (<%= approved_users.count %>)
            </h5>

            <%# Bouton visible pour tous les organisateurs (peu importe le mode de validation)
                Montre le nombre de demandes en attente, ou "Demandes" si aucune %>
            <% if @current_match_user&.role == "organisateur" %>
              <button class="match-pending-trigger-btn"
                      data-bs-toggle="modal"
                      data-bs-target="#pendingModal"
                      title="Gérer les demandes en attente">
                <i data-lucide="clock" style="width:12px;height:12px;"></i>
                <% if pending_mus.any? %>
                  <%= pending_mus.count %> en attente
                <% else %>
                  Demandes
                <% end %>
              </button>
            <% end %>
          </div>

          <div class="match-players-grid">

            <%# ── Joueurs approuvés (organisateur inclus) ── %>
            <% approved_users.each do |mu| %>
              <div class="match-player-item">

                <%# Avatar du joueur %>
                <% if mu.user.profil&.avatar&.attached? %>
                  <%= image_tag mu.user.profil.avatar,
                      class: "match-player-avatar", alt: "Avatar joueur" %>
                <% else %>
                  <img src="https://kitt.lewagon.com/placeholder/users/ssaunier"
                       class="match-player-avatar" alt="joueur">
                <% end %>

                <%# Prénom + 1ère lettre du Nom suivi d'un point
                    Ex : "Marc L." — si pas de profil, on affiche la partie avant @ %>
                <%
                  first       = mu.user.profil&.first_name.presence || mu.user.email.split("@").first
                  last_letter = mu.user.profil&.last_name.presence&.first&.upcase
                  display     = last_letter ? "#{first} #{last_letter}." : first
                %>
                <span class="match-player-name"><%= display %></span>

              </div>
            <% end %>

            <%# ── Joueurs en attente — avatar avec badge horloge, non cliquable ── %>
            <% pending_mus.each do |mu| %>
              <div class="match-player-item match-player-item--pending">

                <%# Wrapper relatif pour positionner le badge horloge sur l'avatar %>
                <div class="match-player-avatar-wrapper">
                  <% if mu.user.profil&.avatar&.attached? %>
                    <%= image_tag mu.user.profil.avatar,
                        class: "match-player-avatar match-player-avatar--pending", alt: "Avatar joueur" %>
                  <% else %>
                    <img src="https://kitt.lewagon.com/placeholder/users/ssaunier"
                         class="match-player-avatar match-player-avatar--pending" alt="joueur">
                  <% end %>

                  <%# Badge horloge en bas à droite (visible pour tous) %>
                  <span class="match-player-pending-badge">
                    <i data-lucide="clock" style="width:9px;height:9px;"></i>
                  </span>
                </div>

                <%# Nom en jaune pour signaler l'état en attente %>
                <%
                  first       = mu.user.profil&.first_name.presence || mu.user.email.split("@").first
                  last_letter = mu.user.profil&.last_name.presence&.first&.upcase
                  display     = last_letter ? "#{first} #{last_letter}." : first
                %>
                <span class="match-player-name match-player-name--pending"><%= display %></span>

              </div>
            <% end %>

            <%# ── Slot vide cliquable si l'utilisateur connecté n'est pas encore inscrit ── %>
            <% if user_signed_in? && !@current_match_user && !@match.full? %>
              <div class="match-player-item match-player-empty"
                   data-bs-toggle="modal"
                   data-bs-target="#joinModal"
                   role="button"
                   title="Rejoindre le match">
                <div class="match-player-avatar-empty">
                  <i data-lucide="plus" style="width:20px;height:20px;"></i>
                </div>
                <span class="match-player-name">Rejoindre</span>
              </div>
            <% end %>

          </div>
        </div>


      </div>
      <%# ── Fin colonne gauche ── %>


      <%# ════════════════════════════════════════
          COLONNE DROITE (4 / 12) — sticky
          ════════════════════════════════════════ %>
      <div class="col-lg-4">

        <%# ──────────────────────────────────────
            BLOC REJOINDRE — places + bouton + validation
            ────────────────────────────────────── %>
        <div class="match-block match-block-join">

          <%# Phrase accrocheuse selon le nombre de places restantes %>
          <% if @match.player_left == 1 %>
            <p class="match-spots-hook match-spots-hook--urgent">Dernière chance !</p>
          <% elsif @match.player_left == 2 %>
            <p class="match-spots-hook match-spots-hook--warning">Presque complet !</p>
          <% elsif @match.player_left == 3 %>
            <p class="match-spots-hook match-spots-hook--notice">Dépêchez-vous !</p>
          <% end %>

          <%# Compteur de places
              Five = 10 joueurs max
              Places prises = 10 - player_left (places restantes à remplir) %>
          <% spots_taken = 10 - @match.player_left.to_i %>
          <div class="match-spots-display">
            <div class="match-spots-fraction">
              <%= spots_taken %>
              <span class="match-spots-sep">/</span>
              10
            </div>
            <div class="match-spots-label">
              <% if @match.full? %>
                <span style="color:#ff6b6b;">Complet</span>
              <% else %>
                <%= @match.player_left %>
                place<%= @match.player_left > 1 ? "s" : "" %>
                libre<%= @match.player_left > 1 ? "s" : "" %>
              <% end %>
            </div>
          </div>

          <%# Action selon le statut de l'utilisateur %>
          <% if user_signed_in? %>

            <% if @current_match_user %>

              <% if @current_match_user.role == "organisateur" %>
                <%# Organisateur %>
                <div class="match-join-status match-join-status--organizer">
                  <i data-lucide="shield" style="width:14px;height:14px;"></i>
                  Tu es l'organisateur
                </div>

              <% elsif @current_match_user.approved? %>
                <%# Inscrit et approuvé %>
                <div class="match-join-status match-join-status--approved">
                  <i data-lucide="check-circle" style="width:14px;height:14px;"></i>
                  Tu es inscrit
                </div>
                <%= button_to match_match_user_path(@match, @current_match_user),
                    method: :delete,
                    class: "btn btn-outline-danger btn-sm w-100 mt-2",
                    data: { turbo_confirm: "Quitter ce match ?" } do %>
                  Quitter le match
                <% end %>

              <% elsif @current_match_user.pending? %>
                <%# Demande en attente %>
                <div class="match-join-status match-join-status--pending">
                  <i data-lucide="clock" style="width:14px;height:14px;"></i>
                  Demande en attente
                </div>
                <%= button_to match_match_user_path(@match, @current_match_user),
                    method: :delete,
                    class: "btn btn-outline-secondary btn-sm w-100 mt-2" do %>
                  Annuler la demande
                <% end %>

              <% elsif @current_match_user.waiting? %>
                <%# File d'attente %>
                <div class="match-join-status match-join-status--waiting">
                  <i data-lucide="list" style="width:14px;height:14px;"></i>
                  En file d'attente
                </div>

              <% elsif @current_match_user.rejected? %>
                <%# Refusé %>
                <div class="match-join-status match-join-status--rejected">
                  <i data-lucide="x-circle" style="width:14px;height:14px;"></i>
                  Demande refusée
                </div>

              <% end %>

            <% else %>
              <%# Pas encore inscrit → bouton ouvre la modal de confirmation %>
              <% if @match.full? %>
                <button class="btn btn-warning w-100 match-join-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#joinModal">
                  <i data-lucide="list" style="width:15px;height:15px;"></i>
                  Rejoindre la file
                </button>
              <% else %>
                <button class="btn btn-primary w-100 match-join-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#joinModal">
                  Rejoindre le match
                </button>
              <% end %>
            <% end %>

          <% else %>
            <%# Non connecté → vers inscription %>
            <%= link_to new_user_registration_path, class: "btn btn-primary w-100 match-join-btn" do %>
              Rejoindre le match
            <% end %>
          <% end %>

          <%# Mode de validation choisi par l'organisateur %>
          <div class="match-validation-badge">
            <% if @match.manual_validation? %>
              <i data-lucide="user-check" style="width:13px;height:13px;"></i>
              Sélection manuelle par l'organisateur
            <% else %>
              <i data-lucide="zap" style="width:13px;height:13px;"></i>
              Inscription automatique
            <% end %>
          </div>

        </div>
        <%# ── Fin bloc rejoindre ── %>


        <%# ──────────────────────────────────────
            BLOC CHAT — prévisualisation inline
            ────────────────────────────────────── %>
        <div class="match-block match-chat-block">

          <%# En-tête %>
          <div class="match-chat-header">
            <div class="d-flex align-items-center gap-2">
              <i data-lucide="message-circle" style="width:16px;height:16px;color:#1EDD88;"></i>
              <strong style="color:#fff;">Match Chat</strong>
            </div>
            <% if is_participant %>
              <%# Pastille "Connecté" pour les participants %>
              <span class="match-chat-online-dot">Connecté</span>
            <% elsif @match.messages.count > 0 %>
              <%# Badge avec le nombre de messages pour les non-participants %>
              <span class="match-chat-new-badge"><%= @match.messages.count %> NOUVEAUX</span>
            <% end %>
          </div>

          <% if is_participant %>

            <%# Abonnement Turbo Stream pour les nouveaux messages en temps réel %>
            <%= turbo_stream_from "match_chat_#{@match.id}" %>

            <%# Aperçu des 2 derniers messages (pas de controller ici, il est sur le modal) %>
            <div>

              <%# Aperçu des 2 derniers messages %>
              <% preview_messages = @match.messages.includes(:user).order(:created_at).last(2) %>
              <% if preview_messages.any? %>
                <div class="match-chat-preview-list">
                  <% avatar_colors = %w[#2E7D32 #1565C0 #6A1B9A #AD1457 #E65100 #00695C] %>
                  <% preview_messages.each do |msg| %>
                    <div class="match-chat-preview-item">
                      <%# Bulle avec initiales colorées %>
                      <div class="match-chat-preview-avatar"
                           style="background-color:<%= avatar_colors[msg.user_id % avatar_colors.length] %>;">
                        <%= msg.user.display_name.split.map(&:first).join.upcase.first(2) %>
                      </div>
                      <div class="match-chat-preview-content">
                        <span class="match-chat-preview-name"><%= msg.user.display_name %></span>
                        <span class="match-chat-preview-text">
                          <%= truncate(msg.content, length: 55) %>
                        </span>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="match-chat-empty-hint">Aucun message. Brise la glace !</p>
              <% end %>

              <%# Séparateur et lien vers le chat complet (ouvre la modal) %>
              <div class="match-chat-divider"></div>
              <button class="match-chat-open-btn"
                      data-bs-toggle="modal"
                      data-bs-target="#chatModal">
                Accéder au chat complet →
              </button>

            </div>

          <% else %>
            <%# Chat flouté pour les non-participants — aperçu des derniers messages %>
            <div class="match-chat-blur-wrapper">

              <%# Contenu flouté : mêmes messages que pour les participants %>
              <div class="match-chat-blur-content">
                <% preview_messages = @match.messages.includes(:user).order(:created_at).last(2) %>
                <% avatar_colors = %w[#2E7D32 #1565C0 #6A1B9A #AD1457 #E65100 #00695C] %>
                <% if preview_messages.any? %>
                  <div class="match-chat-preview-list">
                    <% preview_messages.each do |msg| %>
                      <div class="match-chat-preview-item">
                        <div class="match-chat-preview-avatar"
                             style="background-color:<%= avatar_colors[msg.user_id % avatar_colors.length] %>;">
                          <%= msg.user.display_name.split.map(&:first).join.upcase.first(2) %>
                        </div>
                        <div class="match-chat-preview-content">
                          <span class="match-chat-preview-name"><%= msg.user.display_name %></span>
                          <span class="match-chat-preview-text"><%= truncate(msg.content, length: 55) %></span>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <%# Placeholder si aucun message encore %>
                  <div class="match-chat-preview-list">
                    <div class="match-chat-preview-item">
                      <div class="match-chat-preview-avatar" style="background-color:#2E7D32;">JD</div>
                      <div class="match-chat-preview-content">
                        <span class="match-chat-preview-name">Joueur</span>
                        <span class="match-chat-preview-text">Rejoins le match pour discuter !</span>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>

              <%# Overlay avec le bouton centré par-dessus le flou %>
              <div class="match-chat-blur-overlay">
                <% if user_signed_in? && !@current_match_user %>
                  <button class="match-chat-access-btn"
                          data-bs-toggle="modal"
                          data-bs-target="#joinModal">
                    Accéder au chat
                  </button>
                <% elsif !user_signed_in? %>
                  <%= link_to new_user_session_path, class: "match-chat-access-btn" do %>
                    Accéder au chat
                  <% end %>
                <% end %>
              </div>

            </div>
          <% end %>

        </div>
        <%# ── Fin bloc chat ── %>

      </div>
      <%# ── Fin colonne droite ── %>

    </div>
  </div>
</div>


<%# ══════════════════════════════════════════════════
    MODAL "REJOINDRE CE MATCH ?"
    Déclenché par 3 points d'entrée :
      1. Bouton "Rejoindre le match" (colonne droite)
      2. Slot vide dans la grille joueurs
      3. Bouton "Accéder au chat" (chat verrouillé)
    ══════════════════════════════════════════════════ %>
<% if user_signed_in? && !@current_match_user %>
  <div class="modal fade" id="joinModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content join-modal-content">

        <%# Croix de fermeture %>
        <button type="button"
                class="join-modal-close"
                data-bs-dismiss="modal"
                aria-label="Fermer">
          <i data-lucide="x" style="width:16px;height:16px;"></i>
        </button>

        <%# Icône et titre %>
        <div class="join-modal-icon">
          <i data-lucide="users" style="width:28px;height:28px;"></i>
        </div>
        <div class="join-modal-title">Rejoindre ce match ?</div>
        <p class="join-modal-subtitle"><%= @match.title %></p>

        <%# Formulaire caché — le bouton "Oui" le soumet via form= %>
        <%# Pas de champs visibles, juste l'action POST %>
        <%= form_with url: match_match_users_path(@match),
            method: :post,
            id: "join-form",
            class: "d-none" do |f| %>
        <% end %>

        <%# Boutons Oui / Non — Oui en premier à gauche, Non à droite %>
        <div class="d-flex gap-3 mt-4">
          <%# Oui → soumet le formulaire caché %>
          <button type="submit"
                  form="join-form"
                  class="btn btn-primary flex-fill join-modal-btn-yes">
            Oui
          </button>
          <%# Non → ferme la modal sans soumettre %>
          <button type="button"
                  class="btn btn-outline-secondary flex-fill join-modal-btn-no"
                  data-bs-dismiss="modal">
            Non
          </button>
        </div>

      </div>
    </div>
  </div>
<% end %>


<%# ══════════════════════════════════════════════════
    MODAL CHAT COMPLET — participants et organisateur
    ══════════════════════════════════════════════════ %>
<% if is_participant %>
  <%# Le data-controller est ICI sur le modal pour que Stimulus ait accès
      aux targets messages/input/typing ET que onModalOpen se déclenche
      quand Bootstrap ouvre le modal (shown.bs.modal) %>
  <div class="modal fade"
       id="chatModal"
       tabindex="-1"
       data-controller="chat"
       data-chat-current-user-id-value="<%= current_user.id %>"
       data-chat-match-id-value="<%= @match.id %>"
       data-action="shown.bs.modal->chat#onModalOpen">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content chat-modal-content">

        <%# En-tête du chat %>
        <div class="modal-header chat-header">
          <div class="d-flex align-items-center gap-2">
            <span class="chat-header-icon">💬</span>
            <div>
              <div class="chat-header-title">Chat du match</div>
              <div class="chat-header-subtitle">
                <%= approved_users.count %> participant<%= approved_users.count > 1 ? "s" : "" %>
              </div>
            </div>
          </div>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>

        <%# Zone scrollable des messages %>
        <div class="modal-body p-0">
          <div class="chat-messages"
               id="chat-messages"
               data-chat-target="messages">
            <% if @match.messages.any? %>
              <%= render @match.messages.includes(:user).order(:created_at) %>
            <% else %>
              <%# id="chat-empty" ciblé par Stimulus pour suppression au 1er message %>
              <div class="chat-empty text-center text-muted py-5" id="chat-empty">
                <div class="mb-2" style="font-size: 2rem;">💬</div>
                <p>Personne n'a encore écrit. Brise la glace !</p>
              </div>
            <% end %>
          </div>
        </div>

        <%# Indicateur "X est en train d'écrire..." %>
        <div class="chat-typing-indicator"
             id="chat-typing"
             data-chat-target="typing"
             style="display: none;">
          <span class="chat-typing-dots">
            <span></span><span></span><span></span>
          </span>
          <span class="chat-typing-name" data-chat-target="typingName"></span>
          est en train d'écrire...
        </div>

        <%# Formulaire d'envoi de message %>
        <div class="modal-footer p-2 border-top" id="chat-form">
          <%= render "messages/form", match: @match, message: Message.new %>
        </div>

      </div>
    </div>
  </div>
<% end %>


<%# ══════════════════════════════════════════════════
    MODAL "DEMANDES EN ATTENTE" — uniquement pour l'organisateur
    Affiche la liste des joueurs qui souhaitent rejoindre le match.
    Permet de voir leur profil, leur niveau / rôle, et d'accepter ou refuser.
    ══════════════════════════════════════════════════ %>
<% if @current_match_user&.role == "organisateur" %>
  <% pending_modal_users = @match_users.select(&:pending?) %>

  <div class="modal fade" id="pendingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content pending-modal-content">

        <%# Croix de fermeture %>
        <button type="button"
                class="pending-modal-close"
                data-bs-dismiss="modal"
                aria-label="Fermer">
          <i data-lucide="x" style="width:16px;height:16px;"></i>
        </button>

        <%# En-tête — icône + titre + nombre de demandes %>
        <div class="pending-modal-header">
          <div class="pending-modal-icon">
            <i data-lucide="users" style="width:22px;height:22px;"></i>
          </div>
          <div>
            <div class="pending-modal-title">Demandes en attente</div>
            <div class="pending-modal-subtitle">
              <%= pending_modal_users.count %> joueur<%= pending_modal_users.count > 1 ? "s" : "" %> souhaite<%= pending_modal_users.count > 1 ? "nt" : "" %> rejoindre
            </div>
          </div>
        </div>

        <%# Séparateur %>
        <div class="pending-modal-divider"></div>

        <%# Liste des joueurs en attente %>
        <div class="pending-modal-list">

          <% if pending_modal_users.any? %>
            <% pending_modal_users.each do |mu| %>

              <%# Ligne d'un joueur en attente %>
              <div class="pending-modal-row">

                <%# Avatar cliquable → ouvre le profil dans un nouvel onglet %>
                <%= link_to user_profil_path(mu.user),
                    class: "pending-modal-avatar-link",
                    target: "_blank",
                    title: "Voir le profil" do %>
                  <% if mu.user.profil&.avatar&.attached? %>
                    <%= image_tag mu.user.profil.avatar,
                        class: "pending-modal-avatar", alt: "Avatar joueur" %>
                  <% else %>
                    <img src="https://kitt.lewagon.com/placeholder/users/ssaunier"
                         class="pending-modal-avatar" alt="joueur">
                  <% end %>
                <% end %>

                <%# Infos du joueur : nom + niveau + rôle + lien profil %>
                <div class="pending-modal-info">
                  <%
                    first       = mu.user.profil&.first_name.presence || mu.user.email.split("@").first
                    last_name   = mu.user.profil&.last_name.presence
                    full_name   = last_name ? "#{first} #{last_name}" : first
                    level       = mu.user.profil&.level.presence  || "Niveau non renseigné"
                    role_pref   = mu.user.profil&.role.presence   || "Rôle non renseigné"
                  %>
                  <div class="pending-modal-name"><%= full_name %></div>
                  <div class="pending-modal-tags">
                    <span class="pending-modal-tag pending-modal-tag--level"><%= level %></span>
                    <span class="pending-modal-tag pending-modal-tag--role"><%= role_pref %></span>
                  </div>
                  <%# Lien vers le profil complet (ouvre dans un nouvel onglet) %>
                  <%= link_to user_profil_path(mu.user),
                      class: "pending-modal-profile-link",
                      target: "_blank" do %>
                    <i data-lucide="external-link" style="width:11px;height:11px;"></i>
                    Voir le profil complet
                  <% end %>
                </div>

                <%# Boutons accepter (vert) / refuser (rouge) %>
                <div class="pending-modal-actions">
                  <%= button_to approve_match_match_user_path(@match, mu),
                      method: :patch,
                      class: "pending-modal-btn pending-modal-btn--approve",
                      title: "Accepter" do %>
                    <i data-lucide="check" style="width:14px;height:14px;"></i>
                  <% end %>
                  <%= button_to reject_match_match_user_path(@match, mu),
                      method: :patch,
                      class: "pending-modal-btn pending-modal-btn--reject",
                      title: "Refuser" do %>
                    <i data-lucide="x" style="width:14px;height:14px;"></i>
                  <% end %>
                </div>

              </div>

            <% end %>
          <% else %>
            <p class="pending-modal-empty">Aucune demande en attente pour le moment.</p>
          <% end %>

        </div>

      </div>
    </div>
  </div>

  <%# Ouvre automatiquement la modale dès que l'organisateur arrive sur la page
      — uniquement s'il y a au moins une demande en attente %>
  <% if pending_modal_users.any? %>
    <script>
      // "turbo:load" se déclenche à chaque navigation Turbo (remplace DOMContentLoaded)
      document.addEventListener("turbo:load", function openPendingModal() {
        var modalEl = document.getElementById("pendingModal");
        if (modalEl) {
          // getOrCreateInstance réutilise l'instance Bootstrap existante
          // → évite que le backdrop reste bloqué quand on ferme avec la croix
          var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
          modal.show();
        }
        // On retire l'écouteur pour ne l'exécuter qu'une seule fois par visite
        document.removeEventListener("turbo:load", openPendingModal);
      });
    </script>
  <% end %>

<% end %>
