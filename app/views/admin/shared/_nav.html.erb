<%# ── Navigation par onglets de l'espace Admin ──────────────────────────── %>
<%# Partial partagé entre toutes les pages admin %>
<%# Paramètre attendu : active_tab — :dashboard, :formulaires ou :security %>

<%# L'abonnement turbo_stream_from "admin_contact_messages" est dans _navbar.html.erb
    (conditionnel if current_user&.admin?) pour éviter les doublons qui neutralisent
    les subscriptions côté client Turbo. Un seul abonné par canal. %>

<%# Onglets centrés, style cohérent avec le reste du site (auth-tab) %>
<div class="d-flex justify-content-center mb-5">
  <div class="admin-nav-tabs">

    <%# ── Onglet Dashboard ── %>
    <%= link_to admin_root_path,
                class: "admin-nav-tab #{active_tab == :dashboard ? "admin-nav-tab--active" : ""}" do %>
      <i data-lucide="layout-dashboard" style="width:15px; height:15px;"></i>
      Dashboard
    <% end %>

    <%# ── Onglet Formulaires (messages de contact) ── %>
    <%= link_to admin_contact_messages_path,
                class: "admin-nav-tab #{active_tab == :formulaires ? "admin-nav-tab--active" : ""}" do %>
      <i data-lucide="mail" style="width:15px; height:15px;"></i>
      Formulaires
      <%# Wrapper fixe avec ID ciblé par broadcast_update_to — son contenu est mis à jour en temps réel %>
      <span id="admin-nav-unread-badge">
        <%= render "admin/shared/admin_unread_badge" %>
      </span>
    <% end %>

    <%# ── Onglet Sécurité (logs de connexions et d'actions suspectes) ── %>
    <%= link_to admin_security_logs_path,
                class: "admin-nav-tab #{active_tab == :security ? "admin-nav-tab--active" : ""}" do %>
      <i data-lucide="shield-alert" style="width:15px; height:15px;"></i>
      Sécurité
    <% end %>

  </div>
</div>
