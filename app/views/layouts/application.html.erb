<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Teams-up" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Teams-up">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag "favicon.png" %>

    <%# Lucide Icons — bibliothèque d'icônes SVG légères %>
    <%# Doc : https://lucide.dev/icons/ — utilisation : <i data-lucide="nom-icone"></i> %>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  </head>

  <%# data-controller="scroll-to-error" : sur chaque chargement de page, fait défiler
      automatiquement jusqu'à la première erreur de formulaire si elle existe %>
  <body data-controller="scroll-to-error">
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>

    <%# main prend tout l'espace disponible → footer toujours en bas (flex: 1) %>
    <main>
      <%= yield %>
    </main>

    <%# Pied de page commun à toutes les pages %>
    <%= render "shared/footer" %>

    <%# Bouton + panneau chat sticky — visible sur toutes les pages pour les connectés %>
    <%# Doit être EN DEHORS du <main> pour que position:fixed fonctionne correctement %>
    <%= render "shared/sticky_chat" %>

    <%# Modal post-match : s'affiche à la 1ère connexion après un match terminé %>
    <%# @pending_review_matches est chargé par ApplicationController#load_review_modal_data %>
    <% if user_signed_in? && @pending_review_matches.present? %>
      <%= render "shared/review_modal" %>
    <% end %>

    <%# Modals provenant des vues (ex: modal avis profil) %>
    <%# Rendus ici — en dehors de tout stacking context — pour que Bootstrap puisse
        gérer correctement z-index et backdrop sans conflit de positionnement CSS %>
    <%= yield :modals %>

    <%# Initialise toutes les icônes Lucide présentes dans la page %>
    <%# Appelé en bas de body pour que le DOM soit chargé %>
    <script>
      // Initialisation au premier chargement de la page
      lucide.createIcons();

      // Ré-initialisation après chaque mise à jour Turbo (navigation, turbo_frame, turbo_stream)
      // Sans ça, les icônes dans les frames remplacées par Turbo disparaissent
      document.addEventListener("turbo:render", () => lucide.createIcons());
      document.addEventListener("turbo:frame-render", () => lucide.createIcons());

      // Turbo Stream (ex: nouvelle notification via ActionCable) — l'événement "before-stream-render"
      // se déclenche AVANT que le DOM soit modifié, donc on utilise setTimeout pour attendre
      // que le remplacement du fragment soit terminé avant de ré-initialiser les icônes Lucide
      document.addEventListener("turbo:before-stream-render", () => {
        setTimeout(() => lucide.createIcons(), 0);
      });
    </script>
  </body>
</html>
