<!DOCTYPE html>
<html>
  <head>
    <%# Encodage déclaré explicitement — bonne pratique HTML5 et prérequis SEO %>
    <meta charset="utf-8">
    <%# display_meta_tags génère automatiquement :
        - <title>Page | Teams-up</title>
        - <meta name="description" content="...">
        - <meta property="og:title" content="..."> (partage réseaux sociaux)
        - <meta property="og:description" content="...">
        - <meta property="og:url" content="...">
        - <meta name="twitter:card" content="...">
        Les valeurs viennent du before_action set_default_meta_tags (ApplicationController)
        et peuvent être surchargées dans chaque controller avec set_meta_tags(). %>
    <%= display_meta_tags site: "Teams-up" %>

    <%# ── Vérification Google Search Console ──────────────────────────────────
        Deux codes : un par propriété Search Console (teams-up-sport.fr et .com).
        Stockés dans les variables d'environnement Heroku.
        GOOGLE_SITE_VERIFICATION     → propriété www.teams-up-sport.fr
        GOOGLE_SITE_VERIFICATION_COM → propriété www.teams-up-sport.com (redirige vers .fr) %>
    <% if ENV["GOOGLE_SITE_VERIFICATION"].present? %>
      <meta name="google-site-verification" content="<%= ENV["GOOGLE_SITE_VERIFICATION"] %>">
    <% end %>
    <% if ENV["GOOGLE_SITE_VERIFICATION_COM"].present? %>
      <meta name="google-site-verification" content="<%= ENV["GOOGLE_SITE_VERIFICATION_COM"] %>">
    <% end %>

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Teams-up">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# ── PWA : manifeste + couleur de thème ──────────────────────────────── %>
    <%# Le manifeste dit au navigateur que l'app est installable (icône, nom, couleurs) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%# theme-color : colore la barre de statut/navigateur sur mobile %>
    <meta name="theme-color" content="#111111">

    <%# ── Enregistrement du Service Worker ─────────────────────────────────
        Le service worker permet : cache offline, fond de préchargement.
        On l'enregistre uniquement si le navigateur supporte l'API. %>
    <%= javascript_tag nonce: true do %>
      if ("serviceWorker" in navigator) {
        // Enregistre le SW avec la portée "/" = toutes les pages du site
        navigator.serviceWorker.register("<%= pwa_service_worker_path %>", { scope: "/" });
      }
    <% end %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag "favicon.png" %>

    <%# Lucide Icons — bibliothèque d'icônes SVG légères %>
    <%# Doc : https://lucide.dev/icons/ — utilisation : <i data-lucide="nom-icone"></i> %>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>

    <%# Bebas Neue — police utilisée pour les chiffres de la player card %>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">
  </head>

  <%# data-controller="scroll-to-error" : sur chaque chargement de page, fait défiler
      automatiquement jusqu'à la première erreur de formulaire si elle existe %>
  <body data-controller="scroll-to-error">
    <%= render "shared/navbar" %>
    <%# Bande sous la navbar : sport switcher (connecté) ou boutons auth (non connecté) — mobile uniquement %>
    <%= render "shared/mobile_sub_navbar" %>
    <%= render "shared/flashes" %>

    <%# ── Canal de notifications personnelles ──────────────────────────────────
        Chaque user connecté écoute son propre canal Turbo Stream.
        Toutes les notifications en temps réel (décision, annulation, joueur quitte,
        invitation reçue) sont broadcastées sur ce canal depuis les controllers.
        Le conteneur vide reçoit les modals injectées dynamiquement. %>
    <% if user_signed_in? %>
      <%= turbo_stream_from "user_#{current_user.id}_notifications" %>
      <div id="global_notification_container"></div>
    <% end %>

    <%# ── Onboarding post-inscription ─────────────────────────────────────────
        La modale Bootstrap est hors du <main> (position:fixed géré par Bootstrap).
        Le banner de rappel est ici, juste avant le contenu, pour apparaître sous la navbar. %>
    <% if @show_onboarding_modal %>
      <%= render "shared/onboarding_modal" %>
    <% elsif @show_profile_reminder_banner %>
      <%= render "shared/profile_reminder_banner" %>
    <% end %>

    <%# main prend tout l'espace disponible → footer toujours en bas (flex: 1) %>
    <main>
      <%= yield %>
    </main>

    <%# Pied de page commun à toutes les pages %>
    <%= render "shared/footer" %>

    <%# Bouton + panneau chat sticky — visible sur toutes les pages pour les connectés %>
    <%# Doit être EN DEHORS du <main> pour que position:fixed fonctionne correctement %>
    <%= render "shared/sticky_chat" %>

    <%# Modal post-match : s'affiche à la 1ère connexion après un match terminé %>
    <%# @pending_review_matches est chargé par ApplicationController#load_review_modal_data %>
    <% if user_signed_in? && @pending_review_matches.present? %>
      <%= render "shared/review_modal", pending_review_matches: @pending_review_matches %>
      <%# Script séparé : ouvre la modal automatiquement après connexion %>
      <script>
        document.addEventListener("DOMContentLoaded", function() {
          var el = document.getElementById("review-modal");
          if (el) { new bootstrap.Modal(el).show(); }
        });
      </script>
    <% end %>

    <%# Modals provenant des vues (ex: modal avis profil) %>
    <%# Rendus ici — en dehors de tout stacking context — pour que Bootstrap puisse
        gérer correctement z-index et backdrop sans conflit de positionnement CSS %>
    <%= yield :modals %>
    <%# Modale grille des niveaux — disponible sur toutes les pages via le bouton "?" %>
    <%= render "shared/level_grid_modal" %>

    <%# Initialise toutes les icônes Lucide présentes dans la page %>
    <%# Appelé en bas de body pour que le DOM soit chargé %>
    <script>
      // Initialisation au premier chargement de la page
      lucide.createIcons();

      // Ré-initialisation après chaque mise à jour Turbo (navigation, turbo_frame, turbo_stream)
      // Sans ça, les icônes dans les frames remplacées par Turbo disparaissent
      document.addEventListener("turbo:render", () => lucide.createIcons());
      document.addEventListener("turbo:frame-render", () => lucide.createIcons());

      // Turbo Stream (ex: nouvelle notification via ActionCable) — on intercepte la fonction
      // de rendu pour appeler lucide.createIcons() et ouvrir les modals APRÈS que le DOM a été modifié.
      // C'est plus fiable que les <script> inline qui ne s'exécutent pas toujours avec Turbo Stream.
      document.addEventListener("turbo:before-stream-render", (event) => {
        const originalRender = event.detail.render;
        event.detail.render = function(streamElement) {
          originalRender(streamElement); // mise à jour du DOM

          lucide.createIcons(); // ré-initialise les icônes APRÈS le DOM

          // Ouvre automatiquement toute modal marquée data-auto-open="true"
          // (injectée via Turbo Stream depuis les partials de notification)
          document.querySelectorAll("[data-auto-open='true']").forEach(function(el) {
            // Retire l'attribut pour éviter de ré-ouvrir si le DOM est re-rendu
            el.removeAttribute("data-auto-open");

            if (typeof bootstrap !== "undefined") {
              bootstrap.Modal.getOrCreateInstance(el).show();

              // Si une URL de redirection est définie, on redirige à la fermeture
              var redirectUrl = el.getAttribute("data-redirect-url");
              if (redirectUrl) {
                el.addEventListener("hidden.bs.modal", function() {
                  window.location.href = redirectUrl;
                }, { once: true });
              }
            }
          });
        };
      });
    </script>
  </body>
</html>
