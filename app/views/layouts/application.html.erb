<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Team Up" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Team Up">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= favicon_link_tag "favicon.png" %>

    <%# Lucide Icons — bibliothèque d'icônes SVG légères %>
    <%# Doc : https://lucide.dev/icons/ — utilisation : <i data-lucide="nom-icone"></i> %>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  </head>

  <body>
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>

    <%# main prend tout l'espace disponible → footer toujours en bas (flex: 1) %>
    <main>
      <%= yield %>
    </main>

    <%# Pied de page commun à toutes les pages %>
    <%= render "shared/footer" %>

    <%# Initialise toutes les icônes Lucide présentes dans la page %>
    <%# Appelé en bas de body pour que le DOM soit chargé %>
    <script>
      // Fonction utilitaire : (ré)initialise toutes les icônes Lucide dans la page
      function initLucide() { lucide.createIcons(); }

      // 1. Chargement initial de la page
      initLucide();

      // 2. Après une navigation Turbo (changement de page)
      document.addEventListener("turbo:render", initLucide);

      // 3. Après la mise à jour d'un turbo_frame (ex: cloche de notifications)
      //    C'est cet événement qui se déclenche quand un turbo_stream remplace un frame
      document.addEventListener("turbo:frame-render", initLucide);
    </script>
  </body>
</html>
