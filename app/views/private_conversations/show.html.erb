<%# ── Chat privé — chargé dans la colonne droite de la modale ────────────────
    Variables attendues :
      - @conversation : objet PrivateConversation
      - @messages     : liste des messages (ordonnés par created_at)
      - @message      : Message.new (pour le formulaire d'envoi)
    Structure identique à conversations/show.html.erb mais pour le chat privé
%>

<%= turbo_frame_tag "sticky-chat-frame" do %>

  <div data-controller="chat"
       data-chat-current-user-id-value="<%= current_user.id %>"
       data-chat-conversation-id-value="<%= @conversation.id %>"
       data-chat-mark-read-url-value="<%= mark_read_private_conversation_path(@conversation) %>"
       class="sticky-chat-inner">

    <%# Abonnement Turbo Stream — reçoit les nouveaux messages en temps réel %>
    <%= turbo_stream_from "private_chat_#{@conversation.id}" %>

    <%# En-tête du chat %>
    <% other = @conversation.other_user(current_user) %>
    <div class="sticky-chat-chat-header">
      <%# Avatar + nom cliquables : ferme la modale puis navigue vers le profil
          data-action cible sticky-chat (controller parent) via goToProfile
          data-url    : URL du profil transmise au controller JS %>
      <span class="sticky-chat-profile-link"
            data-action="click->sticky-chat#goToProfile"
            data-url="<%= user_profil_path(other) %>">
        <%= user_avatar_tag other,
            css_class: "chat-avatar-img",
            style: "width:20px;height:20px;min-width:20px;border-radius:50%;object-fit:cover;overflow:hidden;flex-shrink:0;" %>
        <%= truncate(other.display_name || other.email, length: 25) %>
      </span>
    </div>

    <%# Zone scrollable des messages
        id="sticky-chat-messages" : cible du broadcast Turbo Stream (message.rb) %>
    <div class="sticky-chat-messages-zone"
         id="sticky-chat-messages"
         data-chat-target="messages">

      <% if @messages.any? %>
        <%= render @messages %>
      <% else %>
        <%# Message vide initial — supprimé par chat_controller quand on envoie le 1er message %>
        <div class="chat-empty text-center py-3" id="chat-empty">
          <div style="font-size: 1.5rem;">👋</div>
          <p class="small">Dis bonjour !</p>
        </div>
      <% end %>

    </div>

    <%# Indicateur "X est en train d'écrire..." — identique au chat de match
        Affiché/masqué par showTypingIndicator() dans chat_controller.js %>
    <div class="chat-typing-indicator"
         id="chat-typing"
         data-chat-target="typing"
         style="display: none;">
      <span class="chat-typing-dots">
        <span></span><span></span><span></span>
      </span>
      <span class="chat-typing-name" data-chat-target="typingName"></span>
      est en train d'écrire...
    </div>

    <%# Formulaire d'envoi
        id="sticky-chat-form" : réinitialisé par MessagesController après envoi %>
    <div class="sticky-chat-form-zone" id="sticky-chat-form">
      <%= render "messages/form",
          match: nil,
          message: @message,
          private_conversation: @conversation %>
    </div>

  </div>

<% end %>
