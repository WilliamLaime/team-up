<%# Formulaire d'envoi de message — réinitialisé après chaque envoi via Turbo Stream
    Accepte un match, une private_conversation ou une équipe
    Variables attendues :
      - message              : objet Message.new
      - match                : objet Match (ou nil)
      - private_conversation : objet PrivateConversation (ou nil)
      - team                 : objet Team (ou nil) %>

<%# Détermine l'URL de soumission selon le type de conversation %>
<% if local_assigns[:private_conversation] && private_conversation.present?
     # Message privé → POST /private_conversations/:id/messages
     form_model = [private_conversation, message]
   elsif local_assigns[:team] && team.present?
     # Message d'équipe → POST /teams/:team_id/messages
     form_model = [team, message]
   else
     # Message de match → POST /matches/:match_id/messages
     form_model = [match, message]
   end %>

<%= form_with model: form_model, class: "chat-form d-flex gap-2 align-items-center w-100", data: { chat_target: "form" } do |f| %>
  <%# RGAA 11.1 — label explicite masqué visuellement pour les lecteurs d'écran %>
  <%= f.label :content, "Message", class: "visually-hidden" %>

  <%# Champ texte — flex-grow-1 pour prendre toute la largeur disponible %>
  <%= f.text_field :content,
      placeholder: "Écrire un message...",
      class: "form-control flex-grow-1",
      autocomplete: "off",
      data: {
        chat_target: "input",
        # keydown : envoyer avec Entrée
        # input   : signaler aux autres qu'on est en train d'écrire
        action: "keydown->chat#handleKeydown input->chat#onTyping"
      } %>

  <%# RGAA 11.9 — aria-label pour nommer le bouton (icône seule sans texte visible) %>
  <%# RGAA 4.8  — aria-hidden="true" sur le SVG décoratif dans le bouton %>
  <%= f.button type: "submit",
      class: "btn btn-success chat-send-btn",
      aria: { label: "Envoyer le message" },
      data: { chat_target: "submit" } do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
    </svg>
  <% end %>
<% end %>
