<%# =====================================================
   NAVBAR — Thème sombre avec accents verts
   Structure simplifiée : plus de collapse/burger
   - Logo à gauche
   - Liens centre → d-none d-lg-flex (desktop uniquement)
   - Actions droite → toujours visibles (cloche + avatar)
   ===================================================== %>

<%# Abonnement Turbo Stream pour les admins — met à jour le voyant vert en temps réel
    sur toutes les pages (pas seulement les pages admin) %>
<% if current_user&.admin? %>
  <%= turbo_stream_from "admin_contact_messages" %>
<% end %>

<nav class="navbar navbar-expand-lg navbar-dark-custom">
  <div class="container">

    <%# ── Logo (toujours visible) ── %>
    <%= link_to root_path, class: "navbar-brand" do %>
      <%= image_tag "elements_graphiques/logo_vert.svg", alt: "Teams-Up", class: "navbar-logo" %>
    <% end %>

    <%# ── Liens du centre (desktop uniquement, cachés sur mobile) ── %>
    <ul class="navbar-nav d-none d-lg-flex flex-row mx-auto gap-1 align-items-center">
      <li class="nav-item">
        <%# "active" si on est sur /matches SANS le filtre ?mine=true
            aria-current="page" : indique la page active aux lecteurs d'écran (RGAA 12.4) %>
        <% matches_active = current_page?(matches_path) && params[:mine].blank? %>
        <%= link_to matches_path,
            class: "nav-link #{matches_active ? 'active' : ''}",
            "aria-current": (matches_active ? "page" : nil) do %>
          Trouver un match
        <% end %>
      </li>
      <% if user_signed_in? %>
        <li class="nav-item">
          <% teams_active = request.path.start_with?('/teams') %>
          <%= link_to teams_path,
              class: "nav-link #{teams_active ? 'active' : ''}",
              "aria-current": (teams_active ? "page" : nil) do %>
            Mes équipes
          <% end %>
        </li>
      <% end %>
      <li class="nav-item">
        <% about_active = current_page?(about_path) %>
        <%= link_to about_path,
            class: "nav-link #{about_active ? 'active' : ''}",
            "aria-current": (about_active ? "page" : nil) do %>
          Qui sommes-nous ?
        <% end %>
      </li>


    </ul>

    <%# ══════════════════════════════════════════════════════
        ACTIONS DROITE — toujours visibles (mobile + desktop)
        On affiche/cache certains éléments avec d-none/d-lg-block
        ══════════════════════════════════════════════════════ %>
    <div class="d-flex align-items-center gap-2 gap-lg-3 ms-auto ms-lg-0">

      <% if user_signed_in? %>

        <%# ── Bouton "Installer l'app" PWA ──────────────────────────────────
            Caché par défaut, affiché automatiquement si le navigateur détecte
            que l'app est installable (événement beforeinstallprompt).
            Style : bouton vert (couleur principale de la charte) pour le rendre visible. %>
        <%# ── Bouton "Installer l'app" PWA + modale personnalisée ──────────────
            data-controller="pwa-install" : active le controller Stimulus
            Le bouton ouvre notre modale custom (au lieu du prompt Chrome directement).
            La modale custom s'affiche, et quand l'user clique "Installer" dedans,
            on déclenche le prompt natif Chrome. %>
        <%# ── Bouton "Installer l'app" PWA — toujours visible pour les connectés ──
            Au clic : si déjà installé sur cet appareil → modale "déjà installé"
                      sinon → modale d'installation normale %>
        <div data-controller="pwa-install">

          <%# Bouton toujours visible (mobile + desktop) %>
          <%# Sur mobile : icône seule (pas de texte) pour économiser l'espace navbar
              Sur desktop (lg+) : icône + texte "Installer l'app" %>
          <%# Sur desktop : bouton vert avec texte. Sur mobile : icône discrète style nav (comme la cloche et le chat) %>
          <%# aria-label : nom accessible fiable (sur mobile l'icône est seule sans texte) %>
          <button data-pwa-install-target="button"
                  data-action="click->pwa-install#openModal"
                  class="nav-pwa-btn d-flex align-items-center gap-2"
                  aria-label="Installer l'application sur votre appareil"
                  title="Installer l'application sur votre appareil">
            <i data-lucide="download" class="nav-pwa-icon" style="width:20px;height:20px;" aria-hidden="true"></i>
            <span class="d-none d-lg-inline nav-pwa-label">Installer l'app</span>
          </button>

          <%# ── Modale unique avec deux états gérés par Stimulus ──────────────
              État 1 (installable)    : titre + avantages + bouton Installer
              État 2 (déjà installé) : message informatif + bouton Fermer %>
          <div data-pwa-install-target="modal"
               class="modal fade" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content pwa-modal-content">

                <%# En-tête commun aux deux états %>
                <div class="modal-header border-0 pb-0 pt-4 px-4">
                  <%= image_tag "elements_graphiques/logo_vert.svg", alt: "Teams-up", style: "height:28px;" %>
                  <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>

                <%# ── État 1 : installation disponible ── %>
                <div data-pwa-install-target="installView">
                  <div class="modal-body px-4 py-4">
                    <h5 class="pwa-modal-title">
                      Installe Teams-up sur ton appareil
                    </h5>
                    <p class="pwa-modal-desc">
                      Accède à Teams-up directement depuis ton écran d'accueil, comme une vraie application — sans passer par le navigateur.
                    </p>
                    <ul class="pwa-modal-list">
                      <li class="pwa-modal-list-item">
                        <i data-lucide="zap" style="width:15px;height:15px;color:#1EDD88;flex-shrink:0;"></i>
                        Lancement instantané
                      </li>
                      <li class="pwa-modal-list-item">
                        <i data-lucide="smartphone" style="width:15px;height:15px;color:#1EDD88;flex-shrink:0;"></i>
                        Expérience plein écran
                      </li>
                    </ul>
                  </div>
                  <%# Instructions spécifiques iOS (Safari ne supporte pas le prompt natif) %>
                  <div data-pwa-install-target="iosInstructions" style="display:none; padding: 0 1.5rem 1rem;">
                    <p class="pwa-modal-ios-hint">
                      Sur iOS, appuie sur
                      <strong class="pwa-modal-ios-strong">Partager</strong>
                      <i data-lucide="share" style="width:13px;height:13px;color:#1EDD88;vertical-align:middle;"></i>
                      puis
                      <strong class="pwa-modal-ios-strong">Sur l'écran d'accueil</strong>.
                    </p>
                  </div>

                  <div class="modal-footer border-0 px-4 pb-4 pt-0 gap-2">
                    <button type="button" class="btn btn-sm pwa-modal-btn-later" data-bs-dismiss="modal">
                      Plus tard
                    </button>
                    <%# Bouton principal : caché sur iOS (pas de prompt natif), actif si le navigateur le supporte %>
                    <button type="button"
                            data-pwa-install-target="installBtn"
                            data-action="click->pwa-install#install"
                            class="btn btn-sm d-flex align-items-center gap-2"
                            style="background-color:#1EDD88; color:#111111; border:none; font-weight:700; border-radius:8px; padding:8px 20px;">
                      <i data-lucide="download" style="width:15px;height:15px;"></i>
                      Installer
                    </button>
                  </div>
                </div>

                <%# ── État 2 : déjà installé sur cet appareil ── %>
                <div data-pwa-install-target="alreadyInstalledView" style="display:none;">
                  <div class="modal-body px-4 py-4 text-center">
                    <div style="margin-bottom:1rem;">
                      <i data-lucide="circle-check" style="width:40px;height:40px;color:#1EDD88;"></i>
                    </div>
                    <h5 class="pwa-modal-title">
                      Déjà installée sur cet appareil
                    </h5>
                    <p class="pwa-modal-desc">
                      Teams-up est déjà installé ici. Tu peux l'ouvrir directement depuis ton écran d'accueil.<br>
                      <span class="pwa-modal-hint-small">Pour installer sur un autre appareil, utilise ce bouton depuis ce nouvel appareil.</span>
                    </p>
                  </div>
                  <div class="modal-footer border-0 px-4 pb-4 pt-0">
                    <button type="button" class="btn btn-sm w-100 pwa-modal-btn-later" data-bs-dismiss="modal">
                      Fermer
                    </button>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

        <%# ── Cloche notifications (UNE seule instance, temps réel via Turbo) ──
            turbo_stream_from : s'abonne au canal ActionCable de l'utilisateur.
            turbo_frame_tag   : ce fragment est remplacé à chaque nouvelle notif. %>
        <%= turbo_stream_from current_user, :notifications %>
        <div class="nav-item dropdown">
          <%= turbo_frame_tag "notification_bell" do %>
            <%= render "shared/notification_bell" %>
          <% end %>
        </div>

        <%# ── Bouton chat — ouvre la modale globale des conversations ──
            Le badge vert (#chat-navbar-badge) est géré par le Stimulus controller
            sticky-chat : il s'affiche quand il y a des messages non lus. %>
        <div class="nav-item">
          <%# aria-label : bouton icône-seule → nom accessible nécessaire (RGAA 11.9) %>
          <button type="button"
                  class="nav-chat-btn"
                  data-bs-toggle="modal"
                  data-bs-target="#global-chat-modal"
                  aria-label="Mes conversations"
                  title="Mes conversations">
            <%# Pas de color inline — hérite de .nav-chat-btn { color: var(--theme-text-muted) } %>
            <i data-lucide="message-circle" style="width:20px;height:20px;" aria-hidden="true"></i>
            <span id="chat-navbar-badge" class="nav-chat-badge" style="display:none;"></span>
          </button>
        </div>

        <%# ── Avatar + dropdown utilisateur (mobile + desktop) ── %>
        <div class="nav-item dropdown">
          <button type="button"
                  class="d-flex align-items-center gap-2 text-decoration-none btn-reset"
                  id="userDropdown"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="Menu utilisateur">
            <% display_name = current_user.profil &&
                [current_user.profil.first_name, current_user.profil.last_name]
                  .compact.join(" ").presence %>
            <%# Nom affiché uniquement sur desktop %>
            <% if display_name %>
              <span class="navbar-user-name d-none d-lg-inline"><%= display_name %></span>
            <% end %>
            <%# Avatar + point vert si admin avec des messages non lus %>
            <span class="navbar-avatar-wrapper">
              <%= user_avatar_tag current_user,
                  css_class: "avatar",
                  style: "object-fit:cover;",
                  alt: display_name || current_user.email %>
              <%# Wrapper fixe — son contenu est mis à jour en temps réel via Turbo Stream %>
              <% if current_user.admin? %>
                <span id="navbar-admin-avatar-dot">
                  <%= render "shared/navbar_admin_avatar_dot" %>
                </span>
              <% end %>
            </span>
          </button>

          <%# Dropdown desktop : Mon profil / Mon compte / Admin (si admin) / Déconnexion %>
          <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
            <%= link_to profil_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
              <i data-lucide="user" style="width:14px;height:14px;" aria-hidden="true"></i> Mon profil
            <% end %>
            <%= link_to edit_user_registration_path,
                class: "dropdown-item d-flex align-items-center gap-2" do %>
              <i data-lucide="settings" style="width:14px;height:14px;" aria-hidden="true"></i> Mon compte
            <% end %>
            <%# Lien Admin — visible uniquement pour les administrateurs %>
            <% if current_user&.admin? %>
              <div class="dropdown-divider"></div>
              <%= link_to admin_root_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                <i data-lucide="shield" style="width:14px;height:14px;" aria-hidden="true"></i>
                Administration
                <%# ms-auto pousse le wrapper vers la droite (flex item) — contenu mis à jour via Turbo Stream %>
                <span id="navbar-admin-inline-dot" class="ms-auto">
                  <%= render "shared/navbar_admin_inline_dot" %>
                </span>
              <% end %>
            <% end %>
            <div class="dropdown-divider"></div>
            <%= link_to destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "dropdown-item text-danger d-flex align-items-center gap-2" do %>
              <i data-lucide="log-out" style="width:14px;height:14px;" aria-hidden="true"></i> Se déconnecter
            <% end %>
          </div>
        </div>

      <% else %>
        <%# ── Non connecté — desktop uniquement (mobile → dans la sub-navbar) ── %>
        <div class="d-none d-lg-flex align-items-center gap-3">
          <%= link_to "Se connecter", new_user_session_path, class: "btn-cta-link" %>
          <%= link_to new_user_registration_path,
              class: "btn btn-primary btn-sm px-3 btn-cta-primary d-flex align-items-center gap-1" do %>
            S'inscrire
          <% end %>
        </div>
      <% end %>

      <%# ── Bouton toggle mode clair / mode sombre ───────────────────────────────
          Visible pour TOUS les utilisateurs (connectés ou non).
          data-theme-toggle-target="button" : le Stimulus controller "theme-toggle"
          (attaché sur <body>) détecte ce bouton et met à jour son icône au chargement
          et après chaque toggle.
          aria-label et title mis à jour dynamiquement par le controller JS. %>
      <button type="button"
              class="nav-theme-btn"
              data-theme-toggle-target="button"
              data-action="click->theme-toggle#toggle"
              title="Changer le thème"
              aria-label="Changer le thème">
        <%# L'icône est initialement "sun" (pour mode sombre → inviter à passer en clair).
            Le Stimulus controller la met à jour dès le connect() selon data-theme de <html>. %>
        <i data-lucide="sun" style="width:20px;height:20px;" aria-hidden="true"></i>
      </button>

    </div><%# fin actions droite %>

  </div>
</nav>
