<nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
  <div class="container-fluid">

    <%# Logo qui renvoie vers la page d'accueil %>
    <%= link_to root_path, class: "navbar-brand" do %>
      <%= image_tag "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/logo.png" %>
    <% end %>

    <%# Bouton hamburger pour mobile %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">

      <%# Liens de navigation à gauche %>
      <ul class="navbar-nav me-auto">
        <% if user_signed_in? %>

          <%# Lien vers la liste des matchs %>
          <li class="nav-item">
            <%= link_to "Les matchs", matches_path, class: "nav-link" %>
          </li>

          <%# Lien pour créer un match %>
          <li class="nav-item">
            <%= link_to "Créer un match", new_match_path, class: "nav-link" %>
          </li>

        <% end %>
      </ul>

      <%# Menu utilisateur à droite %>
      <ul class="navbar-nav ms-auto">
        <% if user_signed_in? %>

          <%# Dropdown avec avatar %>
          <li class="nav-item dropdown">
            <a href="#" class="avatar" id="navbarDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "avatar", alt: "menu utilisateur" %>
            </a>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
              <%# Lien vers mon profil %>
              <%= link_to "Mon profil", profil_path, class: "dropdown-item" %>
              <%# Lien vers les paramètres du compte Devise %>
              <%= link_to "Mon compte", edit_user_registration_path, class: "dropdown-item" %>
              <div class="dropdown-divider"></div>
              <%# Déconnexion %>
              <%= link_to "Se déconnecter", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %>
            </div>
          </li>

        <% else %>

          <%# Liens pour les visiteurs non connectés %>
          <li class="nav-item">
            <%= link_to "Se connecter", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "S'inscrire", new_user_registration_path, class: "nav-link" %>
          </li>

        <% end %>
      </ul>

    </div>
  </div>
</nav>
