<nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
  <div class="container-fluid">

    <%# Logo qui renvoie vers la page d'accueil %>
    <%= link_to root_path, class: "navbar-brand" do %>
      <%= image_tag "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/logo.png" %>
    <% end %>

    <%# Bouton hamburger pour mobile %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">

      <%# Liens de navigation à gauche %>
      <ul class="navbar-nav me-auto">
        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to matches_path, class: "nav-link d-flex align-items-center gap-1" do %>
              <i data-lucide="calendar-days" style="width:16px;height:16px;"></i> Les matchs
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to new_match_path, class: "nav-link d-flex align-items-center gap-1" do %>
              <i data-lucide="plus-circle" style="width:16px;height:16px;"></i> Créer un match
            <% end %>
          </li>
        <% end %>
      </ul>

      <%# Menu utilisateur à droite %>
      <ul class="navbar-nav ms-auto align-items-center gap-2">
        <% if user_signed_in? %>

          <%# ====== CLOCHE DE NOTIFICATIONS ====== %>
          <%#
            turbo_stream_from : s'abonne au canal ActionCable personnel de l'utilisateur.
            Canal unique : [current_user, :notifications] → "notifications_user_42"
            Quand une notification est créée, Turbo remplace automatiquement
            le turbo_frame "notification_bell" ci-dessous.
          %>
          <%= turbo_stream_from current_user, :notifications %>

          <%#
            turbo_frame_tag "notification_bell" : le seul fragment remplacé en temps réel.
            Contenu = partial _notification_bell.html.erb
            À chaque nouvelle notif, Turbo remplace uniquement ce <turbo-frame> sans rechargement.
          %>
          <li class="nav-item dropdown">
            <%= turbo_frame_tag "notification_bell" do %>
              <%= render "shared/notification_bell" %>
            <% end %>
          </li>
          <%# ====== FIN CLOCHE ====== %>

          <%# Dropdown avatar + nom de l'utilisateur %>
          <li class="nav-item dropdown">
            <%#
              On affiche le Prénom Nom à côté de l'avatar si le profil existe
              &. = opérateur "safe navigation" : évite une erreur si profil est nil
            %>
            <a href="#" class="d-flex align-items-center gap-2 text-decoration-none" id="navbarDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <%# Affiche Prénom Nom uniquement si le profil a au moins un nom renseigné %>
              <% display_name = current_user.profil && [current_user.profil.first_name, current_user.profil.last_name].compact.join(" ").presence %>
              <% if display_name %>
                <span class="small fw-semibold text-dark d-none d-sm-inline">
                  <%= display_name %>
                </span>
              <% end %>
              <% if current_user.profil&.avatar&.attached? %>
                <%= image_tag current_user.profil.avatar,
                    class: "avatar",
                    alt: "Photo de #{[current_user.profil.first_name, current_user.profil.last_name].compact.join(' ').presence || current_user.email}",
                    style: "object-fit:cover;" %>
              <% else %>
                <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "avatar", alt: "menu utilisateur" %>
              <% end %>
            </a>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
              <%= link_to profil_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                <i data-lucide="user" style="width:14px;height:14px;"></i> Mon profil
              <% end %>
              <%= link_to edit_user_registration_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                <i data-lucide="settings" style="width:14px;height:14px;"></i> Mon compte
              <% end %>
              <div class="dropdown-divider"></div>
              <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item d-flex align-items-center gap-2 text-danger" do %>
                <i data-lucide="log-out" style="width:14px;height:14px;"></i> Se déconnecter
              <% end %>
            </div>
          </li>

        <% else %>
          <li class="nav-item">
            <%= link_to new_user_session_path, class: "nav-link d-flex align-items-center gap-1" do %>
              <i data-lucide="log-in" style="width:16px;height:16px;"></i> Se connecter
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to new_user_registration_path, class: "btn btn-primary btn-sm d-flex align-items-center gap-1" do %>
              <i data-lucide="user-plus" style="width:16px;height:16px;"></i> S'inscrire
            <% end %>
          </li>
        <% end %>
      </ul>

    </div>
  </div>
</nav>
