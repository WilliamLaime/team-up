<%# =====================================================
    NAVBAR — Thème sombre avec accents verts
    - Utilisateur non connecté : liens + "Se connecter" + "S'inscrire"
    - Utilisateur connecté     : liens + "Créer un match" + cloche + avatar
    ===================================================== %>

<nav class="navbar navbar-expand-lg navbar-dark-custom">
  <div class="container">

    <%# ── Logo ── %>
    <%= link_to root_path, class: "navbar-brand" do %>
      <%= image_tag "logo_teams-up_logo_vert.png", alt: "Teams-Up", height: 30 %>
    <% end %>

    <%# ── Bouton hamburger (mobile) ── %>
    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse" data-bs-target="#navbarMain"
            aria-controls="navbarMain" aria-expanded="false" aria-label="Menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">

      <%# ── Liens du centre ── %>
      <ul class="navbar-nav mx-auto gap-1">
        <li class="nav-item">
          <%= link_to matches_path, class: "nav-link d-flex align-items-center gap-1" do %>
            <i data-lucide="search" style="width:15px;height:15px;"></i>
            Trouver un match
          <% end %>
        </li>
        <li class="nav-item">
          <%# Lien vers la section "Comment ça marche" de la homepage %>
          <%= link_to "#how-it-works", class: "nav-link" do %>
            Qui sommes-nous ?
          <% end %>
        </li>
      </ul>

      <%# ── Actions à droite ── %>
      <ul class="navbar-nav align-items-center gap-2">

        <% if user_signed_in? %>

          <%# Bouton principal : Créer un match (vert) %>
          <li class="nav-item">
            <%= link_to new_match_path, class: "btn btn-primary btn-sm px-3 d-flex align-items-center gap-1" do %>
              <i data-lucide="plus" style="width:15px;height:15px;"></i>
              Créer un match
            <% end %>
          </li>

          <%# ── Cloche notifications ── %>
          <% unread_count = current_user.notifications.unread.count %>
          <li class="nav-item dropdown">
            <a class="nav-link position-relative px-2" href="#"
               id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <i data-lucide="bell" style="width:20px;height:20px;color:rgba(255,255,255,0.75);"></i>
              <% if unread_count > 0 %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                      style="font-size:0.6rem;">
                  <%= unread_count %>
                </span>
              <% end %>
            </a>

            <%# Dropdown des notifications %>
            <div class="dropdown-menu dropdown-menu-end notif-dropdown"
                 aria-labelledby="notifDropdown">

              <%# En-tête %>
              <div class="notif-header d-flex justify-content-between align-items-center px-3 py-2">
                <strong class="small text-white">Notifications</strong>
                <% if unread_count > 0 %>
                  <%# Bouton "Tout lire" — text-primary prend la couleur verte %>
                  <%= button_to "Tout lire", mark_all_read_notifications_path,
                      method: :patch,
                      class: "btn btn-link btn-sm p-0 text-decoration-none text-primary small" %>
                <% end %>
              </div>

              <%# Liste des 5 dernières notifications %>
              <% recent_notifs = current_user.notifications.recent.limit(5) %>
              <% if recent_notifs.any? %>
                <% recent_notifs.each do |notif| %>
                  <%= button_to mark_read_notification_path(notif), method: :patch,
                      class: "w-100 text-start border-0 p-0 notif-item #{notif.read? ? '' : 'unread'}" do %>
                    <div class="d-flex align-items-start gap-2 px-3 py-2">
                      <% if notif.read? %>
                        <i data-lucide="check-circle" style="width:15px;height:15px;flex-shrink:0;margin-top:2px;color:rgba(255,255,255,0.4);"></i>
                      <% else %>
                        <i data-lucide="bell-dot" style="width:15px;height:15px;flex-shrink:0;margin-top:2px;" class="text-primary"></i>
                      <% end %>
                      <div>
                        <div class="<%= notif.read? ? 'text-muted' : 'fw-semibold text-white' %>"
                             style="font-size:0.82rem;white-space:normal;line-height:1.3;">
                          <%= notif.message %>
                        </div>
                        <small style="color:rgba(255,255,255,0.4);font-size:0.75rem;">
                          <%= time_ago_in_words(notif.created_at) %>
                        </small>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              <% else %>
                <div class="text-center py-3" style="color:rgba(255,255,255,0.5);">
                  <i data-lucide="inbox" style="width:22px;height:22px;"></i>
                  <div class="small mt-1">Aucune notification</div>
                </div>
              <% end %>

              <%# Lien "Voir tout" %>
              <div class="notif-footer text-center py-1">
                <%= link_to "Voir toutes les notifications", notifications_path,
                    class: "dropdown-item notif-see-all text-center small py-2" %>
              </div>

            </div>
          <%# ====== CLOCHE DE NOTIFICATIONS ====== %>
          <%#
            turbo_stream_from : s'abonne au canal ActionCable personnel de l'utilisateur.
            Canal unique : [current_user, :notifications] → "notifications_user_42"
            Quand une notification est créée, Turbo remplace automatiquement
            le turbo_frame "notification_bell" ci-dessous.
          %>
          <%= turbo_stream_from current_user, :notifications %>

          <%#
            turbo_frame_tag "notification_bell" : le seul fragment remplacé en temps réel.
            Contenu = partial _notification_bell.html.erb
            À chaque nouvelle notif, Turbo remplace uniquement ce <turbo-frame> sans rechargement.
          %>
          <li class="nav-item dropdown">
            <%= turbo_frame_tag "notification_bell" do %>
              <%= render "shared/notification_bell" %>
            <% end %>
          </li>
          <%# ── Fin cloche ── %>

          <%# ── Avatar + dropdown utilisateur ── %>
          <li class="nav-item dropdown">
            <a href="#" class="d-flex align-items-center gap-2 text-decoration-none"
               id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <% display_name = current_user.profil &&
                  [current_user.profil.first_name, current_user.profil.last_name]
                    .compact.join(" ").presence %>
              <% if display_name %>
                <span class="navbar-user-name d-none d-sm-inline"><%= display_name %></span>
              <% end %>
              <% if current_user.profil&.avatar&.attached? %>
                <%= image_tag current_user.profil.avatar, class: "avatar",
                    alt: display_name || current_user.email,
                    style: "object-fit:cover;" %>
              <% else %>
                <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier",
                    class: "avatar", alt: "avatar" %>
              <% end %>
            </a>

            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
              <%= link_to profil_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                <i data-lucide="user" style="width:14px;height:14px;"></i> Mon profil
              <% end %>
              <%= link_to edit_user_registration_path,
                  class: "dropdown-item d-flex align-items-center gap-2" do %>
                <i data-lucide="settings" style="width:14px;height:14px;"></i> Mon compte
              <% end %>
              <div class="dropdown-divider"></div>
              <%= link_to destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "dropdown-item text-danger d-flex align-items-center gap-2" do %>
                <i data-lucide="log-out" style="width:14px;height:14px;"></i> Se déconnecter
              <% end %>
            </div>
          </li>

        <% else %>
          <%# Utilisateur non connecté %>

          <%# Bouton secondaire : Se connecter (outline) %>
          <li class="nav-item">
            <%= link_to new_user_session_path,
                class: "btn btn-outline-secondary btn-sm px-3 d-flex align-items-center gap-1",
                style: "color:rgba(255,255,255,0.8);border-color:rgba(255,255,255,0.25);" do %>
              Se connecter
            <% end %>
          </li>

          <%# Bouton primaire : S'inscrire (vert) %>
          <li class="nav-item">
            <%= link_to new_user_registration_path,
                class: "btn btn-primary btn-sm px-3 d-flex align-items-center gap-1" do %>
              S'inscrire
            <% end %>
          </li>

        <% end %>
      </ul>

    </div>
  </div>
</nav>
