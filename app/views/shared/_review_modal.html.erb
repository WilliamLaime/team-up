<%# ── Modal post-match : noter ses coéquipiers ──────────────────────────── %>
<%# Structure en stepper : un match à la fois, navigation "Match suivant →" %>
<%# La section "Homme du match" ne s'affiche que si can_vote_homme est vrai %>


<%# auto_open : true = ouvre au chargement (après connexion), false = ouverture manuelle (bouton) %>
<% auto_open ||= true %>
<div class="modal fade"
     id="review-modal"
     tabindex="-1"
     aria-hidden="true"
     data-controller="review-modal"
     data-review-modal-auto-open-value="<%= auto_open %>"
     data-bs-backdrop="static">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:480px;">
    <%# Fond de la modale selon le thème via var(--theme-*) %>
    <div class="modal-content" style="background:var(--theme-bg-card); border:1px solid var(--theme-border); border-radius:14px;">

      <%# En-tête de la modal %>
      <div class="modal-header" style="border-bottom:1px solid var(--theme-border); padding:1.25rem 1.5rem;">
        <div style="flex:1;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <h5 style="color:var(--theme-text-strong); font-size:1rem; font-weight:700; margin:0;">
              <i data-lucide="star" style="width:16px; height:16px; color:#1EDD88; display:inline; vertical-align:middle; margin-right:0.4rem;"></i>
              Notez vos coéquipiers
            </h5>
            <%# Indicateur "1 / 3" mis à jour par JS (data-step-indicator) %>
            <% total_matches = pending_review_matches.count %>
            <span data-step-indicator
                  style="font-size:0.72rem; font-weight:600; color:var(--theme-text-muted); background:var(--theme-hover-bg); padding:0.2rem 0.55rem; border-radius:999px; <%= total_matches <= 1 ? 'display:none;' : '' %>">
              1 / <%= total_matches %>
            </span>
          </div>
          <%# Sous-titre : compte les joueurs restants dans le step courant, mis à jour par JS %>
          <% total_pending = pending_review_matches.sum { |m| m[:users].count } %>
          <p style="font-size:0.75rem; color:var(--theme-text-muted); margin:0.2rem 0 0;">
            <span data-pending-label>
              <% if total_pending > 0 %>
                encore <%= total_pending %> <%= total_pending > 1 ? "joueurs" : "joueur" %> à noter
              <% end %>
            </span>
          </p>
        </div>
        <%# Bouton fermer (croix) %>
        <button type="button"
                class="btn-close btn-close-white ms-3"
                data-action="click->review-modal#dismiss"
                style="opacity:0.5;">
        </button>
      </div>

      <%# Corps : stepper — un seul match visible à la fois %>
      <div class="modal-body review-modal-body" style="padding:1.25rem 1.5rem;">

        <% pending_review_matches.each_with_index do |item, index| %>
          <%# Chaque match est un "step" numéroté. Seul le step 0 est visible au départ. %>
          <div data-match-step="<%= index %>"
               style="<%= index == 0 ? '' : 'display:none;' %>">

            <%# Titre du match (sport + date) %>
            <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:#1EDD88; margin-bottom:0.75rem;">
              <i data-lucide="calendar" style="width:11px; height:11px; display:inline; vertical-align:middle;"></i>
              <%= item[:match].title %> — <%= item[:match].date&.strftime("%d/%m/%Y") %>
            </div>

            <%# ── Cards de notation (une par joueur non encore noté) ── %>
            <% item[:users].each do |player| %>
              <%# Fond de la card selon le thème %>
              <div class="review-card"
                   id="review-card-<%= player.id %>-<%= item[:match].id %>"
                   style="background:var(--theme-bg-surface); border:1px solid var(--theme-border); border-radius:10px; padding:0.9rem 1rem; margin-bottom:0.75rem;">

                <%# Identité du joueur %>
                <div style="display:flex; align-items:center; gap:0.65rem; margin-bottom:0.75rem;">
                  <% if player.profil&.avatar&.attached? %>
                    <%= image_tag player.profil.avatar,
                        style: "width:38px; height:38px; border-radius:50%; object-fit:cover; flex-shrink:0;",
                        alt: player.display_name %>
                  <% else %>
                    <%# Avatar initiale : fond et texte selon le thème %>
                    <div style="width:38px; height:38px; border-radius:50%; background:var(--theme-hover-bg); display:flex; align-items:center; justify-content:center; font-size:0.9rem; font-weight:800; color:var(--theme-text-muted); flex-shrink:0;">
                      <%= player.display_name.first.upcase %>
                    </div>
                  <% end %>
                  <div style="font-size:0.85rem; font-weight:700; color:var(--theme-text-strong);">
                    <%= player.display_name %>
                  </div>
                </div>

                <%# Formulaire d'avis soumis en AJAX via Stimulus %>
                <%= form_with url: user_avis_path(player), method: :post,
                    html: { style: "display:contents;" },
                    data: {
                      controller: "star-rating",
                      action: "submit->review-modal#submitReview",
                      "review-modal-player-id-param": player.id,
                      "review-modal-match-id-param":  item[:match].id
                    } do |f| %>

                  <%# match_id caché pour le backend %>
                  <%= hidden_field_tag "avis[match_id]", item[:match].id %>
                  <%# Note cachée remplie par le controller star-rating %>
                  <%= hidden_field_tag "avis[rating]", "",
                      data: { "star-rating-target": "input" } %>

                  <%# Étoiles cliquables — couleur initiale selon le thème %>
                  <div style="margin-bottom:0.6rem;">
                    <div style="display:flex; gap:0.3rem; font-size:1.65rem; cursor:pointer;"
                         data-star-rating-target="stars">
                      <% (1..5).each do |i| %>
                        <span data-action="click->star-rating#select"
                              data-value="<%= i %>"
                              style="color:var(--theme-text-muted); transition:color 0.15s; user-select:none;">★</span>
                      <% end %>
                    </div>
                  </div>

                  <%# Commentaire optionnel — fond et texte selon le thème %>
                  <textarea name="avis[content]"
                            placeholder="Un commentaire ? (optionnel)"
                            rows="2"
                            style="width:100%; background:var(--theme-bg-card); border:1px solid var(--theme-border); border-radius:7px; color:var(--theme-text-primary); padding:0.5rem 0.65rem; font-size:0.78rem; resize:none; margin-bottom:0.65rem;"></textarea>

                  <%# Bouton soumettre %>
                  <button type="submit"
                          class="btn btn-sm btn-cta-primary"
                          style="width:100%; border-radius:7px; font-size:0.8rem;"
                          data-star-rating-target="submit">
                    Envoyer mon avis
                  </button>

                <% end %>
              </div>
            <% end %>

            <%# ── Section "Homme du match" ─────────────────────────────────────── %>
            <%# Affiché uniquement si can_vote_homme (co-joueurs dispo + pas encore voté) %>
            <%# ou si has_voted (pour montrer la confirmation "Vote enregistré !") %>
            <% if item[:can_vote_homme] || item[:has_voted] %>
              <%# Séparateur selon le thème %>
              <div style="height:1px; background:var(--theme-border); margin:0.75rem 0;"></div>

              <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:#f59e0b; margin-bottom:0.65rem;">
                <i data-lucide="crown" style="width:11px; height:11px; display:inline; vertical-align:middle;"></i>
                Homme du match
              </div>

              <div id="vote-section-<%= item[:match].id %>">
                <% if item[:has_voted] %>
                  <%# Déjà voté : confirmation %>
                  <div style="display:flex; align-items:center; justify-content:center; gap:0.5rem; padding:0.5rem; color:#f59e0b;">
                    <span>🏆</span>
                    <span style="font-size:0.85rem; font-weight:600;">Vote enregistré !</span>
                  </div>
                <% else %>
                  <%# Pas encore voté : liste des co-joueurs sélectionnables %>
                  <%# Fond/bordure/couleur des boutons selon le thème %>
                  <div style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:0.65rem;">
                    <% item[:all_co_players].each do |player| %>
                      <button type="button"
                              class="vote-candidate-btn"
                              data-action="click->review-modal#selectVoteCandidate"
                              data-player-id="<%= player.id %>"
                              data-match-id="<%= item[:match].id %>"
                              style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.35rem 0.7rem; background:var(--theme-hover-bg); border:1px solid var(--theme-border); border-radius:999px; color:var(--theme-text-muted); font-size:0.78rem; cursor:pointer; transition:all 0.15s;">
                        <%= player.display_name %>
                      </button>
                    <% end %>
                  </div>

                  <%# Bouton vote — désactivé tant qu'aucun joueur n'est sélectionné %>
                  <button type="button"
                          class="btn btn-sm"
                          data-action="click->review-modal#submitVote"
                          data-match-id="<%= item[:match].id %>"
                          disabled
                          style="width:100%; border-radius:7px; font-size:0.78rem; background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.3); color:#f59e0b; opacity:0.5;">
                    Voter pour l'homme du match
                  </button>
                <% end %>
              </div>
            <% end %>
            <%# / section homme du match %>

          </div>
          <%# / data-match-step %>
        <% end %>

      </div>
      <%# / modal-body %>

      <%# Pied : "Plus tard" toujours dispo + "Match suivant" si plusieurs matchs %>
      <% total_matches = pending_review_matches.count %>
      <div class="modal-footer" style="border-top:1px solid var(--theme-border); padding:0.9rem 1.5rem; justify-content:space-between; align-items:center;">

        <%# Ferme la modal sans noter %>
        <button type="button"
                data-action="click->review-modal#dismiss"
                style="font-size:0.78rem; color:var(--theme-text-muted); background:none; border:none; cursor:pointer; padding:0.2rem 0.5rem;">
          Plus tard →
        </button>

        <%# Navigation vers le match suivant (masqué s'il n'y a qu'un seul match) %>
        <% if total_matches > 1 %>
          <button type="button"
                  data-action="click->review-modal#nextStep"
                  data-next-btn
                  style="font-size:0.78rem; font-weight:600; color:#1EDD88; background:rgba(30,221,136,0.08); border:1px solid rgba(30,221,136,0.25); border-radius:7px; cursor:pointer; padding:0.35rem 0.9rem; transition:all 0.15s;">
            Match suivant →
          </button>
        <% end %>

      </div>

    </div>
  </div>
</div>
