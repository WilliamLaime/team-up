<%# =====================================================
    FOOTER — Pied de page sombre
    Logo + liens + copyright + réseaux sociaux
    ===================================================== %>

<footer class="site-footer">
  <div class="container">
    <%# align-items-center : tout sur la même ligne, centré verticalement %>
    <div class="row align-items-center">

      <%# ── Logo : picto SVG + texte SVG côte à côte ── %>
      <%# justify-content-center sur mobile, justify-content-md-start sur desktop %>
      <div class="col-md-4 d-flex justify-content-center justify-content-md-start">
        <%= link_to root_path, class: "footer-logo" do %>
          <%# Icône picto blanc Teams-Up %>
          <%= image_tag "img_footer/teamsup_picto_blanc.svg", alt: "", height: 32, class: "footer-logo-picto" %>
          <%# Texte "TEAMS-UP" en SVG %>
          <%= image_tag "img_footer/teamsup_texte.svg", alt: "Teams-Up", height: 18, class: "footer-logo-texte" %>
        <% end %>
      </div>

      <%# ── Liens navigation centrés ── %>
      <div class="col-md-4 d-flex align-items-center justify-content-center">
        <ul class="footer-links">
          <%# Liens vers les pages légales %>
          <li><%= link_to "Confidentialité", confidentialite_path %></li>
          <li><%= link_to "Conditions", conditions_path %></li>
          <%# Lien vers la vraie page de contact %>
          <li><%= link_to "Contact", contact_path %></li>
          <%# "Qui sommes-nous ?" visible uniquement sur mobile (d-md-none) %>
          <li class="d-md-none"><%= link_to "Qui sommes-nous ?", about_path %></li>
        </ul>
      </div>

      <%# ── Réseaux sociaux ── %>
      <%# justify-content-center sur mobile, justify-content-md-end sur desktop %>
      <div class="col-md-4 d-flex justify-content-center justify-content-md-end">
        <%# Font Awesome pour les réseaux sociaux (Lucide n'a pas TikTok) %>
        <div class="footer-social d-flex gap-4">
          <a href="https://www.instagram.com/teamsup33?igsh=dGs2d3F6MDBmZDJ6" target="_blank" rel="noopener" aria-label="Instagram">
            <i class="fa-brands fa-instagram fa-lg"></i>
          </a>
          <a href="https://www.tiktok.com/@teamsup33" target="_blank" rel="noopener" aria-label="TikTok">
            <i class="fa-brands fa-tiktok fa-lg"></i>
          </a>
          <a href="https://www.youtube.com/@Teams-up33" target="_blank" rel="noopener" aria-label="YouTube">
            <i class="fa-brands fa-youtube fa-lg"></i>
          </a>
          <a href="https://www.twitch.tv/teamsup33" target="_blank" rel="noopener" aria-label="Twitch">
            <i class="fa-brands fa-twitch fa-lg"></i>
          </a>
        </div>
      </div>

    </div>

  </div><%# fin container %>

  <%# Bande copyright pleine largeur — fond plus foncé que le reste du footer %>
  <div class="footer-bottom">
    <div class="container text-center">
      &copy; <%= Time.current.year %> Team-Up. Tous droits réservés.
    </div>
  </div>

</footer>
