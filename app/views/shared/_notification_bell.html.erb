<%#
  Partial de la cloche de notifications — thème sombre.
  Mis à jour en temps réel via ActionCable/Turbo Stream.
  Utilisé dans _navbar.html.erb via turbo_frame_tag "notification_bell".
%>

<% unread_count = current_user.notifications.unread.count %>

<%# Bouton cloche — badge rouge si notifications non lues %>
<a class="nav-link px-2" href="#"
   id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
  <%# Le span position-relative est collé à la taille de l'icône (inline-flex)
      pour que le badge se positionne par rapport à la cloche et non au lien entier %>
  <span class="position-relative d-inline-flex">
    <i data-lucide="bell" style="width:20px;height:20px;color:rgba(255,255,255,0.75);"></i>
    <% if unread_count > 0 %>
      <%# Badge rouge au coin supérieur droit de la cloche %>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
            style="font-size:0.6rem;">
        <%= unread_count %>
      </span>
    <% end %>
  </span>
</a>

<%# Dropdown — classe notif-dropdown pour le style sombre défini dans _navbar.scss %>
<div class="dropdown-menu dropdown-menu-end notif-dropdown" aria-labelledby="notifDropdown">

  <%# En-tête : titre + bouton "Tout lire" si nécessaire %>
  <div class="notif-header d-flex justify-content-between align-items-center px-3 py-2">
    <strong class="small text-white">Notifications</strong>
    <% if unread_count > 0 %>
      <%# text-primary = couleur verte (Bootstrap $primary overridé) %>
      <%# turbo_frame: "_top" pour sortir du turbo_frame "notification_bell" et naviguer en pleine page %>
      <%= button_to "Tout lire", mark_all_read_notifications_path,
          method: :patch,
          data: { turbo_frame: "_top" },
          class: "btn btn-link btn-sm p-0 text-decoration-none text-primary small" %>
    <% end %>
  </div>

  <%# Liste des 30 dernières notifications — zone scrollable %>
  <% recent_notifs = current_user.notifications.recent.limit(30) %>
  <% if recent_notifs.any? %>
  <div class="notif-list">
    <% recent_notifs.each do |notif| %>
      <%# Cliquer marque la notif comme lue — classe "unread" = fond vert léger %>
      <%# data-turbo-frame="_top" : navigation pleine page pour sortir du turbo_frame "notification_bell" %>
      <%= button_to mark_read_notification_path(notif), method: :patch,
          class: "w-100 text-start border-0 p-0 notif-item #{notif.read? ? '' : 'unread'}",
          data: { turbo_frame: "_top" } do %>
        <div class="d-flex align-items-start gap-2 px-3 py-2">
          <%# Icône : check grisé si lue, cloche verte si non lue %>
          <% if notif.read? %>
            <i data-lucide="check-circle" style="width:15px;height:15px;flex-shrink:0;margin-top:2px;color:rgba(255,255,255,0.4);"></i>
          <% else %>
            <i data-lucide="bell-dot" style="width:15px;height:15px;flex-shrink:0;margin-top:2px;" class="text-primary"></i>
          <% end %>
          <div>
            <%# Texte : blanc/gris si lue, blanc gras si non lue %>
            <div class="<%= notif.read? ? '' : 'fw-semibold' %>"
                 style="font-size:0.82rem;white-space:normal;line-height:1.3;color:<%= notif.read? ? 'rgba(255,255,255,0.5)' : '#fff' %>;">
              <%= notif.message %>
            </div>
            <small style="color:rgba(255,255,255,0.4);font-size:0.75rem;">
              <%= time_ago_in_words(notif.created_at) %>
            </small>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
  <% else %>
    <%# État vide — aucune notification %>
    <div class="text-center py-3" style="color:rgba(255,255,255,0.5);">
      <i data-lucide="inbox" style="width:22px;height:22px;"></i>
      <div class="small mt-1">Aucune notification</div>
    </div>
  <% end %>

  <%# Pied de dropdown : lien vers toutes les notifications %>
  <div class="notif-footer text-center py-1">
    <%# data-turbo-frame="_top" pour sortir du turbo_frame et naviguer vers la page complète %>
    <%= link_to "Voir toutes les notifications", notifications_path,
        class: "dropdown-item notif-see-all text-center small py-2",
        data: { turbo_frame: "_top" } %>
  </div>

</div>
