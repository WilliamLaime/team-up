<%#
  Composant carte match — partagé entre la home et la liste des matchs.

  Variables locales :
    match      (required) — l'objet Match à afficher
    btn_label  (optional) — texte du bouton principal, défaut : "Rejoindre"
%>
<% btn_label ||= "Voir le match" %>

<%# Calculs réutilisés dans la carte %>
<%
  # Image de couverture via le helper SportImagesHelper (URLs Cloudinary)
  # Le helper gère : banner_image manuelle > rotation déterministe par sport
  cover_image = sport_cover_image(match)

  # Classe CSS du badge de niveau — tier dynamique selon la grille du sport
  level_css = level_badge_css(match.level, match.sport)

  # Date courte en français (ex: "Lun 13, 18:30")
  fr_days  = %w[Dim Lun Mar Mer Jeu Ven Sam]
  date_str = if match.date
    day       = fr_days[match.date.wday]
    time_part = match.time ? ", #{match.time.strftime('%H:%M')}" : ""
    "#{day} #{match.date.strftime('%d')}#{time_part}"
  else
    "—"
  end

  # Nom affiché de l'organisateur (Prénom I.)
  if match.user.present?
    first        = match.user.profil&.first_name || match.user.email.split("@").first
    last_initial = match.user.profil&.last_name&.first
    organizer_display = last_initial ? "#{first} #{last_initial}." : first
  end
%>

<div class="match-card">

  <%# ── Image du terrain + overlays ──────────────────────────────────────── %>
  <div class="match-card-img-wrapper">
    <%# loading: lazy → le navigateur ne télécharge cette image que quand la carte
        approche du viewport. Évite de charger les images hors-écran au chargement initial. %>
    <%= image_tag cover_image, alt: "Terrain #{match.title}", class: "match-card-img", loading: "lazy" %>

    <%# Badge sport — coin haut gauche de l'image %>
    <% if match.sport %>
      <div class="match-sport-overlay">
        <%= sport_icon(match.sport, size: "0.85rem", css_class: "match-sport-overlay-icon") %>
        <span class="match-sport-overlay-name"><%= match.sport.name %></span>
      </div>
    <% end %>

    <%# Bandeau "TERMINÉ" sur l'image si le match est terminé (> 1h après le début) %>
    <% if match.completed? %>
      <div class="match-completed-overlay">Terminé</div>
    <%# Bandeau "COMPLET" sur l'image si le match est plein (et pas encore terminé) %>
    <% elsif match.full? %>
      <div class="match-full-overlay">Complet</div>
    <% end %>

    <%# Overlay organisateur : brassard capitaine OU "Prénom N." %>
    <% if user_signed_in? && match.user == current_user %>
      <div class="match-organizer-overlay">
        <span class="match-captain-armband">C</span>
        <span class="match-captain-label">Ton match</span>
      </div>
    <% elsif match.user.present? %>
      <div class="match-organizer-overlay">
        <span class="match-organizer-name"><%= organizer_display %></span>
      </div>
    <% end %>
  </div>

  <%# ── Corps de la carte ─────────────────────────────────────────────────── %>
  <div class="match-card-body">

    <%# Ligne 1 : badges (sport + urgent + niveau) + date courte %>
    <div class="d-flex align-items-center justify-content-between mb-2">
      <div class="d-flex gap-1 flex-wrap">
        <% if match.urgent? %>
          <%# aria-hidden sur l'emoji : le mot "Urgent" suffit aux lecteurs d'écran %>
          <span class="match-badge-urgent"><span aria-hidden="true">🔥</span> Urgent</span>
        <% end %>
        <span class="match-badge-level <%= level_css %>"><%= match.level %></span>
      </div>
      <%# Format + date côte à côte à droite %>
      <div class="d-flex align-items-center gap-2">
        <% if match.format.present? %>
          <span class="match-card-date">
            <i data-lucide="users" style="width:12px;height:12px;" aria-hidden="true"></i>
            <%= match.format %>
          </span>
        <% end %>
        <span class="match-card-date">
          <i data-lucide="calendar" style="width:12px;height:12px;" aria-hidden="true"></i>
          <%= date_str %>
        </span>
      </div>
    </div>

    <%# Titre %>
    <div class="match-card-title" style="margin-bottom:6px; min-height:0; -webkit-line-clamp:1;">
      <%= match.title %>
    </div>

    <%# Description — toujours présente, hauteur fixe 2 lignes pour aligner toutes les cards %>
    <div style="font-size:0.75rem; color:var(--theme-text-muted); margin-top:0; margin-bottom:18px; line-height:1.4; height:2.1rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
      <%= match.description %>
    </div>

    <%# Lieu %>
    <div class="match-info-line">
      <i data-lucide="map-pin" style="width:13px;height:13px;" aria-hidden="true"></i>
      <span><%= match.place || "Lieu non défini" %></span>
    </div>

    <%# Avatars des joueurs inscrits + places manquantes %>
    <div class="match-players-row">
      <div class="match-avatars">
        <% match.users.first(3).each do |player| %>
          <%# Avatar du joueur ou initiales colorées si pas de photo %>
          <%= user_avatar_tag player, css_class: "match-avatar" %>
        <% end %>
      </div>
      <span class="match-players-text">
        <% if match.full? %>
          Complet
        <% else %>
          <%= match.player_left %> joueur<%= match.player_left > 1 ? "s" : "" %> manquant<%= match.player_left > 1 ? "s" : "" %>
        <% end %>
      </span>
    </div>

  </div>

  <%# ── Pied de carte : bouton ────────────────────────────────────────────── %>
  <div class="match-card-footer">
    <% if match.completed? %>
      <%# Match terminé → bouton secondaire pour tous %>
      <%= link_to match_path(match), class: "btn btn-cta-secondary btn-sm w-100 match-card-btn" do %>
        Voir le match
      <% end %>
    <% elsif match.full? %>
      <%# Match complet (pas encore terminé) → bouton secondaire %>
      <%= link_to match_path(match), class: "btn btn-cta-secondary btn-sm w-100 match-card-btn" do %>
        Voir le match
      <% end %>
    <% elsif user_signed_in? %>
      <%= link_to match_path(match), class: "btn btn-primary btn-sm w-100 match-card-btn" do %>
        <%# Si c'est le créateur du match, on personnalise le label %>
        <%= match.user == current_user ? "Voir ton match" : btn_label %>
      <% end %>
    <% else %>
      <%# Non connecté → on va quand même vers la page du match (accessible sans connexion).
          La connexion sera demandée uniquement si l'utilisateur clique sur "Rejoindre". %>
      <%= link_to match_path(match), class: "btn btn-primary btn-sm w-100 match-card-btn" do %>
        <%= btn_label %>
      <% end %>
    <% end %>
  </div>

</div>
