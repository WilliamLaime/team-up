<%#
  Composant carte match — partagé entre la home et la liste des matchs.

  Variables locales :
    match      (required) — l'objet Match à afficher
    btn_label  (optional) — texte du bouton principal, défaut : "Rejoindre"
%>
<% btn_label ||= "Voir le match" %>

<%# Calculs réutilisés dans la carte %>
<%
  # Images disponibles par sport — dossier sports/ dans assets/images/
  sport_images = {
    "football"   => %w[
      sports/Football/ballon.jpg
      sports/Football/citytoulouse.jpg
      sports/Football/bresil.jpg
      sports/Football/herbe.jpg
      sports/Football/city1.jpg
      sports/Football/citydrone.jpg
      sports/Football/Duel.jpg
      sports/Football/Medellin.jpg
      sports/Football/bris_glace.jpg
      sports/Football/terrainight.jpg
    ],
    "tennis"     => %w[
      sports/Tennis/tennis1.jpg
      sports/Tennis/tennis2.jpg
      sports/Tennis/tennis3.jpg
      sports/Tennis/tennis4.jpg
      sports/Tennis/tennis5.jpg
      sports/Tennis/tennis6.jpg
    ],
    "padel"      => %w[
      sports/Padel/padel1.jpg
      sports/Padel/padel2.jpg
      sports/Padel/padel3.jpg
      sports/Padel/padel4.jpg
      sports/Padel/padel5.jpg
      sports/Padel/padel6.jpg
    ],
    "volleyball" => %w[
      sports/Volley/volley1.jpg
      sports/Volley/volley2.jpg
      sports/Volley/volley3.jpg
      sports/Volley/volley4.jpg
      sports/Volley/volley5.jpg
      sports/Volley/volley6.jpg
    ],
    "basketball" => %w[
      sports/Basketball/basket1.jpg
      sports/Basketball/basket2.jpg
      sports/Basketball/basket3.jpg
      sports/Basketball/basket4.jpg
      sports/Basketball/basket5.jpg
      sports/Basketball/basket6.jpg
    ],
    "handball"   => %w[
      sports/Handball/handball1.jpg
      sports/Handball/handball2.jpg
    ],
    "badminton"  => %w[
      sports/Badminton/badminton1.jpg
      sports/Badminton/badminton2.jpg
      sports/Badminton/badminton3.jpg
      sports/Badminton/badminton4.jpg
      sports/Badminton/badminton5.jpg
      sports/Badminton/badminton6.jpg
    ]
  }

  # On récupère le slug du sport du match, ou "football" par défaut
  sport_slug = match.sport&.slug || "football"

  # On récupère la liste d'images correspondante (ou football si slug inconnu)
  images = sport_images[sport_slug] || sport_images["football"]

  # Rotation déterministe : le même match aura toujours la même image
  cover_image = images[match.id % images.length]

  # Classe CSS du badge de niveau
  level_css = case match.level
    when "Débutant"      then "level-debutant"
    when "Intermédiaire" then "level-intermediaire"
    when "Avancé"        then "level-avance"
    else                      "level-tout"
  end

  # Date courte en français (ex: "Lun 13, 18:30")
  fr_days  = %w[Dim Lun Mar Mer Jeu Ven Sam]
  date_str = if match.date
    day       = fr_days[match.date.wday]
    time_part = match.time ? ", #{match.time.strftime('%H:%M')}" : ""
    "#{day} #{match.date.strftime('%d')}#{time_part}"
  else
    "—"
  end

  # Nom affiché de l'organisateur (Prénom I.)
  if match.user.present?
    first        = match.user.profil&.first_name || match.user.email.split("@").first
    last_initial = match.user.profil&.last_name&.first
    organizer_display = last_initial ? "#{first} #{last_initial}." : first
  end
%>

<div class="match-card">

  <%# ── Image du terrain + overlays ──────────────────────────────────────── %>
  <div class="match-card-img-wrapper">
    <%= image_tag cover_image, alt: "Terrain #{match.title}", class: "match-card-img" %>

    <%# Badge sport — coin haut gauche de l'image %>
    <% if match.sport %>
      <div class="match-sport-overlay">
        <%= sport_icon(match.sport, size: "0.85rem", css_class: "match-sport-overlay-icon") %>
        <span class="match-sport-overlay-name"><%= match.sport.name %></span>
      </div>
    <% end %>

    <%# Bandeau "COMPLET" sur l'image si le match est plein %>
    <% if match.full? %>
      <div class="match-full-overlay">Complet</div>
    <% end %>

    <%# Overlay organisateur : brassard capitaine OU "Prénom N." %>
    <% if user_signed_in? && match.user == current_user %>
      <div class="match-organizer-overlay">
        <span class="match-captain-armband">C</span>
        <span class="match-captain-label">Ton match</span>
      </div>
    <% elsif match.user.present? %>
      <div class="match-organizer-overlay">
        <span class="match-organizer-name"><%= organizer_display %></span>
      </div>
    <% end %>
  </div>

  <%# ── Corps de la carte ─────────────────────────────────────────────────── %>
  <div class="match-card-body">

    <%# Ligne 1 : badges (sport + urgent + niveau) + date courte %>
    <div class="d-flex align-items-center justify-content-between mb-2">
      <div class="d-flex gap-1 flex-wrap">
        <% if match.urgent? %>
          <span class="match-badge-urgent">🔥 Urgent</span>
        <% end %>
        <span class="match-badge-level <%= level_css %>"><%= match.level %></span>
      </div>
      <span class="match-card-date">
        <i data-lucide="calendar" style="width:12px;height:12px;"></i>
        <%= date_str %>
      </span>
    </div>

    <%# Titre du match (tronqué à 2 lignes) %>
    <div class="match-card-title"><%= match.title %></div>

    <%# Format — affiché uniquement pour les sports multi-formats %>
    <% if match.format.present? %>
      <div class="match-info-line">
        <i data-lucide="users" style="width:13px;height:13px;"></i>
        <span><%= match.format %></span>
      </div>
    <% end %>

    <%# Lieu %>
    <div class="match-info-line">
      <i data-lucide="map-pin" style="width:13px;height:13px;"></i>
      <span><%= match.place || "Lieu non défini" %></span>
    </div>

    <%# Avatars des joueurs inscrits + places manquantes %>
    <div class="match-players-row">
      <div class="match-avatars">
        <% match.users.first(3).each do |player| %>
          <% if player.profil&.avatar&.attached? %>
            <%= image_tag player.profil.avatar, class: "match-avatar", alt: player.email %>
          <% else %>
            <img src="https://kitt.lewagon.com/placeholder/users/ssaunier" class="match-avatar" alt="joueur">
          <% end %>
        <% end %>
      </div>
      <span class="match-players-text">
        <% if match.full? %>
          Complet
        <% else %>
          <%= match.player_left %> joueur<%= match.player_left > 1 ? "s" : "" %> manquant<%= match.player_left > 1 ? "s" : "" %>
        <% end %>
      </span>
    </div>

  </div>

  <%# ── Pied de carte : bouton ────────────────────────────────────────────── %>
  <div class="match-card-footer">
    <% if match.full? %>
      <%# Match complet → bouton voir le match %>
      <%= link_to match_path(match), class: "btn btn-cta-secondary btn-sm w-100 match-card-btn" do %>
        Voir le match
      <% end %>
    <% elsif user_signed_in? %>
      <%= link_to match_path(match), class: "btn btn-primary btn-sm w-100 match-card-btn" do %>
        <%# Si c'est le créateur du match, on personnalise le label %>
        <%= match.user == current_user ? "Voir ton match" : btn_label %>
      <% end %>
    <% else %>
      <%= link_to new_user_registration_path, class: "btn btn-primary btn-sm w-100 match-card-btn" do %>
        <%= btn_label %>
      <% end %>
    <% end %>
  </div>

</div>
