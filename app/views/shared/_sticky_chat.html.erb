<%# ── Chat global — modale Bootstrap (sidebar conversations + zone chat) ────────
    Remplace l'ancien panneau sticky flottant en bas à droite.
    L'icône dans la navbar ouvre cette modale via data-bs-toggle="modal".
    Structure :
      [sidebar avec 2 onglets (Matchs+Équipes / Messages) | zone chat turbo-frame]
    Notifications : badge non-lu sur l'icône navbar géré en temps réel via ActionCable
%>
<% if user_signed_in? %>

  <%# ── Conversations de matchs (onglet "Matchs") ──────────────────────────
      Récupère les match_users actifs (non-dismissés, matchs non terminés) %>
  <%
    active_match_users = current_user.match_users
      .where("status = 'approved' OR role = 'organisateur'")
      .where(chat_dismissed_at: nil)
      .includes(:match)

    sticky_convos = active_match_users
      .select { |mu| !mu.match.past? }
      .sort_by { |mu| mu.match.created_at }
      .reverse
  %>

  <%# ── Conversations d'équipe (intégrées dans l'onglet "Matchs") ───────────
      Récupère les équipes dont l'utilisateur est membre %>
  <%
    user_team_members = current_user.team_members.includes(:team)
  %>

  <%# ── Conversations privées (onglet "Messages") ───────────────────────────
      Récupère toutes les conversations privées où current_user est sender ou recipient %>
  <%
    private_convos = PrivateConversation
      .where("sender_id = ? OR recipient_id = ?", current_user.id, current_user.id)
      .where(
        # Exclut les conversations que l'utilisateur a masquées
        # sender_dismissed_at nil = pas dismissée pour le sender, idem pour recipient
        "(sender_id = ? AND sender_dismissed_at IS NULL) OR (recipient_id = ? AND recipient_dismissed_at IS NULL)",
        current_user.id, current_user.id
      )
      .includes(:messages, sender: :profil, recipient: :profil)
      .order(updated_at: :desc)
  %>

  <%# id="sticky-chat-global" + data-turbo-permanent : dit à Turbo Drive de NE PAS
      remplacer cet élément lors des navigations de page.
      Sans ça, chaque navigation Turbo détruit les abonnements ActionCable
      et les messages n'arrivent plus en temps réel. %>
  <div id="sticky-chat-global"
       data-controller="sticky-chat"
       data-turbo-permanent>

    <%# Abonnement au stream personnel de l'utilisateur
        Permet de recevoir les mises à jour des badges non-lus en temps réel
        (broadcast depuis Message model pour les matchs, équipes et convs privées)
        NOTE : les streams de chat d'équipe (team_chat_sticky_*) sont abonnés dans
        team_conversations/show.html.erb (à l'intérieur de la turbo-frame),
        comme les streams de match dans conversations/show.html.erb %>
    <%= turbo_stream_from "user_conversations_#{current_user.id}" %>

    <%# Trigger caché pour l'ouverture automatique de la modale
        Quand l'organisateur crée un match, un broadcast met à jour son contenu
        Le MutationObserver Stimulus le détecte et appelle bootstrap.Modal.show() %>
    <div id="sticky-chat-open-trigger" style="display:none;"></div>

    <%# Indicateur d'onglet actif — peut être mis à jour par Turbo Stream
        (ex: depuis le profil → ouvre directement l'onglet Messages) %>
    <span id="sticky-chat-tab-indicator" style="display:none;"></span>

    <%# ── Modale Bootstrap ─────────────────────────────────────────────────── %>
    <div class="modal fade" id="global-chat-modal" tabindex="-1"
         aria-labelledby="chatModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content chat-modal-content">

          <%# Le contenu est divisé en deux colonnes : sidebar | chat
              pas de modal-header classique — l'en-tête est intégré dans la sidebar %>
          <div class="modal-body p-0 d-flex chat-modal-body">

            <%# ── Colonne gauche : sidebar avec onglets ─────────────────────── %>
            <div class="sticky-chat-sidebar">

              <%# ── Onglets de navigation (Matchs / Messages) ───────────────── %>
              <%# Gestion par Stimulus (sticky-chat#switchTab) — pas data-bs-toggle
                  car Bootstrap Tab entre en conflit avec data-turbo-permanent %>
              <div class="sticky-chat-tabs">
                <%# Onglet "Chats" (matchs + équipes) — actif par défaut (classe "active" gérée par Stimulus) %>
                <button class="sticky-chat-tab active"
                        type="button"
                        data-tab="chats"
                        data-action="click->sticky-chat#switchTab">
                  Chats
                  <%# Point vert non-lus — caché par défaut, affiché par updateBadge() %>
                  <span class="sticky-chat-tab-badge" id="badge-tab-chats" style="display:none;"></span>
                </button>
                <%# Onglet "Messages" (conversations privées) %>
                <button class="sticky-chat-tab"
                        type="button"
                        data-tab="messages"
                        data-action="click->sticky-chat#switchTab">
                  Messages
                  <span class="sticky-chat-tab-badge" id="badge-tab-messages" style="display:none;"></span>
                </button>
                <%# Bouton fermer — pousse à droite avec ms-auto %>
                <button class="sticky-chat-close-btn ms-auto"
                        data-bs-dismiss="modal"
                        title="Fermer">
                  <i data-lucide="x" style="width:14px;height:14px;"></i>
                </button>
              </div>

              <%# ── Contenu des onglets — géré par Stimulus, pas Bootstrap Tab ── %>
              <div class="sticky-chat-tab-content">

                <%# ── Onglet Chats (matchs + équipes) — visible par défaut (sticky-chat-pane--active) %>
                <div class="sticky-chat-pane sticky-chat-pane--active" id="tab-chats">

                  <%# IMPORTANT : #sticky-chat-sidebar-list doit TOUJOURS être présent
                      dans le DOM, même quand la liste est vide.
                      Les broadcasts Turbo Stream (match_user.rb → broadcast_prepend_to)
                      ciblent cet id pour ajouter une conversation en temps réel.
                      Si l'élément n'existe pas lors du broadcast, rien ne s'affiche. %>
                  <div id="sticky-chat-sidebar-list">

                    <%# ── Conversations d'équipe (point bleu) — en premier ── %>
                    <% if user_team_members.any? %>
                      <% user_team_members.each do |tm| %>
                        <%= render "shared/team_convo_item", team: tm.team, team_member: tm %>
                      <% end %>
                    <% end %>

                    <%# ── Conversations de match (point vert) ── %>
                    <% if sticky_convos.any? %>
                      <% sticky_convos.each do |mu| %>
                        <%= render "shared/sticky_convo_item", match: mu.match, match_user: mu %>
                      <% end %>
                    <% end %>

                    <%# Message vide si aucune conversation dans aucune catégorie %>
                    <% if sticky_convos.empty? && user_team_members.empty? %>
                      <div class="sticky-chat-sidebar-empty" id="sticky-chat-sidebar-empty">
                        <div>⚽</div>
                        <p>Rejoins un match ou une équipe pour chatter !</p>
                      </div>
                    <% end %>

                  </div>

                </div>

                <%# ── Onglet Messages (conversations privées) — caché par défaut %>
                <div class="sticky-chat-pane" id="tab-messages">
                  <%# IMPORTANT : #private-chat-sidebar-list doit TOUJOURS être présent
                      pour que les broadcasts Turbo Stream puissent y insérer des items. %>
                  <div id="private-chat-sidebar-list">
                    <% if private_convos.any? %>
                      <% private_convos.each do |conv| %>
                        <%= render "shared/private_convo_item",
                            conversation: conv,
                            current_user: current_user %>
                      <% end %>
                    <% else %>
                      <div class="sticky-chat-sidebar-empty" id="private-chat-sidebar-empty">
                        <div>💬</div>
                        <p>Aucun message privé</p>
                        <p style="font-size:0.68rem;">Visite le profil d'un joueur pour lui écrire !</p>
                      </div>
                    <% end %>
                  </div>
                </div>

              </div>
              <%# ── Fin contenu onglets ── %>

            </div>
            <%# ── Fin sidebar ── %>

            <%# ── Colonne droite : chat sélectionné (Turbo Frame) ───────────── %>
            <div class="sticky-chat-content">
              <turbo-frame id="sticky-chat-frame" class="sticky-chat-frame-wrapper">
                <div class="sticky-chat-no-selection">
                  <div style="font-size: 1.8rem;">💬</div>
                  <p>Sélectionne une conversation</p>
                </div>
              </turbo-frame>
            </div>

          </div>
          <%# ── Fin modal-body ── %>

        </div>
      </div>
    </div>
    <%# ── Fin modale ── %>

  </div>

<% end %>
