<%# Bouton de relation ami — affiché sur le profil d'un autre utilisateur
    Gère 4 états :
      1. Déjà amis (accepted) → badge "Amis" + bouton "Retirer" si c'est moi qui ai initié
      2. Demande envoyée par moi (pending sent) → "En attente" + bouton "Annuler"
      3. Demande reçue de cet utilisateur (pending received) → boutons "Accepter" / "Refuser"
      4. Aucune relation → bouton "Ajouter"

    Paramètres locaux :
      - profil_user              : l'utilisateur dont on consulte le profil
      - already_friends          : boolean
      - pending_sent             : boolean — j'ai envoyé une demande à cette personne
      - pending_received         : boolean — cette personne m'a envoyé une demande
      - friendship_initiated_by_me : objet Friendship si c'est moi qui ai initié %>

<%= turbo_frame_tag "friend_button_#{profil_user.id}" do %>

<%# current_user.present? fonctionne aussi bien en contexte request normal qu'en broadcast ActionCable %>
<% if current_user.present? && current_user != profil_user %>

  <%# ── État 1 : on est déjà amis ── %>
  <% if already_friends %>
    <%# ID unique pour la modale (évite les conflits si plusieurs cartes sur la page) %>
    <% modal_id = "removefriendModal#{profil_user.id}" %>
    <div style="display:inline-flex; align-items:center; gap:0.4rem;">
      <%# Badge "Amis" vert — classe hardcodée claire car la player card est toujours sombre %>
      <span class="friend-status-badge friend-status-badge--friends">
        <i data-lucide="user-check" style="width:11px; height:11px;"></i>
        Amis
      </span>

      <%# Bouton "Retirer" — style discret blanc sur fond sombre %>
      <button type="button"
              class="friend-action-btn friend-action-btn--muted"
              data-bs-toggle="modal"
              data-bs-target="#<%= modal_id %>">
        <i data-lucide="user-minus" style="width:10px; height:10px;"></i>
        Retirer
      </button>
    </div>

    <%# Modale hissée hors du flip-card via content_for :modals
        (les transforms CSS du flip-card piègent les modales à l'intérieur sinon) %>
    <% content_for :modals do %>
      <div class="modal fade" id="<%= modal_id %>" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
          <%# Fond et bordure selon le thème %>
          <div class="modal-content" style="background:var(--theme-bg-card); border:1px solid var(--theme-border); border-radius:12px;">

            <div class="modal-body text-center" style="padding:1.5rem 1.5rem 1rem;">
              <div style="font-size:2rem; margin-bottom:0.75rem;">👋</div>
              <p style="color:var(--theme-text-strong); font-weight:700; font-size:0.95rem; margin-bottom:0.3rem;">
                Retirer <%= profil_user.profil&.first_name %> ?
              </p>
              <p style="color:var(--theme-text-muted); font-size:0.8rem; margin:0;">
                Vous ne serez plus amis et ne pourrez plus vous envoyer de messages.
              </p>
            </div>

            <div class="modal-footer" style="border-top:1px solid var(--theme-border); padding:0.75rem 1.5rem; gap:0.5rem; justify-content:center;">
              <%# Annuler — ferme juste la modale %>
              <button type="button"
                      data-bs-dismiss="modal"
                      style="font-size:0.8rem; font-weight:600; color:var(--theme-text-muted);
                             background:var(--theme-hover-bg); border:1px solid var(--theme-border);
                             border-radius:20px; padding:0.4rem 1rem; cursor:pointer;">
                Annuler
              </button>

              <%# Confirmer — soumet la vraie requête DELETE %>
              <%= button_to user_friendship_path(profil_user),
                    method: :delete,
                    data: { turbo_frame: "_top" },
                    style: "font-size:0.8rem; font-weight:700; color:#fff;
                            background:rgba(220,53,69,0.8); border:1px solid rgba(220,53,69,0.5);
                            border-radius:20px; padding:0.4rem 1rem; cursor:pointer;" do %>
                Retirer
              <% end %>
            </div>

          </div>
        </div>
      </div>
    <% end %>

  <%# ── État 2 : j'ai envoyé une demande, en attente de réponse ── %>
  <% elsif pending_sent %>
    <div style="display:inline-flex; align-items:center; gap:0.4rem;">
      <%# Badge "En attente" — blanc discret, lisible sur fond sombre de la player card %>
      <span class="friend-status-badge friend-status-badge--pending">
        <i data-lucide="clock" style="width:11px; height:11px;"></i>
        En attente
      </span>
      <%# Bouton pour annuler la demande envoyée %>
      <%# data-turbo-frame="_top" → force une navigation complète pour que le toast flash s'affiche %>
      <%= button_to user_friendship_path(profil_user),
            method: :delete,
            data: { turbo_frame: "_top" },
            class: "friend-action-btn friend-action-btn--cancel" do %>
        <i data-lucide="x" style="width:10px; height:10px;"></i>
        Annuler
      <% end %>
    </div>

  <%# ── État 3 : cette personne m'a envoyé une demande, je dois répondre ── %>
  <% elsif pending_received %>
    <div style="display:inline-flex; align-items:center; gap:0.4rem;">
      <%# Bouton Accepter — vert %>
      <%# data-turbo-frame="_top" → force une navigation complète pour que le toast flash s'affiche %>
      <%= button_to accept_user_friendship_path(profil_user),
            method: :patch,
            data: { turbo_frame: "_top" },
            class: "friend-action-btn friend-action-btn--add" do %>
        <i data-lucide="check" style="width:11px; height:11px;"></i>
        Accepter
      <% end %>
      <%# Bouton Refuser — rouge discret %>
      <%# data-turbo-frame="_top" → force une navigation complète pour que le toast flash s'affiche %>
      <%= button_to decline_user_friendship_path(profil_user),
            method: :patch,
            data: { turbo_frame: "_top" },
            class: "friend-action-btn friend-action-btn--cancel" do %>
        <i data-lucide="x" style="width:11px; height:11px;"></i>
        Refuser
      <% end %>
    </div>

  <%# ── État 4 : aucune relation, bouton "Ajouter" ── %>
  <% else %>
    <%# data-turbo-frame="_top" → force une navigation complète pour que le toast flash s'affiche %>
    <%= button_to user_friendship_path(profil_user),
          method: :post,
          data: { turbo_frame: "_top" },
          class: "friend-action-btn friend-action-btn--add" do %>
      <i data-lucide="user-plus" style="width:11px; height:11px;"></i>
      Ajouter
    <% end %>
  <% end %>

<% end %><%# fin if current_user.present? %>

<% end %><%# fin turbo_frame_tag friend_button %>
