<%# Modal de notification "un joueur a rejoint automatiquement" pour l'organisateur.
    Injectée dans #auto_join_notification_container en temps réel via Turbo Stream
    (broadcast depuis MatchUsersController#join_automatically).
    Variables attendues : joining_user (User), match, match_user (MatchUser) %>

<div class="modal fade" id="autoJoinModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content pending-modal-content" style="text-align:center;">

      <%# Croix de fermeture %>
      <button type="button"
              class="pending-modal-close"
              data-bs-dismiss="modal"
              aria-label="Fermer">
        <i data-lucide="x" style="width:16px;height:16px;"></i>
      </button>

      <%# Calcul du nom affiché : "Prénom N." %>
      <%
        first       = joining_user.profil&.first_name.presence || joining_user.email.split("@").first
        last_letter = joining_user.profil&.last_name.presence&.first&.upcase
        display     = last_letter ? "#{first} #{last_letter}." : first
      %>

      <%# Avatar du joueur + "Prénom N. a rejoint" %>
      <div style="display:flex; flex-direction:column; align-items:center; gap:10px; padding-top:8px; padding-bottom:16px;">
        <%# Avatar (photo ou initiales colorées) %>
        <%= user_avatar_tag joining_user, css_class: "pending-modal-avatar" %>
        <%# Titre avec nom du joueur %>
        <div class="pending-modal-title" style="font-size:1.05rem; margin-bottom:0;">
          <%= display %> a rejoint !
        </div>
      </div>

      <%# Sous-titre : nom du match + info place %>
      <div class="pending-modal-subtitle" style="margin-bottom:0;">
        <strong><%= display %></strong> vient de rejoindre votre match <strong><%= match.title %></strong>.<br>
        Il reste <strong><%= match.player_left %></strong> place<%= match.player_left > 1 ? "s" : "" %> disponible<%= match.player_left > 1 ? "s" : "" %>.
      </div>

      <%# Message laissé par le joueur — affiché uniquement s'il en a écrit un %>
      <% if match_user.message.present? %>
        <div style="margin:16px 0 0; padding:12px 16px; background:rgba(255,255,255,0.05); border-radius:8px; border:1px solid rgba(255,255,255,0.1); text-align:left;">
          <div style="font-size:0.75rem; color:#aaa; margin-bottom:6px; display:flex; align-items:center; gap:6px;">
            <i data-lucide="message-circle" style="width:13px;height:13px;"></i>
            Message de <%= display %>
          </div>
          <div style="font-size:0.9rem; color:#eee; font-style:italic;">
            "<%= match_user.message %>"
          </div>
        </div>
      <% end %>

      <div class="pending-modal-divider" style="margin-top:20px;"></div>

      <%# Boutons d'action %>
      <div style="display:flex; flex-direction:column; align-items:center; gap:10px; padding:16px 0 4px;">

        <%# Bouton de fermeture principal %>
        <button type="button"
                class="btn btn-sm w-100"
                style="background:rgba(255,150,50,0.12); color:#ff9632; border:1px solid rgba(255,150,50,0.3);"
                data-bs-dismiss="modal">
          Super, j'ai vu !
        </button>

      </div>

    </div>
  </div>
</div>

<%# Ouvre la modal Bootstrap automatiquement quand le contenu est injecté par Turbo Stream.
    Après fermeture de la modal, recharge la page pour refléter le nouveau nombre de joueurs
    (compteur mis à jour, grille des joueurs actualisée, etc.). %>
<script>
  (function() {
    var el = document.getElementById("autoJoinModal");
    if (el && typeof bootstrap !== "undefined") {
      var modal = bootstrap.Modal.getOrCreateInstance(el);
      modal.show();

      if (typeof lucide !== "undefined") { lucide.createIcons(); }

      // Recharge la page quand la modal est fermée → données joueurs à jour
      el.addEventListener("hidden.bs.modal", function() {
        window.location.reload();
      }, { once: true });
    }
  })();
</script>
