<%# =====================================================
    PAGE D'ACCUEIL — Team Up
    4 sections : Hero / Matchs / Comment ça marche / CTA
    ===================================================== %>

<%# ══════════════════════════════════════════════════
    1. HERO — Section principale sombre
       Titre + description + CTA + image terrain
    ══════════════════════════════════════════════════ %>
<section class="hero-section">

  <%# Picto décoratif en arrière-plan — flouté avec glow vert léger %>
  <%= image_tag "elements_graphiques/logo_teams-up_seul_picto.svg", class: "hero-picto-bg", alt: "" %>

  <div class="container">
    <div class="row align-items-center g-5">

      <%# ── Colonne gauche : texte ── %>
      <div class="col-lg-6">

        <%# Badge avec point animé %>
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <%= @available_matches_count %> match<%= @available_matches_count > 1 ? "s" : "" %> disponible<%= @available_matches_count > 1 ? "s" : "" %>
        </div>

        <%# Titre principal sur 2 lignes %>
        <h1 class="hero-title">
          Créer un match<br>
          <span class="hero-title-accent">en 30 secondes.</span>
        </h1>

        <%# Sous-titre %>
        <p class="hero-description">
          Le moyen le plus rapide pour compléter votre cinq ou rejoindre
          une équipe de passionnés. Plus d'excuses pour ne pas jouer.
        </p>

        <%# Boutons CTA :
            - Utilisateur connecté   → "Créer un match" (primaire) + "Voir les matchs" (secondaire)
            - Utilisateur non connecté → "Créer un match" (primaire) → redirige vers inscription
        %>
        <div class="d-flex flex-wrap gap-3">
          <% if user_signed_in? %>
            <%# Bouton primaire → création d'un match %>
            <%= render "shared/btn_primary", url: new_match_path, text: "Créer un match" %>
            <%# Bouton secondaire → liste des matchs %>
            <%= render "shared/btn_secondary", url: matches_path, text: "Voir les matchs" %>
          <% else %>
            <%# Bouton primaire → inscription (utilisateur non connecté) %>
            <%= render "shared/btn_primary", url: new_user_registration_path, text: "Créer un match" %>
            <%# Bouton secondaire → liste des matchs %>
            <%= render "shared/btn_secondary", url: matches_path, text: "Voir les matchs" %>
          <% end %>
        </div>

      </div>

      <%# ── Colonne droite : image + overlay ── %>
      <div class="col-lg-6 d-none d-lg-block">
        <div class="hero-image-wrapper">

          <%# Image hero : change selon le sport actif de l'utilisateur %>
          <% case current_sport&.name
             when "Football"
               hero_src = asset_path("img banner/banner_foot.jpeg")
               hero_alt = "Terrain de football"
             when "Badminton"
               hero_src = asset_path("img banner/banner_bad.jpeg")
               hero_alt = "Joueur de badminton"
             when "Basketball"
               hero_src = asset_path("img banner/banner_basket.jpeg")
               hero_alt = "Joueur de basketball"
             when "Handball"
               hero_src = asset_path("img banner/banner_hand.jpeg")
               hero_alt = "Joueur de handball"
             when "Padel"
               hero_src = asset_path("img banner/banner_padel.jpeg")
               hero_alt = "Joueur de padel"
             when "Volleyball"
               hero_src = asset_path("img banner/banner_volley.jpeg")
               hero_alt = "Joueur de volley"
             when nil
               # Mode Multisport (aucun sport sélectionné) → image Cloudinary multisports
               hero_src = sport_misc_image(:multisports_img)
               hero_alt = "Multisport"
             else
               # Tennis par défaut
               hero_src = asset_path("img banner/banner_tennis.avif")
               hero_alt = "Joueur de tennis"
             end %>
          <%= image_tag hero_src, alt: hero_alt, class: "hero-img" %>

          <%# Carte overlay : affiche le prochain match disponible (jamais complet)
              @hero_match est calculé dans le controller — exclut les matchs full? %>
          <% if @hero_match %>
            <%# Le lien englobe toute la carte pour la rendre cliquable %>
            <%= link_to match_path(@hero_match), class: "hero-match-card" do %>

              <%# Ligne haute : icône ronde + label + titre %>
              <div class="d-flex align-items-center gap-3">
                <%# Icône orange avec éclair %>
                <div class="hero-match-icon">
                  <i data-lucide="zap" style="width:18px;height:18px;"></i>
                </div>
                <%# Infos principales %>
                <div class="flex-grow-1 overflow-hidden">
                  <div class="hero-match-label">
                    <%= @hero_match.urgent? ? "Match Urgent" : @hero_match.level %>
                  </div>
                  <div class="hero-match-title"><%= @hero_match.title %></div>
                </div>
              </div>

              <%# Ligne basse : heure à gauche, places restantes à droite %>
              <div class="d-flex justify-content-between align-items-center hero-match-footer">
                <span class="hero-match-time">
                  <%= @hero_match.time&.strftime('%H:%M') %> · Ce soir
                </span>
                <%# Toujours des places dispo (jamais complet grâce au controller) %>
                <span class="hero-match-spots">
                  <%= @hero_match.player_left %> place<%= @hero_match.player_left > 1 ? "s" : "" %>
                </span>
              </div>

            <% end %>

          <% else %>
            <%# Aucun match disponible — encart vide avec CTA %>
            <div class="hero-match-card hero-match-card--empty">
              <div class="d-flex align-items-center gap-3">
                <div class="hero-match-icon">
                  <i data-lucide="calendar-plus" style="width:18px;height:18px;"></i>
                </div>
                <div class="flex-grow-1">
                  <div class="hero-match-label">Aucun match prévu</div>
                  <div class="hero-match-title">Sois le premier à créer un match !</div>
                </div>
              </div>
              <div class="hero-match-footer">
                <% if user_signed_in? %>
                  <%= link_to new_match_path, class: "hero-match-cta-link" do %>
                    Créer un match <i data-lucide="arrow-right" style="width:13px;height:13px;"></i>
                  <% end %>
                <% else %>
                  <%= link_to new_user_registration_path, class: "hero-match-cta-link" do %>
                    S'inscrire pour jouer <i data-lucide="arrow-right" style="width:13px;height:13px;"></i>
                  <% end %>
                <% end %>
              </div>
            </div>

          <% end %>

        </div>
      </div>

    </div>
  </div>
</section>


<%# ══════════════════════════════════════════════════
    2. MATCHS À PROXIMITÉ — Section claire
       Affiche les 3 prochains matchs de la BDD
    ══════════════════════════════════════════════════ %>
<section class="matches-section">
  <div class="container">

    <%# En-tête de section %>
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <h2 class="matches-section-title">Matchs à proximité</h2>
        <p class="matches-section-subtitle mb-0">
          Les prochaines séances disponibles près de vous.
        </p>
      </div>
      <%= render "shared/nav_button", url: matches_path, label: "Tout voir", direction: "forward", extra_class: "mt-1" %>
    </div>

    <% if @matches.any? %>
      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% @matches.each do |match| %>
          <div class="col">
            <%# Utilise le composant partagé — btn_label "Voir le match" pour la home %>
            <%= render "shared/match_card", match: match, btn_label: "Voir le match" %>
          </div>
        <% end %>
      </div>

    <% else %>
      <%# Aucun match disponible %>
      <div class="matches-empty">
        <i data-lucide="calendar-x" style="width:40px;height:40px;color:#ccc;"></i>
        <p class="mt-3 mb-2">Aucun match disponible pour le moment.</p>
        <% if user_signed_in? %>
          <%= link_to "Créer le premier match", new_match_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>

  </div>
</section>


<%# ══════════════════════════════════════════════════
    3. COMMENT ÇA MARCHE — Section claire
       3 étapes : Propose / Notifie / Équipe complète
    ══════════════════════════════════════════════════ %>
<section class="how-it-works-section" id="how-it-works">
  <div class="container">

    <h2 class="hiw-title">Jouez plus, organisez moins.</h2>
    <p class="hiw-subtitle">
      Team-Up simplifie la logistique pour que vous restiez concentré sur le terrain.
    </p>

    <div class="row justify-content-center g-4">

      <%# Étape 1 : Proposer un match %>
      <div class="col-md-4">
        <div class="hiw-item">
          <div class="hiw-icon-circle">
            <i data-lucide="calendar-plus" style="width:26px;height:26px;"></i>
          </div>
          <div class="hiw-item-title">Propose un match</div>
          <p class="hiw-item-text">
            Indique l'heure, le lieu et le nombre de joueurs souhaités en moins d'une minute, sans solution.
          </p>
        </div>
      </div>

      <%# Étape 2 : On notifie les joueurs %>
      <div class="col-md-4">
        <div class="hiw-item">
          <div class="hiw-icon-circle">
            <i data-lucide="bell-ring" style="width:26px;height:26px;"></i>
          </div>
          <div class="hiw-item-title">On notifie les joueurs</div>
          <p class="hiw-item-text">
            Notre algorithme alerte les joueurs disponibles à proximité automatiquement.
          </p>
        </div>
      </div>

      <%# Étape 3 : Équipe complète %>
      <div class="col-md-4">
        <div class="hiw-item">
          <div class="hiw-icon-circle">
            <i data-lucide="check-circle-2" style="width:26px;height:26px;"></i>
          </div>
          <div class="hiw-item-title">Ton équipe est complète</div>
          <p class="hiw-item-text">
            Reçois une notification quand ton match est prêt <br>et retrouve tes coéquipiers sur le terrain.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>


<%# ══════════════════════════════════════════════════
    4. CTA SOMBRE — "Dites adieu aux groupes WhatsApp"
       Section sombre avec mockup de conversation
    ══════════════════════════════════════════════════ %>
<section class="cta-section">
  <div class="container">
    <div class="row align-items-center g-5">

      <%# ── Colonne gauche : texte + liste ── %>
      <div class="col-lg-6">

        <h2 class="cta-title">
          Dites adieu aux groupes whatsApp <span class="cta-title-accent">bordéliques.</span>
        </h2>

        <p class="cta-description">
          Gérez tout au même endroit : validation des joueurs, sécurité,
          et bien plus. Plus de déplacements à la dernière minute sans solution.
        </p>

        <%# Liste des avantages avec coches vertes %>
        <ul class="cta-feature-list">
          <li>
            <span class="cta-check">
              <i data-lucide="check" style="width:11px;height:11px;"></i>
            </span>
            Canal de discussion privé par match
          </li>
          <li>
            <span class="cta-check">
              <i data-lucide="check" style="width:11px;height:11px;"></i>
            </span>
            Partage de localisation rapide
          </li>
          <li>
            <span class="cta-check">
              <i data-lucide="check" style="width:11px;height:11px;"></i>
            </span>
            Notifications push pour les messages importants
          </li>
        </ul>
      </div>

      <%# ── Colonne droite : image de la fenêtre de dialogue ── %>
      <div class="col-lg-6 d-flex justify-content-center align-items-center">
        <%= image_tag "fenetre_dialogue_home.png", class: "cta-chat-image", alt: "Aperçu du chat Team Up", style: "width: 450px; max-width: 100%; height: auto; display: block;" %>
      </div>

    </div>
  </div>
</section>


<%# ══════════════════════════════════════════════════
    5. CONTACTEZ-NOUS — Section claire
       Deux cartes : contact pro (partenariat) + contact utilisateur (questions/retours)
       Les deux redirigent vers /contact (formulaire existant)
    ══════════════════════════════════════════════════ %>
<section class="contact-cta-section">
  <div class="container">

    <%# ── Titre de section ── %>
    <div class="text-center mb-5">
      <h2 class="contact-cta-title">Contactez-nous</h2>
      <p class="contact-cta-subtitle">
        Une question ou une opportunité ? On est là pour vous.
      </p>
    </div>

    <%# ── Deux cartes côte à côte ── %>
    <div class="row justify-content-center g-4">

      <%# ── Carte 1 : Contact Professionnel ── %>
      <%# Pour les partenariats, presse, propositions commerciales → page dédiée %>
      <div class="col-md-5">
        <%= link_to partenariat_path, class: "contact-cta-card contact-cta-card--pro" do %>

          <%# Icône dans un cercle coloré %>
          <div class="contact-cta-icon contact-cta-icon--pro">
            <i data-lucide="briefcase" style="width:28px;height:28px;"></i>
          </div>

          <%# Titre de la carte %>
          <h3 class="contact-cta-card-title">Contact Professionnel</h3>

          <%# Description courte %>
          <p class="contact-cta-card-text">
            Vous êtes une marque, un club sportif ou un partenaire potentiel ?
            Parlons de ce qu'on peut construire ensemble.
          </p>

          <%# Lien discret en bas de la carte %>
          <span class="contact-cta-card-link">
            Nous écrire <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
          </span>

        <% end %>
      </div>

      <%# ── Carte 2 : Contact Utilisateur ── %>
      <%# Pour les questions, retours d'expérience, bugs signalés %>
      <div class="col-md-5">
        <%= link_to contact_path, class: "contact-cta-card contact-cta-card--user" do %>

          <%# Icône dans un cercle vert %>
          <div class="contact-cta-icon contact-cta-icon--user">
            <i data-lucide="message-circle" style="width:28px;height:28px;"></i>
          </div>

          <%# Titre de la carte %>
          <h3 class="contact-cta-card-title">Support & Retours</h3>

          <%# Description courte %>
          <p class="contact-cta-card-text">
            Un bug, une suggestion ou une question sur l'application ?
            On lit tous les messages et on répond sous 48h.
          </p>

          <%# Lien discret en bas de la carte %>
          <span class="contact-cta-card-link">
            Nous écrire <i data-lucide="arrow-right" style="width:14px;height:14px;"></i>
          </span>

        <% end %>
      </div>

    </div>
  </div>
</section>
