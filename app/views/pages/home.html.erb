<%# Page d'accueil de Team Up %>

<div class="container my-5 text-center">

  <%# Section hero %>
  <h1 class="display-4 fw-bold mb-3">Bienvenue sur Team Up ⚽</h1>
  <p class="lead text-muted mb-4">
    Trouve des joueurs, organise des matchs, joue ensemble.
  </p>

  <%# Boutons d'appel à l'action %>
  <div class="d-flex justify-content-center gap-3 mb-5">
    <% if user_signed_in? %>
      <%= link_to "Voir les matchs", matches_path, class: "btn btn-primary btn-lg" %>
      <%= link_to "Créer un match", new_match_path, class: "btn btn-outline-primary btn-lg" %>
    <% else %>
      <%= link_to "Commencer", new_user_registration_path, class: "btn btn-primary btn-lg" %>
      <%= link_to "Se connecter", new_user_session_path, class: "btn btn-outline-primary btn-lg" %>
    <% end %>
  </div>

  <%# Section "Comment ça marche" %>
  <div class="row justify-content-center g-4">

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm p-3">
        <div class="card-body text-center">
          <div class="display-5 mb-3">📋</div>
          <h5 class="card-title">Crée un match</h5>
          <p class="card-text text-muted">Définis la date, le lieu, le niveau et le nombre de joueurs.</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm p-3">
        <div class="card-body text-center">
          <div class="display-5 mb-3">🤝</div>
          <h5 class="card-title">Rejoins un match</h5>
          <p class="card-text text-muted">Parcours les matchs disponibles et inscris-toi en un clic.</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm p-3">
        <div class="card-body text-center">
          <div class="display-5 mb-3">⚽</div>
          <h5 class="card-title">Joue !</h5>
          <p class="card-text text-muted">Retrouve tes coéquipiers sur le terrain et profite du match.</p>
        </div>
      </div>
    </div>

  </div>
</div>

<%# Section matchs à venir %>
<div class="container my-5">

  <%# Titre de section %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Matchs à venir</h2>
    <%= link_to matches_path, class: "btn btn-outline-primary d-flex align-items-center gap-1" do %>
      <i data-lucide="arrow-right" style="width:16px;height:16px;"></i> Voir plus
    <% end %>
  </div>

  <% if @matches.any? %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% @matches.each do |match| %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-body">

              <%# Ligne titre + badges %>
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0 me-2"><%= match.title %></h5>
                <div class="d-flex flex-wrap gap-1 justify-content-end">
                  <%# Badge "Urgent" si le match commence dans moins de 2h %>
                  <% if match.urgent? %>
                    <span class="badge bg-danger">🔥 Urgent</span>
                  <% end %>
                  <%
                    level_class = case match.level
                      when "Débutant"      then "bg-success"
                      when "Intermédiaire" then "bg-warning text-dark"
                      when "Avancé"        then "bg-danger"
                      else "bg-info text-dark"
                    end
                  %>
                  <span class="badge <%= level_class %>"><%= match.level %></span>
                </div>
              </div>

              <%# Description courte %>
              <p class="card-text text-muted small"><%= truncate(match.description, length: 80) %></p>

              <%# Infos clés du match %>
              <ul class="list-unstyled small mb-0">
                <li class="d-flex align-items-center gap-2 mb-1">
                  <i data-lucide="calendar" style="width:14px;height:14px;" class="text-muted"></i>
                  <%= match.date&.strftime("%d/%m/%Y") || "Date non définie" %>
                </li>
                <li class="d-flex align-items-center gap-2 mb-1">
                  <i data-lucide="clock" style="width:14px;height:14px;" class="text-muted"></i>
                  <%= match.time&.strftime("%H:%M") || "Heure non définie" %>
                </li>
                <li class="d-flex align-items-center gap-2 mb-1">
                  <i data-lucide="map-pin" style="width:14px;height:14px;" class="text-muted"></i>
                  <%= match.place || "Lieu non défini" %>
                </li>
                <%# Affiche "Complet" si plus aucune place %>
                <li class="d-flex align-items-center gap-2">
                  <i data-lucide="users" style="width:14px;height:14px;" class="text-muted"></i>
                  <% if match.full? %>
                    <span class="text-danger fw-semibold">Complet</span>
                  <% else %>
                    <%= match.player_left %> place(s) disponible(s)
                  <% end %>
                </li>
              </ul>

            </div>

            <%# Bouton voir le match %>
            <div class="card-footer bg-transparent">
              <%= link_to "Voir le match", match_path(match), class: "btn btn-outline-primary btn-sm w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <%# Aucun match disponible %>
    <div class="text-center text-muted py-5">
      <i data-lucide="calendar-x" style="width:48px;height:48px;"></i>
      <p class="mt-3">Aucun match disponible pour le moment.</p>
      <% if user_signed_in? %>
        <%= link_to "Créer le premier match", new_match_path, class: "btn btn-primary mt-2" %>
      <% end %>
    </div>
  <% end %>

</div>
