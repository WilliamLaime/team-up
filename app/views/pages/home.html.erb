<%# =====================================================
    PAGE D'ACCUEIL — Team Up
    4 sections : Hero / Matchs / Comment ça marche / CTA
    ===================================================== %>


<%# ══════════════════════════════════════════════════
    1. HERO — Section principale sombre
       Titre + description + CTA + image terrain
    ══════════════════════════════════════════════════ %>
<section class="hero-section">
  <div class="container">
    <div class="row align-items-center g-5">

      <%# ── Colonne gauche : texte ── %>
      <div class="col-lg-6">

        <%# Badge avec point animé %>
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <%= @matches.count %> match<%= @matches.count > 1 ? "s" : "" %> disponible<%= @matches.count > 1 ? "s" : "" %>
        </div>

        <%# Titre principal sur 2 lignes %>
        <h1 class="hero-title">
          Créer un match<br>
          <span class="hero-title-accent">en 30 secondes.</span>
        </h1>

        <%# Sous-titre %>
        <p class="hero-description">
          Le moyen le plus rapide pour compléter votre cinq ou rejoindre
          une équipe de passionnés. Plus d'excuses pour ne pas jouer.
        </p>

        <%# Boutons CTA :
            - Utilisateur connecté   → "Créer un match" (primaire) + "Voir les matchs" (secondaire)
            - Utilisateur non connecté → "Créer un match" (primaire) → redirige vers inscription
        %>
        <div class="d-flex flex-wrap gap-3">
          <% if user_signed_in? %>
            <%# Bouton primaire → création d'un match %>
            <%= render "shared/btn_primary", url: new_match_path, text: "Créer un match" %>
            <%# Bouton secondaire → liste des matchs %>
            <%= render "shared/btn_secondary", url: matches_path, text: "Voir les matchs" %>
          <% else %>
            <%# Bouton primaire → inscription (utilisateur non connecté) %>
            <%= render "shared/btn_primary", url: new_user_registration_path, text: "Créer un match" %>
            <%# Bouton secondaire → liste des matchs %>
            <%= render "shared/btn_secondary", url: matches_path, text: "Voir les matchs" %>
          <% end %>
        </div>

      </div>

      <%# ── Colonne droite : image + overlay ── %>
      <div class="col-lg-6 d-none d-lg-block">
        <div class="hero-image-wrapper">

          <%# Image de terrain (placeholder sportif) %>
          <img
            src="https://images.unsplash.com/photo-1529900748604-07564a03e7a6?w=700&q=80"
            alt="Terrain de sport"
            class="hero-img"
          >

          <%# Carte overlay : affiche le prochain match disponible (jamais complet)
              @hero_match est calculé dans le controller — exclut les matchs full? %>
          <% if @hero_match %>
            <%# Le lien englobe toute la carte pour la rendre cliquable %>
            <%= link_to match_path(@hero_match), class: "hero-match-card" do %>

              <%# Ligne haute : icône ronde + label + titre %>
              <div class="d-flex align-items-center gap-3">
                <%# Icône orange avec éclair %>
                <div class="hero-match-icon">
                  <i data-lucide="zap" style="width:18px;height:18px;"></i>
                </div>
                <%# Infos principales %>
                <div class="flex-grow-1 overflow-hidden">
                  <div class="hero-match-label">
                    <%= @hero_match.urgent? ? "Match Urgent" : @hero_match.level %>
                  </div>
                  <div class="hero-match-title"><%= @hero_match.title %></div>
                </div>
              </div>

              <%# Ligne basse : heure à gauche, places restantes à droite %>
              <div class="d-flex justify-content-between align-items-center hero-match-footer">
                <span class="hero-match-time">
                  <%= @hero_match.time&.strftime('%H:%M') %> · Ce soir
                </span>
                <%# Toujours des places dispo (jamais complet grâce au controller) %>
                <span class="hero-match-spots">
                  <%= @hero_match.player_left %> place<%= @hero_match.player_left > 1 ? "s" : "" %>
                </span>
              </div>

            <% end %>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</section>


<%# ══════════════════════════════════════════════════
    2. MATCHS À PROXIMITÉ — Section claire
       Affiche les 3 prochains matchs de la BDD
    ══════════════════════════════════════════════════ %>
<section class="matches-section">
  <div class="container">

    <%# En-tête de section %>
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <h2 class="matches-section-title">Matchs à proximité</h2>
        <p class="matches-section-subtitle mb-0">
          Les prochaines séances disponibles près de vous.
        </p>
      </div>
      <%= render "shared/nav_button", url: matches_path, label: "Tout voir", direction: "forward", extra_class: "mt-1" %>
    </div>

    <% if @matches.any? %>
      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% @matches.each do |match| %>
          <div class="col">
            <%# Utilise le composant partagé — btn_label "Voir le match" pour la home %>
            <%= render "shared/match_card", match: match, btn_label: "Voir le match" %>
          </div>
        <% end %>
      </div>

    <% else %>
      <%# Aucun match disponible %>
      <div class="matches-empty">
        <i data-lucide="calendar-x" style="width:40px;height:40px;color:#ccc;"></i>
        <p class="mt-3 mb-2">Aucun match disponible pour le moment.</p>
        <% if user_signed_in? %>
          <%= link_to "Créer le premier match", new_match_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>

  </div>
</section>


<%# ══════════════════════════════════════════════════
    3. COMMENT ÇA MARCHE — Section claire
       3 étapes : Propose / Notifie / Équipe complète
    ══════════════════════════════════════════════════ %>
<section class="how-it-works-section" id="how-it-works">
  <div class="container">

    <h2 class="hiw-title">Jouez plus, organisez moins.</h2>
    <p class="hiw-subtitle">
      Team-Up simplifie la logistique pour que vous restiez concentré sur le terrain.
    </p>

    <div class="row justify-content-center g-4">

      <%# Étape 1 : Proposer un match %>
      <div class="col-md-4">
        <div class="hiw-item">
          <div class="hiw-icon-circle">
            <i data-lucide="calendar-plus" style="width:26px;height:26px;"></i>
          </div>
          <div class="hiw-item-title">Propose un match</div>
          <p class="hiw-item-text">
            Indique l'heure, le lieu et le nombre de joueurs souhaités en moins d'une minute, sans solution.
          </p>
        </div>
      </div>

      <%# Étape 2 : On notifie les joueurs %>
      <div class="col-md-4">
        <div class="hiw-item">
          <div class="hiw-icon-circle">
            <i data-lucide="bell-ring" style="width:26px;height:26px;"></i>
          </div>
          <div class="hiw-item-title">On notifie les joueurs</div>
          <p class="hiw-item-text">
            Notre algorithme alerte les joueurs disponibles à proximité automatiquement.
          </p>
        </div>
      </div>

      <%# Étape 3 : Équipe complète %>
      <div class="col-md-4">
        <div class="hiw-item">
          <div class="hiw-icon-circle">
            <i data-lucide="check-circle-2" style="width:26px;height:26px;"></i>
          </div>
          <div class="hiw-item-title">Ton équipe est complète</div>
          <p class="hiw-item-text">
            Reçois une notification dès que ton match est plein et retrouve tes coéquipiers sur le terrain.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>


<%# ══════════════════════════════════════════════════
    4. CTA SOMBRE — "Dites adieu aux groupes WhatsApp"
       Section sombre avec mockup de conversation
    ══════════════════════════════════════════════════ %>
<section class="cta-section">
  <div class="container">
    <div class="row align-items-center g-5">

      <%# ── Colonne gauche : texte + liste ── %>
      <div class="col-lg-6">

        <h2 class="cta-title">
          Dites adieu aux groupes whatsApp <span class="cta-title-accent">bordéliques.</span>
        </h2>

        <p class="cta-description">
          Gérez tout au même endroit : validation des joueurs, sécurité,
          et bien plus. Plus de déplacements à la dernière minute sans solution.
        </p>

        <%# Liste des avantages avec coches vertes %>
        <ul class="cta-feature-list">
          <li>
            <span class="cta-check">
              <i data-lucide="check" style="width:11px;height:11px;"></i>
            </span>
            Canal de discussion privé par match
          </li>
          <li>
            <span class="cta-check">
              <i data-lucide="check" style="width:11px;height:11px;"></i>
            </span>
            Partage de localisation rapide
          </li>
          <li>
            <span class="cta-check">
              <i data-lucide="check" style="width:11px;height:11px;"></i>
            </span>
            Notifications push pour les messages importants
          </li>
        </ul>
      </div>

      <%# ── Colonne droite : mockup de chat ── %>
      <div class="col-lg-6 d-flex justify-content-center">
        <div class="cta-chat-mockup">

          <%# En-tête du groupe %>
          <div class="chat-header">
            <div class="chat-group-icon">
              <i data-lucide="users" style="width:18px;height:18px;"></i>
            </div>
            <div>
              <div class="chat-group-name">Groupe Match #405</div>
              <%# "TEAM COMPLÈTE" en vert via text-primary %>
              <div class="chat-group-sub text-primary fw-bold" style="font-size:0.72rem;letter-spacing:0.05em;">TEAM COMPLÈTE</div>
            </div>
          </div>

          <%# Messages fictifs — les messages entrants ont un avatar à gauche %>

          <%# Message entrant d'Alex avec son avatar %>
          <div class="chat-message-row">
            <%# Avatar en 56px affiché à 28px → résolution 2× propre %>
            <img src="https://i.pravatar.cc/56?img=11" class="chat-avatar" alt="Alex">
            <div class="chat-message-col">
              <%# Prénom au-dessus de la bulle, en gris discret %>
              <span class="chat-sender-name">Alex</span>
              <div class="chat-message incoming">
                <span class="msg-text">On est 9, il manque encore quelqu'un pour demain ?</span>
                <span class="msg-time">18:42</span>
              </div>
            </div>
          </div>

          <div class="chat-message notification">
            ✅ Un nouveau joueur a rejoint le match !
          </div>

          <%# Message entrant de Julie avec son avatar %>
          <div class="chat-message-row">
            <%# Avatar en 56px affiché à 28px → résolution 2× propre %>
            <img src="https://i.pravatar.cc/56?img=47" class="chat-avatar" alt="Julie">
            <div class="chat-message-col">
              <%# Prénom au-dessus de la bulle, en gris discret %>
              <span class="chat-sender-name">Julie</span>
              <div class="chat-message incoming">
                <span class="msg-text">C'est à quelle heure le terrain ?</span>
                <span class="msg-time">18:55</span>
              </div>
            </div>
          </div>

          <%# Message sortant (pas d'avatar, c'est "moi") %>
          <div class="chat-message outgoing">
            <span class="msg-text">On se retrouve à 19h devant le terrain 🤝</span>
            <span class="msg-time">19:00</span>
          </div>

          <div class="chat-message notification">
            🏆 Ton équipe est complète — bonne chance !
          </div>

          <%# Faux champ de saisie — purement décoratif, non fonctionnel %>
          <div class="chat-input-bar">
            <span class="chat-input-placeholder">Écrire un message...</span>
            <button class="chat-send-btn" disabled aria-label="Envoyer">
              <i data-lucide="send" style="width:15px;height:15px;"></i>
            </button>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
