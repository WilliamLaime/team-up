<%# =====================================================
    PAGE CONTACT
    Route : GET /contact
    Page publique — accessible sans connexion
    ===================================================== %>

<div class="contact-page">

  <%# ── Bannière hero ───────────────────────────────── %>
  <section class="contact-banner">
    <div class="container">
      <h1 class="contact-banner-title">Contact</h1>
      <p class="contact-banner-subtitle">
        Une question, une suggestion ou un bug à signaler ?<br>
        On est là pour t'écouter.
      </p>
    </div>
  </section>

  <%# ── Section principale : formulaire + infos ──────── %>
  <section class="contact-main">
    <div class="container">
      <div class="row justify-content-center g-5">

        <%# ── Colonne gauche : infos de contact ── %>
        <div class="col-md-4">
          <h2 class="contact-section-title">Nous contacter</h2>

          <%# Carte email %>
          <div class="contact-info-card">
            <%# Icône Lucide mail %>
            <i data-lucide="mail" class="contact-info-icon"></i>
            <div>
              <p class="contact-info-label">Email</p>
              <p class="contact-info-value">contact@team-up.fr</p>
            </div>
          </div>

          <%# Carte réseaux sociaux %>
          <div class="contact-info-card">
            <%# Icône Lucide users %>
            <i data-lucide="users" class="contact-info-icon"></i>
            <div>
              <p class="contact-info-label">Réseaux sociaux</p>
              <%# Liens vers les réseaux — "#" en attendant les vraies URLs %>
              <div class="contact-social">
                <a href="#" aria-label="Instagram" class="contact-social-link">
                  <i class="fa-brands fa-instagram"></i>
                </a>
                <a href="#" aria-label="TikTok" class="contact-social-link">
                  <i class="fa-brands fa-tiktok"></i>
                </a>
                <a href="#" aria-label="YouTube" class="contact-social-link">
                  <i class="fa-brands fa-youtube"></i>
                </a>
              </div>
            </div>
          </div>

          <%# Carte délai de réponse %>
          <div class="contact-info-card">
            <%# Icône Lucide clock %>
            <i data-lucide="clock" class="contact-info-icon"></i>
            <div>
              <p class="contact-info-label">Délai de réponse</p>
              <p class="contact-info-value">Sous 48h en semaine</p>
            </div>
          </div>
        </div>

        <%# ── Colonne droite : formulaire de contact ── %>
        <div class="col-md-7">
          <h2 class="contact-section-title">Envoyer un message</h2>

          <%# Formulaire connecté au backend via form_with %>
          <%# model: @contact_message → Rails connaît la route (POST /contact) et gère le CSRF token %>
          <%= form_with model: @contact_message, url: contact_path,
                        local: true, class: "contact-form" do |f| %>

            <%# Affiche les erreurs de validation si le formulaire a été resoumis avec des erreurs %>
            <% if @contact_message.errors.any? %>
              <div class="alert alert-danger mb-3" role="alert">
                <strong>Corrige les erreurs suivantes :</strong>
                <ul class="mb-0 mt-1">
                  <% @contact_message.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <%# Ligne prénom + nom %>
            <div class="row g-3 mb-3">
              <div class="col-sm-6">
                <%# f.label génère un <label> lié au champ :prenom %>
                <%= f.label :prenom, class: "contact-label" do %>
                  Prénom <span class="contact-required">*</span>
                <% end %>
                <%= f.text_field :prenom, class: "contact-input", placeholder: "Ton prénom", required: true, autocomplete: "given-name" %>
              </div>
              <div class="col-sm-6">
                <%= f.label :nom, class: "contact-label" do %>
                  Nom <span class="contact-required">*</span>
                <% end %>
                <%= f.text_field :nom, class: "contact-input", placeholder: "Ton nom", required: true, autocomplete: "family-name" %>
              </div>
            </div>

            <%# Email %>
            <div class="mb-3">
              <%= f.label :email, class: "contact-label" do %>
                Email <span class="contact-required">*</span>
              <% end %>
              <%# is-invalid : ajoute un contour rouge Bootstrap si la validation échoue %>
              <%= f.email_field :email,
                    class: "contact-input #{"is-invalid" if @contact_message.errors[:email].any?}",
                    placeholder: "ton@email.com",
                    required: true,
                    autocomplete: "email" %>
              <%# Message d'erreur affiché directement sous le champ %>
              <% if @contact_message.errors[:email].any? %>
                <div class="invalid-feedback d-block">
                  <%= @contact_message.errors[:email].first %>
                </div>
              <% end %>
            </div>

            <%# Sujet %>
            <div class="mb-3">
              <%= f.label :sujet, class: "contact-label" do %>
                Sujet <span class="contact-required">*</span>
              <% end %>
              <%= f.text_field :sujet, class: "contact-input", placeholder: "De quoi s'agit-il ?", required: true %>
            </div>

            <%# Message %>
            <div class="mb-4">
              <%= f.label :message, class: "contact-label" do %>
                Message <span class="contact-required">*</span>
              <% end %>
              <%= f.text_area :message, class: "contact-input contact-textarea",
                             placeholder: "Ton message…", rows: 5, required: true %>
            </div>

            <%# Légende champs obligatoires %>
            <p class="contact-required-legend"><span class="contact-required">*</span> Champs obligatoires</p>

            <%# Bouton d'envoi %>
            <%= f.submit "Envoyer le message", class: "btn btn-primary btn-lg px-4 btn-cta-primary" %>

          <% end %>
        </div>

      </div>
    </div>
  </section>

</div>
