<%# ── Formulaire création / édition d'une équipe ─────────────────────────── %>
<%# Partagé entre new.html.erb et edit.html.erb %>

<%= form_with model: @team,
    data: { controller: "badge-builder" },
    html: { enctype: "multipart/form-data" } do |f| %>

  <%# Affiche les erreurs de validation %>
  <% if @team.errors.any? %>
    <div class="alert alert-danger mb-3">
      <% @team.errors.full_messages.each do |msg| %>
        <p class="mb-0"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="row g-4">

    <%# ── Colonne gauche : infos de l'équipe + image de couverture ───────── %>
    <div class="col-12 col-lg-7">
      <div class="team-section-card">
        <h2 class="team-section-title">Informations</h2>

        <%# Nom de l'équipe %>
        <div class="mb-3">
          <%= f.label :name, "Nom de l'équipe *", class: "form-label text-white-50" %>
          <%= f.text_field :name,
              class: "form-control form-control-dark",
              placeholder: "Les Invincibles…",
              maxlength: 50,
              required: true %>
        </div>

        <%# Description %>
        <div class="mb-3">
          <%= f.label :description, "Description (optionnelle)", class: "form-label text-white-50" %>
          <%= f.text_area :description,
              class: "form-control form-control-dark",
              placeholder: "Présente ton équipe en quelques mots…",
              rows: 3 %>
        </div>
      </div>

      <%# ── Image de couverture ──────────────────────────────────────────────── %>
      <%#
        Le data-controller="cover-position" gère :
          • Le drag de l'image existante pour recadrer (posX, posY)
          • Le slider de zoom (transform: scale)
          • L'aperçu live quand un nouveau fichier est sélectionné (FileReader)
        Les deux valeurs finales sont stockées dans les champs cachés
        cover_position ("X% Y%") et cover_zoom (float).
      %>
      <div class="team-section-card mt-3"
           data-controller="cover-position"
           data-cover-position-initial-value="<%= f.object.cover_position.presence || '50% 50%' %>"
           data-cover-position-initial-zoom-value="<%= f.object.cover_zoom || 1.0 %>">

        <h2 class="team-section-title">
          <i data-lucide="image" style="width:16px;height:16px;margin-right:6px;"></i>
          Image de couverture
        </h2>

        <%#
          Aperçu interactif — toujours rendu dans le DOM pour que le controller
          puisse y injecter la preview d'un nouveau fichier via FileReader.
          On ne l'affiche que si une image est déjà attachée (ou sera affichée
          dynamiquement par le controller après sélection du fichier).
        %>
        <div class="cover-position-preview"
             data-cover-position-target="preview"
             style="position:relative; width:100%; height:140px; border-radius:10px; overflow:hidden;
                    border:1px solid var(--theme-border); cursor:grab; user-select:none;
                    <%= f.object.cover_image.attached? && f.object.cover_image.blob&.persisted? ? '' : 'display:none;' %>">

          <% if f.object.cover_image.attached? && f.object.cover_image.blob&.persisted? %>
            <%# Image déjà enregistrée : affichée avec position et zoom existants %>
            <%= image_tag f.object.cover_image,
                  alt: "Couverture de l'équipe",
                  data: { "cover-position-target": "image" },
                  style: "width:100%; height:100%; object-fit:cover; display:block;
                          object-position:#{f.object.cover_position.presence || '50% 50%'};
                          transform:scale(#{f.object.cover_zoom || 1.0});
                          transform-origin:#{f.object.cover_position.presence || '50% 50%'};" %>
          <% else %>
            <%# Pas d'image sauvegardée : balise img vide, remplie par le FileReader %>
            <img data-cover-position-target="image" alt=""
                 style="width:100%; height:100%; object-fit:cover; display:none;">
          <% end %>

          <%# Indication de repositionnement par-dessus l'image %>
          <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; pointer-events:none;">
            <span style="background:rgba(0,0,0,0.45); color:#fff; font-size:0.72rem; font-weight:600;
                         padding:0.25rem 0.65rem; border-radius:20px; letter-spacing:0.03em;">
              <i data-lucide="move" style="width:10px;height:10px;margin-right:4px;"></i>
              Glissez pour recadrer
            </span>
          </div>
        </div>

        <%# Slider de zoom — affiché dès qu'une image est présente %>
        <div class="cover-zoom-row"
             data-cover-position-target="zoomRow"
             style="<%= f.object.cover_image.attached? && f.object.cover_image.blob&.persisted? ? '' : 'display:none;' %>">
          <i data-lucide="zoom-in" style="width:14px;height:14px;color:var(--theme-text-muted);flex-shrink:0;"></i>
          <input type="range"
                 class="cover-zoom-slider"
                 min="1" max="2" step="0.05"
                 value="<%= f.object.cover_zoom || 1.0 %>"
                 data-cover-position-target="zoomSlider"
                 data-action="input->cover-position#updateZoom">
          <span class="cover-zoom-value" data-cover-position-target="zoomValue">
            <%= (f.object.cover_zoom || 1.0).round(1) %>×
          </span>
        </div>

        <%# Champs cachés soumis avec le formulaire %>
        <%= f.hidden_field :cover_position,
            value: f.object.cover_position.presence || "50% 50%",
            data: { "cover-position-target": "positionInput" } %>
        <%= f.hidden_field :cover_zoom,
            value: f.object.cover_zoom || 1.0,
            data: { "cover-position-target": "zoomInput" } %>

        <%# Input file : déclenche l'aperçu live via cover-position#previewFile %>
        <%= f.file_field :cover_image,
            class: "form-control form-control-dark mt-3",
            accept: "image/jpeg,image/png,image/webp",
            data: {
              "cover-position-target": "fileField",
              action: "change->cover-position#previewFile"
            } %>
        <p style="font-size:0.75rem; color:var(--theme-text-muted); margin-top:0.4rem;">
          JPG, PNG ou WebP · max 5 Mo · recommandé : 1200×300 px
        </p>

      </div>

      <%# CTA juste sous la card image de couverture, même gap que entre les blocs %>
      <div class="d-flex gap-3 mt-4">
        <%= f.submit f.object.persisted? ? "Enregistrer les modifications" : "Créer l'équipe",
            class: "btn btn-primary btn-cta-primary px-4" %>
        <%= link_to "Annuler", f.object.persisted? ? f.object : teams_path, class: "btn btn-outline-light" %>
      </div>
    </div>

    <%# ── Colonne droite : blason — align-self-start pour rester en haut ─── %>
    <div class="col-12 col-lg-5 align-self-start">
      <div class="team-section-card">
        <h2 class="team-section-title">Blason</h2>

        <%# ── Générateur de blason SVG ─────────────────────────────────────── %>
        <div>

          <%# Aperçu SVG live — centré, plus grand %>
          <div style="display:flex; justify-content:center; margin-bottom:1.25rem;">
            <div class="badge-preview" data-badge-builder-target="preview"
                 style="width:110px; height:110px;">
            </div>
          </div>

          <%# ── 1. Forme du fond ─────────────────────────────────────────── %>
          <div class="mb-3">
            <label class="badge-builder-label">Forme</label>
            <div class="badge-shapes">
              <%#
                Chaque bouton affiche un mini SVG de la forme.
                data-shape est lu par le controller pour générer le bon clipPath.
              %>
              <% [
                { key: "shield",   label: "Bouclier",  path: "M50,3 L92,18 L92,58 C92,78 72,92 50,98 C28,92 8,78 8,58 L8,18 Z" },
                { key: "hexagon",  label: "Hexagone",  path: "M50,5 L93,28 L93,72 L50,95 L7,72 L7,28 Z" },
                { key: "circle",   label: "Cercle",    path: nil },
                { key: "diamond",  label: "Diamant",   path: "M50,3 L97,50 L50,97 L3,50 Z" },
                { key: "pentagon", label: "Pentagone", path: "M50,5 L97,36 L79,92 L21,92 L3,36 Z" }
              ].each_with_index do |shape, i| %>
                <%# RGAA 11.9 — aria-label pour nommer le bouton ; RGAA 4.8 — SVG décoratif masqué %>
                <button type="button"
                        class="badge-shape-btn <%= i == 0 ? 'active' : '' %>"
                        aria-label="<%= shape[:label] %>"
                        data-shape="<%= shape[:key] %>"
                        data-action="click->badge-builder#selectShape">
                  <svg viewBox="0 0 100 100" width="34" height="34" aria-hidden="true">
                    <% if shape[:path] %>
                      <path d="<%= shape[:path] %>" fill="rgba(255,255,255,0.25)" stroke="rgba(255,255,255,0.5)" stroke-width="3"/>
                    <% else %>
                      <circle cx="50" cy="50" r="46" fill="rgba(255,255,255,0.25)" stroke="rgba(255,255,255,0.5)" stroke-width="3"/>
                    <% end %>
                  </svg>
                </button>
              <% end %>
            </div>
          </div>

          <%# ── 2. Couleur du fond ───────────────────────────────────────── %>
          <div class="mb-3">
            <label class="badge-builder-label">Couleur</label>
            <div class="badge-colors">
              <% %w[
                #1EDD88 #2ED573 #26de81 #0be881
                #FF4757 #FF6348 #FFA502 #ECCC68
                #3742FA #2980b9 #A29BFE #a55eea
                #ffffff #b2bec3 #2d3436 #000000
              ].each_with_index do |color, i| %>
                <button type="button"
                        class="badge-color-swatch <%= i == 0 ? 'active' : '' %>"
                        style="background:<%= color %>; <%= color == '#ffffff' ? 'border:1px solid rgba(255,255,255,0.2);' : '' %>"
                        data-color="<%= color %>"
                        data-action="click->badge-builder#selectColor">
                </button>
              <% end %>
            </div>
          </div>

          <%# ── 3. Symbole ───────────────────────────────────────────────── %>
          <div class="mb-3">
            <label class="badge-builder-label">Symbole</label>

            <%# Catégorie Sport %>
            <div style="font-size:0.68rem; color:var(--theme-text-muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.3rem;">Sport</div>
            <div class="badge-icons mb-2">
              <% %w[⚽ 🏀 🏈 🎾 🏐 🥊 🏒 🏹].each do |emoji| %>
                <button type="button"
                        class="badge-icon-btn"
                        data-icon-emoji="<%= emoji %>"
                        data-action="click->badge-builder#selectIcon">
                  <%= emoji %>
                </button>
              <% end %>
            </div>

            <%# Catégorie Puissance %>
            <div style="font-size:0.68rem; color:var(--theme-text-muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.3rem;">Puissance</div>
            <div class="badge-icons mb-2">
              <% %w[⚡ 🔥 💥 🌊 🌪️ ❄️ ☄️ 🌟].each do |emoji| %>
                <button type="button"
                        class="badge-icon-btn"
                        data-icon-emoji="<%= emoji %>"
                        data-action="click->badge-builder#selectIcon">
                  <%= emoji %>
                </button>
              <% end %>
            </div>

            <%# Catégorie Prestige %>
            <div style="font-size:0.68rem; color:var(--theme-text-muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.3rem;">Prestige</div>
            <div class="badge-icons">
              <% %w[👑 🏆 🛡️ ⚔️ 🦁 🦅 🐺 🔱].each do |emoji| %>
                <button type="button"
                        class="badge-icon-btn"
                        data-icon-emoji="<%= emoji %>"
                        data-action="click->badge-builder#selectIcon">
                  <%= emoji %>
                </button>
              <% end %>
            </div>
          </div>

          <%# ── 4. Logo personnalisé avec slider de taille ────────────────── %>
          <%#
            Permet d'uploader une image qui remplace l'emoji dans le blason.
            Le slider permet de régler la taille du logo dans la forme (30% à 110%).
            Le slider n'est affiché qu'une fois un logo sélectionné.
          %>
          <div class="mb-3">
            <label class="badge-builder-label">Logo personnalisé (optionnel)</label>
            <input type="file"
                   class="form-control form-control-dark"
                   accept="image/jpeg,image/png,image/webp,image/svg+xml"
                   data-badge-builder-target="logoInput"
                   data-action="change->badge-builder#selectLogo"
                   style="font-size:0.78rem;">
            <p style="font-size:0.72rem; color:var(--theme-text-muted); margin-top:0.25rem;">
              PNG, JPG, WebP ou SVG — remplace l'emoji dans le blason
            </p>

            <%# Slider de taille du logo — affiché dynamiquement par le controller %>
            <div class="logo-scale-row"
                 data-badge-builder-target="logoControls"
                 style="display:none;">
              <i data-lucide="scaling" style="width:14px;height:14px;color:var(--theme-text-muted);flex-shrink:0;"></i>
              <input type="range"
                     class="cover-zoom-slider"
                     min="0.3" max="1.1" step="0.05"
                     value="0.7"
                     data-badge-builder-target="logoSlider"
                     data-action="input->badge-builder#updateLogoScale">
              <span class="cover-zoom-value" data-badge-builder-target="logoScaleDisplay">70%</span>
            </div>

            <%# Bouton pour effacer le logo et revenir aux emojis %>
            <button type="button"
                    class="badge-tab"
                    style="margin-top:0.3rem; font-size:0.72rem; padding:0.2rem 0.6rem;"
                    data-action="click->badge-builder#clearLogo">
              <i data-lucide="x" style="width:10px;height:10px;margin-right:3px;"></i>
              Effacer le logo
            </button>
          </div>

          <%# Champ caché : contient le SVG final généré côté client %>
          <%= f.hidden_field :badge_svg, data: { badge_builder_target: "svgInput" } %>

        </div><%# fin panelGenerator %>

      </div><%# fin team-section-card blason %>
    </div>

  </div><%# fin row %>

<% end %>
