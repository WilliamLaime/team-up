<%# ── Page détail d'une équipe ─────────────────────────────────────────────── %>

<div class="teams-page">
<div class="container py-4">
  <%= render "shared/nav_button", url: teams_path, label: "Mes équipes", direction: "back", extra_class: "mb-3" %>

  <%# ── Bannière + header fusionnés — le contenu est par-dessus l'image ────── %>
  <div class="team-cover-section">

    <%# Image de fond (absolute, derrière tout).
        object-position applique le cadrage défini par le captain dans le formulaire. %>
    <% if @team.cover_image.attached? %>
      <%# object-position = recadrage sauvegardé ; transform scale = zoom sauvegardé %>
      <%= image_tag @team.cover_image, alt: "", class: "team-cover-bg",
          style: "object-position: #{@team.cover_position.presence || '50% 50%'};
                  transform: scale(#{@team.cover_zoom || 1.0});
                  transform-origin: #{@team.cover_position.presence || '50% 50%'};" %>
    <% else %>
      <%= image_tag "banniere_fond_equipe.png", alt: "", class: "team-cover-bg" %>
    <% end %>
    <%# Overlay sombre pour lisibilité %>
    <div class="team-cover-overlay"></div>

    <%# ── En-tête équipe (par-dessus la bannière) ─────────────────────────── %>
    <div class="team-show-header">

    <%# Blason — priorité : SVG généré > image uploadée > placeholder
        Même logique que la carte : le SVG du badge builder prime toujours. %>
    <div class="team-show-badge">
      <% if @team.badge_svg.present? %>
        <%# SVG généré par le badge builder — rendu inline en sécurité %>
        <div class="team-show-badge-svg"><%= @team.badge_svg.html_safe %></div>
      <% elsif @team.badge_image.attached? %>
        <%# Fallback : image uploadée directement (ancienne version) %>
        <%= image_tag @team.badge_image, alt: "Blason #{@team.name}", class: "team-show-badge-img" %>
      <% else %>
        <div class="team-show-badge-placeholder">
          <i data-lucide="shield" style="width:48px;height:48px;color:var(--theme-text-muted);"></i>
        </div>
      <% end %>
    </div>

    <div class="team-show-info">
      <h1 class="team-show-name"><%= @team.name %></h1>
      <p class="team-show-meta">
        <i data-lucide="users" style="width:13px;height:13px;"></i>
        <%= @team.members_count %> membre<%= @team.members_count > 1 ? "s" : "" %>
        &nbsp;·&nbsp;
        Capitaine :
        <%= link_to user_profil_path(@team.captain),
              style: "color:inherit; font-weight:600;",
              data: { turbo_frame: "_top" } do %>
          <%= @team.captain.profil&.first_name %>
        <% end %>
      </p>
      <% if @team.description.present? %>
        <p class="team-show-description"><%= @team.description %></p>
      <% end %>
    </div>

    <%# Actions captain %>
    <% if @team.captain?(current_user) %>
      <div class="team-show-actions">
        <%# Créer un match directement depuis la bannière %>
        <%= link_to new_match_path(team_id: @team.id),
              class: "btn btn-sm btn-primary btn-cta-primary rounded-pill",
              data: { turbo_frame: "_top" } do %>
          Créer un match
        <% end %>

        <%= link_to edit_team_path(@team), class: "team-banner-btn team-banner-btn--edit" do %>
          <i data-lucide="settings" style="width:13px;height:13px;"></i>
          Modifier
        <% end %>

        <%# Supprimer — icône seule pour ne pas surcharger la bannière %>
        <%= button_to team_path(@team), method: :delete,
            class: "team-banner-btn team-banner-btn--delete",
            title: "Supprimer l'équipe",
            data: { confirm: "Supprimer l'équipe \"#{@team.name}\" ? Cette action est irréversible." } do %>
          <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
        <% end %>
      </div>
    <% elsif policy(@team).leave? %>
      <%# Bouton Quitter — ouvre une modale de confirmation %>
      <button type="button"
              class="btn btn-sm btn-outline-danger rounded-pill"
              data-bs-toggle="modal"
              data-bs-target="#leaveTeamModal">
        <i data-lucide="log-out" style="width:13px;height:13px;margin-right:4px;"></i>
        Quitter l'équipe
      </button>

      <%# Modale hissée via content_for pour éviter les conflits CSS %>
      <% content_for :modals do %>
        <div class="modal fade" id="leaveTeamModal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content" style="background:var(--theme-bg-card); border:1px solid var(--theme-border); border-radius:12px;">

              <div class="modal-body text-center" style="padding:1.5rem 1.5rem 1rem;">
                <div style="font-size:2rem; margin-bottom:0.75rem;">🚪</div>
                <p style="color:var(--theme-text-strong); font-weight:700; font-size:0.95rem; margin-bottom:0.3rem;">
                  Quitter <%= @team.name %> ?
                </p>
                <p style="color:var(--theme-text-muted); font-size:0.8rem; margin:0;">
                  Tu perdras accès au chat et aux matchs de l'équipe.
                </p>
              </div>

              <div class="modal-footer" style="border-top:1px solid var(--theme-border); padding:0.75rem 1.5rem; gap:0.5rem; justify-content:center;">
                <%# Annuler %>
                <button type="button"
                        data-bs-dismiss="modal"
                        style="font-size:0.8rem; font-weight:600; color:var(--theme-text-muted);
                               background:var(--theme-hover-bg); border:1px solid var(--theme-border);
                               border-radius:20px; padding:0.4rem 1rem; cursor:pointer;">
                  Annuler
                </button>
                <%# Confirmer — soumet la requête DELETE %>
                <%= button_to leave_team_path(@team), method: :delete,
                      style: "font-size:0.8rem; font-weight:700; color:#fff;
                              background:rgba(220,53,69,0.8); border:1px solid rgba(220,53,69,0.5);
                              border-radius:20px; padding:0.4rem 1rem; cursor:pointer;" do %>
                  Quitter
                <% end %>
              </div>

            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div><%# fin team-show-header %>
  </div><%# fin team-cover-section %>

  <%# ── Bannière d'invitation (visible uniquement si l'user a une invitation en attente) ── %>
  <% if @my_invitation %>
    <div class="team-invitation-card mb-3">
      <div class="team-invitation-card-body">
        <p style="font-size:0.9rem;margin:0;color:var(--theme-text-primary);">
          <i data-lucide="mail" style="width:14px;height:14px;margin-right:6px;"></i>
          <strong><%= @my_invitation.inviter.profil&.first_name %></strong>
          t'invite à rejoindre cette équipe.
        </p>
      </div>
      <div class="team-invitation-card-actions">
        <%# Accepter %>
        <%= button_to team_team_invitation_path(@team, @my_invitation),
            method: :patch,
            params: { status: "accepted" },
            class: "btn btn-primary btn-cta-primary" do %>
          <i data-lucide="check" style="width:12px;height:12px;margin-right:4px;"></i>
          Rejoindre
        <% end %>
        <%# Refuser %>
        <%= button_to team_team_invitation_path(@team, @my_invitation),
            method: :patch,
            params: { status: "refused" },
            class: "btn btn-sm btn-outline-danger" do %>
          <i data-lucide="x" style="width:12px;height:12px;margin-right:4px;"></i>
          Refuser
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="row g-4 mt-2">

    <%# ── Colonne membres ──────────────────────────────────────────────────── %>
    <div class="col-12 col-lg-7">
      <div class="team-section-card">
        <h2 class="team-section-title">
          <i data-lucide="users" style="width:16px;height:16px;margin-right:6px;"></i>
          Membres
        </h2>

        <% if @team_members.any? %>
          <%# Grille de cartes — 3 colonnes desktop, 2 tablette, 1 mobile %>
          <div class="team-members-grid">
            <% @team_members.each do |tm| %>
              <%# Bordure colorée selon le rôle : or pour capitaine, subtile pour membre %>
              <%# Bordure selon le rang XP du joueur (bronze/silver/gold/platinum/emerald) %>
              <% rank_class = "rank-#{tm.user.rank}" %>
              <div class="team-member-card <%= rank_class %>">

                <%# Actions capitaine (coin haut droit) — visibles uniquement pour le captain %>
                <% if @team.captain?(current_user) && !tm.captain? %>
                  <% modal_id = "transferCapitanModal#{tm.user_id}" %>
                  <div class="team-member-card-actions">
                    <%# Bouton transférer le capitanat %>
                    <button type="button"
                            class="btn btn-xs btn-outline-light"
                            data-bs-toggle="modal"
                            data-bs-target="#<%= modal_id %>"
                            title="Transférer le capitanat">
                      <i data-lucide="star" style="width:10px;height:10px;"></i>
                    </button>
                    <%# Bouton retirer le membre %>
                    <%= button_to team_team_member_path(@team, tm),
                          method: :delete,
                          class: "btn btn-xs btn-outline-danger",
                          title: "Retirer",
                          data: { confirm: "Retirer #{tm.user.profil&.first_name} de l'équipe ?" } do %>
                      <i data-lucide="user-minus" style="width:10px;height:10px;"></i>
                    <% end %>
                  </div>

                  <%# Modale de confirmation transfert capitanat — hissée via content_for %>
                  <% content_for :modals do %>
                    <div class="modal fade" id="<%= modal_id %>" tabindex="-1" aria-hidden="true">
                      <div class="modal-dialog modal-dialog-centered modal-sm">
                        <div class="modal-content" style="background:var(--theme-bg-card); border:1px solid var(--theme-border); border-radius:12px;">
                          <div class="modal-body text-center" style="padding:1.5rem 1.5rem 1rem;">
                            <div style="font-size:2rem; margin-bottom:0.75rem;">⚡</div>
                            <p style="color:var(--theme-text-strong); font-weight:700; font-size:0.95rem; margin-bottom:0.3rem;">
                              Transférer le capitanat à <%= tm.user.profil&.first_name %> ?
                            </p>
                            <p style="color:var(--theme-text-muted); font-size:0.8rem; margin:0;">
                              Tu deviendras simple membre et tu perdras les droits de gestion de l'équipe.
                            </p>
                          </div>
                          <div class="modal-footer" style="border-top:1px solid var(--theme-border); padding:0.75rem 1.5rem; gap:0.5rem; justify-content:center;">
                            <button type="button"
                                    data-bs-dismiss="modal"
                                    style="font-size:0.8rem; font-weight:600; color:var(--theme-text-muted);
                                           background:var(--theme-hover-bg); border:1px solid var(--theme-border);
                                           border-radius:20px; padding:0.4rem 1rem; cursor:pointer;">
                              Annuler
                            </button>
                            <%= button_to transfer_captain_team_path(@team),
                                  method: :patch,
                                  params: { new_captain_id: tm.user_id },
                                  style: "font-size:0.8rem; font-weight:700; color:#fff;
                                          background:rgba(255,193,7,0.8); border:1px solid rgba(255,193,7,0.5);
                                          border-radius:20px; padding:0.4rem 1rem; cursor:pointer;" do %>
                              ⚡ Confirmer
                            <% end %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>

                <%# Avatar + nom cliquables → profil du membre %>
                <%= link_to user_profil_path(tm.user),
                      class: "team-member-card-link",
                      data: { turbo_frame: "_top" } do %>
                  <%# Avatar %>
                  <%# RGESN 5.2 — width/height évite le layout shift ; loading=lazy différé hors viewport %>
                  <% if tm.user.profil&.avatar&.attached? %>
                    <%= image_tag tm.user.profil.avatar, class: "team-member-card-avatar", alt: tm.user.profil.first_name, width: 40, height: 40, loading: "lazy" %>
                  <% else %>
                    <div class="team-member-card-avatar-placeholder">
                      <i data-lucide="user" style="width:22px;height:22px;color:var(--theme-text-muted);"></i>
                    </div>
                  <% end %>

                  <%# Nom %>
                  <span class="team-member-card-name">
                    <%= tm.user.profil&.first_name %> <%= tm.user.profil&.last_name %>
                  </span>

                  <%# Badge rôle %>
                  <span class="team-member-role-badge <%= tm.captain? ? 'captain' : 'member' %>">
                    <%= tm.captain? ? "👑 Capitaine" : "Membre" %>
                  </span>
                <% end %>

              </div>
            <% end %>
          </div>


        <% else %>
          <p style="color:var(--theme-text-muted); font-size:0.85rem;">Aucun membre pour l'instant.</p>
        <% end %>
      </div>
    </div>

    <%# ── Colonne invitations (captain seulement) ─────────────────────────── %>
    <% if @team.captain?(current_user) %>
      <div class="col-12 col-lg-5">

        <%# Formulaire d'invitation avec autocomplete %>
        <div class="team-section-card mb-3"
             data-controller="invite-search"
             data-invite-search-url-value="<%= search_team_team_invitations_path(@team) %>">
          <h2 class="team-section-title">
            <i data-lucide="user-plus" style="width:16px;height:16px;margin-right:6px;"></i>
            Inviter un joueur
          </h2>

          <%= form_with url: team_team_invitations_path(@team), method: :post, local: true do |f| %>
            <%# Input + bouton côte à côte %>
            <div class="invite-search-group">
              <input type="text"
                     data-invite-search-target="input"
                     data-action="input->invite-search#search"
                     placeholder="Email ou prénom…"
                     class="invite-search-input"
                     autocomplete="off">
              <%= f.submit "Inviter", class: "invite-search-btn" %>
            </div>

            <%# Dropdown des résultats %>
            <div data-invite-search-target="dropdown" class="invite-search-dropdown"></div>

            <%# Champ caché soumis avec l'email de la personne sélectionnée %>
            <%= f.hidden_field :invitee_query, data: { "invite-search-target": "hidden" } %>
          <% end %>
        </div>

        <%# Amis invitables %>
        <% if @invitable_friends&.any? %>
          <div class="team-section-card mb-3">
            <h2 class="team-section-title">
              <i data-lucide="users" style="width:16px;height:16px;margin-right:6px;"></i>
              Mes amis
            </h2>
            <ul class="team-members-list">
              <% @invitable_friends.each do |friend| %>
                <li class="team-member-item">
                  <%# Avatar + nom cliquables → profil de l'ami %>
                  <%= link_to user_profil_path(friend),
                        style: "display:flex; align-items:center; gap:0.6rem; text-decoration:none; flex:1; min-width:0;",
                        data: { turbo_frame: "_top" } do %>
                    <%# Avatar %>
                    <% if friend.profil&.avatar&.attached? %>
                      <%# RGESN 5.2 — width/height + lazy-loading %>
                      <%= image_tag friend.profil.avatar, class: "team-member-avatar", alt: friend.profil.first_name, width: 28, height: 28, loading: "lazy" %>
                    <% else %>
                      <div class="team-member-avatar-placeholder">
                        <i data-lucide="user" style="width:18px;height:18px;color:var(--theme-text-muted);"></i>
                      </div>
                    <% end %>

                    <%# Nom %>
                    <div class="team-member-info">
                      <span class="team-member-name">
                        <%= friend.profil&.first_name %> <%= friend.profil&.last_name %>
                      </span>
                    </div>
                  <% end %>

                  <%# Bouton inviter — vert %>
                  <%= button_to team_team_invitations_path(@team),
                      method: :post,
                      params: { invitee_query: friend.email },
                      class: "btn btn-xs btn-outline-success" do %>
                    <i data-lucide="user-plus" style="width:11px;height:11px;margin-right:3px;"></i>
                    Inviter
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# Invitations en attente %>
        <div class="team-section-card mb-3">
          <h2 class="team-section-title">
            <i data-lucide="clock" style="width:16px;height:16px;margin-right:6px;"></i>
            Invitations en attente
          </h2>

          <% if @pending_invitations&.any? %>
            <ul class="team-invitations-list">
              <% @pending_invitations.each do |inv| %>
                <li class="team-invitation-item">
                  <%# Nom cliquable → profil de l'invité en attente %>
                  <%= link_to user_profil_path(inv.invitee),
                        style: "text-decoration:none;",
                        data: { turbo_frame: "_top" } do %>
                    <span class="team-member-name">
                      <%= inv.invitee.profil&.first_name %> <%= inv.invitee.profil&.last_name %>
                    </span>
                  <% end %>
                  <div class="d-flex align-items-center gap-2">
                    <span style="font-size:0.75rem;color:var(--theme-text-muted);">En attente</span>
                    <%= button_to team_team_invitation_path(@team, inv),
                        method: :delete,
                        class: "btn btn-xs btn-outline-danger",
                        data: { confirm: "Annuler l'invitation de #{inv.invitee.profil&.first_name} ?" } do %>
                      <i data-lucide="x" style="width:11px;height:11px;"></i>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p style="color:var(--theme-text-muted); font-size:0.85rem;">Aucune invitation en attente.</p>
          <% end %>
        </div>

        <%# Propositions des membres en attente de validation %>
        <% if @pending_proposals&.any? %>
          <div class="team-section-card">
            <h2 class="team-section-title">
              <i data-lucide="user-check" style="width:16px;height:16px;margin-right:6px;"></i>
              Propositions des membres
            </h2>
            <ul class="team-invitations-list">
              <% @pending_proposals.each do |prop| %>
                <li class="team-invitation-item" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                  <%# Info joueur proposé %>
                  <div style="display:flex; align-items:center; gap:0.5rem; width:100%;">
                    <%= link_to user_profil_path(prop.invitee),
                          style: "text-decoration:none; flex:1;",
                          data: { turbo_frame: "_top" } do %>
                      <span class="team-member-name">
                        <%= prop.invitee.profil&.first_name %> <%= prop.invitee.profil&.last_name %>
                      </span>
                    <% end %>
                    <%# Proposé par %>
                    <span style="font-size:0.7rem; color:var(--theme-text-muted);">
                      par <%= prop.proposed_by&.profil&.first_name %>
                    </span>
                  </div>
                  <%# Boutons valider / refuser %>
                  <div class="d-flex gap-2">
                    <%= button_to review_team_team_invitation_path(@team, prop),
                          method: :patch,
                          params: { decision: "approve" },
                          class: "btn btn-xs btn-outline-success" do %>
                      <i data-lucide="check" style="width:11px;height:11px;margin-right:3px;"></i>
                      Valider
                    <% end %>
                    <%= button_to review_team_team_invitation_path(@team, prop),
                          method: :patch,
                          params: { decision: "decline" },
                          class: "btn btn-xs btn-outline-danger" do %>
                      <i data-lucide="x" style="width:11px;height:11px;margin-right:3px;"></i>
                      Refuser
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

      </div>
    <% elsif @team.member?(current_user) %>
      <%# ── Colonne "Proposer un joueur" (membres non-capitaines) ────────────── %>
      <div class="col-12 col-lg-5">
        <div class="team-section-card">
          <h2 class="team-section-title">
            <i data-lucide="user-plus" style="width:16px;height:16px;margin-right:6px;"></i>
            Proposer un joueur
          </h2>
          <p style="font-size:0.78rem; color:var(--theme-text-muted); margin-bottom:0.75rem;">
            Propose un ami au capitaine — il validera ou refusera la demande.
          </p>

          <% if @proposable_friends&.any? %>
            <ul class="team-members-list">
              <% @proposable_friends.each do |friend| %>
                <li class="team-member-item">
                  <%# Avatar + nom cliquables %>
                  <%= link_to user_profil_path(friend),
                        style: "display:flex; align-items:center; gap:0.6rem; text-decoration:none; flex:1; min-width:0;",
                        data: { turbo_frame: "_top" } do %>
                    <% if friend.profil&.avatar&.attached? %>
                      <%# RGESN 5.2 — width/height + lazy-loading %>
                      <%= image_tag friend.profil.avatar, class: "team-member-avatar", alt: friend.profil.first_name, width: 28, height: 28, loading: "lazy" %>
                    <% else %>
                      <div class="team-member-avatar-placeholder">
                        <i data-lucide="user" style="width:18px;height:18px;color:var(--theme-text-muted);"></i>
                      </div>
                    <% end %>
                    <div class="team-member-info">
                      <span class="team-member-name">
                        <%= friend.profil&.first_name %> <%= friend.profil&.last_name %>
                      </span>
                    </div>
                  <% end %>

                  <%# Bouton proposer — vert pour bien ressortir %>
                  <%= button_to propose_team_team_invitations_path(@team),
                        method: :post,
                        params: { invitee_query: friend.email },
                        class: "btn btn-xs btn-outline-success" do %>
                    <i data-lucide="send" style="width:11px;height:11px;margin-right:3px;"></i>
                    Proposer
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p style="color:var(--theme-text-muted); font-size:0.85rem; margin:0;">
              Tous tes amis sont déjà membres ou ont déjà une invitation en attente.
            </p>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

  <%# ── Section matchs de l'équipe ─────────────────────────────────────────── %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="team-section-card">

        <%# En-tête de la section matchs %>
        <h2 class="team-section-title" style="margin-bottom:1rem;">
          <i data-lucide="calendar" style="width:16px;height:16px;margin-right:6px;"></i>
          Matchs de l'équipe
        </h2>

        <%# Liste des matchs liés à cette équipe %>
        <% team_matches = @team.matches.includes(:sport, user: :profil).order(date: :asc, time: :asc) %>
        <% if team_matches.any? %>
          <div style="display:flex; flex-direction:column; gap:0.5rem;">
            <% team_matches.each do |match| %>
              <%= link_to match_path(match), style: "display:flex; align-items:center; gap:0.75rem; padding:0.6rem 0.75rem; border-radius:8px; background:var(--theme-hover-bg); border:1px solid var(--theme-border); text-decoration:none; transition:background 0.15s;", data: { turbo_frame: "_top" } do %>

                <%# Icône sport %>
                <div style="flex-shrink:0; width:34px; height:34px; border-radius:6px; background:rgba(30,221,136,0.1); display:flex; align-items:center; justify-content:center;">
                  <span style="font-size:1rem;line-height:1;"><%= match.sport&.icon.presence || "🏃" %></span>
                </div>

                <%# Infos match %>
                <div style="flex:1; min-width:0;">
                  <div style="font-size:0.85rem; font-weight:700; color:var(--theme-text-strong); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                    <%= match.title %>
                  </div>
                  <div style="font-size:0.72rem; color:var(--theme-text-muted);">
                    <%= match.date&.strftime("%d %b %Y") %> à <%= match.time&.strftime("%H:%M") %>
                    <% if match.place.present? %> · <%= match.place %><% end %>
                  </div>
                </div>

                <%# Badge visibilité %>
                <% if match.private? %>
                  <span style="font-size:0.68rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:20px; background:rgba(255,165,0,0.15); color:#FFA500;">
                    <i data-lucide="lock" style="width:9px;height:9px;margin-right:2px;"></i>Privé
                  </span>
                <% else %>
                  <span style="font-size:0.68rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:20px; background:rgba(30,221,136,0.15); color:#1EDD88;">
                    <i data-lucide="globe" style="width:9px;height:9px;margin-right:2px;"></i>Public
                  </span>
                <% end %>

              <% end %>
            <% end %>
          </div>
        <% else %>
          <p style="color:var(--theme-text-muted); font-size:0.85rem; margin:0;">
            Aucun match pour cette équipe.
            <% if @team.captain?(current_user) %>
              <%= link_to "Créer le premier !", new_match_path(team_id: @team.id), style: "color:#1EDD88;", data: { turbo_frame: "_top" } %>
            <% end %>
          </p>
        <% end %>

      </div>
    </div>
  </div>


  <%# ── Bouton d'accès au chat (membres uniquement) ──────────────────────────── %>
  <% if @team.member?(current_user) %>
    <div class="row mt-4">
      <div class="col-12">
        <%# Abonnement Turbo Stream — reçoit les broadcasts de la page équipe (stream séparé du sticky)
            Placé ici (hors modale) pour être toujours actif, même si la modale n'est pas ouverte %>
        <%= turbo_stream_from "team_chat_page_#{@team.id}" %>

        <div class="team-chat-card">
          <div class="team-chat-card-left">
            <div class="team-chat-card-icon">
              <i data-lucide="message-circle" style="width:16px;height:16px;"></i>
            </div>
            <div>
              <div class="team-chat-card-title">Chat de l'équipe</div>
              <%# id="team-page-last-message-*" : mis à jour en temps réel via Turbo Stream %>
              <%= render "teams/chat_page_preview", team: @team %>
            </div>
          </div>
          <button class="team-chat-card-btn"
                  data-bs-toggle="modal"
                  data-bs-target="#teamChatModal">
            Ouvrir le chat
            <i data-lucide="arrow-right" style="width:13px;height:13px;"></i>
          </button>
        </div>
      </div>
    </div>

    <%# ── Modale chat d'équipe ─────────────────────────────────────────────────
        Structure identique à la modale chat du match show.
        data-controller="chat" : auto-scroll, style "mine", Entrée pour envoyer
        data-action="shown.bs.modal->chat#onModalOpen" : scroll en bas à l'ouverture %>
    <div class="modal fade"
         id="teamChatModal"
         tabindex="-1"
         data-controller="chat"
         data-chat-current-user-id-value="<%= current_user.id %>"
         data-action="shown.bs.modal->chat#onModalOpen">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content chat-modal-content">

          <%# En-tête %>
          <div class="modal-header chat-header">
            <div class="d-flex align-items-center gap-2">
              <span class="chat-header-icon">🛡️</span>
              <div>
                <div class="chat-header-title"><%= @team.name %></div>
                <div class="chat-header-subtitle">
                  <%= @team.members_count %> membre<%= @team.members_count > 1 ? "s" : "" %>
                </div>
              </div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>

          <%# Zone scrollable des messages
              id="team-chat-messages" : cible du broadcast dans Message#broadcast_team_message
              data-chat-target="messages" : utilisé par chat_controller.js pour l'auto-scroll
              chat-messages--team : fond bleu pour différencier du chat de match (vert) %>
          <div class="modal-body p-0">
            <div class="chat-messages chat-messages--team"
                 id="team-chat-messages"
                 data-chat-target="messages">
              <% team_messages = @team.messages.includes(user: :profil).order(:created_at).last(50) %>
              <% if team_messages.any? %>
                <%= render team_messages %>
              <% else %>
                <%# id="chat-empty" ciblé par chat_controller.js → supprimé au 1er message %>
                <div class="chat-empty text-center py-5" id="chat-empty">
                  <div class="mb-2" style="font-size:2rem;">🛡️</div>
                  <p>Soyez les premiers à chatter !</p>
                </div>
              <% end %>
            </div>
          </div>

          <%# Formulaire d'envoi
              id="team-chat-form" : réinitialisé par MessagesController#create après envoi %>
          <div class="modal-footer p-2 border-top" id="team-chat-form">
            <%= render "messages/form", team: @team, message: Message.new %>
          </div>

        </div>
      </div>
    </div>
  <% end %>

</div>
</div>
