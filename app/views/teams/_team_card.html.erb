<%# ── Carte résumé d'une équipe — affichée dans /teams ───────────────────── %>
<%# Variables attendues : team (Team) %>

<%= link_to team_path(team), style: "text-decoration:none;" do %>
  <div class="team-card">

    <%# Blason — priorité : SVG généré > image uploadée > placeholder
        Le SVG du badge builder passe en premier car il représente le blason
        tel que le capitaine l'a conçu. L'image uploadée est un fallback
        (anciens blasons migrés). %>
    <div class="team-card-badge">
      <% if team.badge_svg.present? %>
        <%# SVG généré par le badge builder — rendu inline en sécurité %>
        <div class="team-card-badge-svg"><%= team.badge_svg.html_safe %></div>
      <% elsif team.badge_image.attached? %>
        <%# Fallback : image uploadée directement (ancienne version) %>
        <%= image_tag team.badge_image, alt: "Blason #{team.name}", class: "team-card-badge-img" %>
      <% else %>
        <%# Placeholder par défaut si aucun blason %>
        <div class="team-card-badge-placeholder">
          <i data-lucide="shield" style="width:32px;height:32px;color:var(--theme-text-muted);"></i>
        </div>
      <% end %>
    </div>

    <%# Infos %>
    <div class="team-card-body">
      <h3 class="team-card-name"><%= team.name %></h3>

      <%# Rôle de l'user dans cette équipe %>
      <% tm = team.team_members.find { |m| m.user_id == current_user.id } %>
      <span class="team-card-role <%= tm&.captain? ? 'captain' : 'member' %>">
        <%= tm&.captain? ? "👑 Capitaine" : "Membre" %>
      </span>

      <p class="team-card-meta">
        <i data-lucide="users" style="width:12px;height:12px;margin-right:3px;"></i>
        <%= team.team_members.size %> membre<%= team.team_members.size > 1 ? "s" : "" %>
      </p>
    </div>

  </div>
<% end %>
